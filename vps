# ─── Status Printer ───────────────────────────────────────────────────────────
print_status() {
    local type=$1
    local message=$2
    case $type in
        "INFO")    echo -e "  ${BG_DARKER}${LBLUE}${BOLD} 📋 INFO    ${RESET} ${SKY}${message}${RESET}" ;;
        "WARN")    echo -e "  ${BG_DARKER}${GOLD}${BOLD} ⚠️  WARN    ${RESET} ${AMBER}${message}${RESET}" ;;
        "ERROR")   echo -e "  ${BG_DARKER}${RED}${BOLD} ❌ ERROR   ${RESET} ${CORAL}${message}${RESET}" ;;
        "SUCCESS") echo -e "  ${BG_DARKER}${LIME}${BOLD} ✅ SUCCESS ${RESET} ${LGREEN}${message}${RESET}" ;;
        "INPUT")   echo -e "${CYAN}${BOLD}  ›› ${TEAL}${message}${RESET}" ;;
        "SECTION")
            echo
            echo -e "  ${PURPLE}╔══${GOLD}${BOLD}  ${message}  ${RESET}${PURPLE}$(printf '═%.0s' $(seq 1 $((60 - ${#message}))))╗${RESET}"
            echo
            ;;
        *)         echo -e "  [${type}] ${message}" ;;
    esac
}
 

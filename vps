# ─── Rainbow Text Function ────────────────────────────────────────────────────
rainbow_text() {
    local text="$1"
    local colors=('\033[38;5;196m' '\033[38;5;202m' '\033[38;5;208m' '\033[38;5;214m' '\033[38;5;220m' '\033[38;5;226m' '\033[38;5;154m' '\033[38;5;46m' '\033[38;5;51m' '\033[38;5;45m' '\033[38;5;21m' '\033[38;5;57m' '\033[38;5;93m' '\033[38;5;165m' '\033[38;5;201m')
    local len=${#text}
    local result=""
    for (( i=0; i<len; i++ )); do
        local color="${colors[$((i % ${#colors[@]}))]}"
        result+="${color}${text:$i:1}"
    done
    echo -e "${result}${RESET}"
}
 
# ─── Gradient Line ────────────────────────────────────────────────────────────
gradient_line() {
    local width="${1:-80}"

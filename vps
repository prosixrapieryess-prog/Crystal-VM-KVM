}
 
box_top()    { echo -e "  ${CYAN}╔$(printf '═%.0s' {1..70})╗${RESET}"; }
box_bottom() { echo -e "  ${CYAN}╚$(printf '═%.0s' {1..70})╝${RESET}"; }
box_line()   { printf "  ${CYAN}║${RESET} %-68s ${CYAN}║${RESET}\n" "$1"; }
 
# ─── Progress Spinner ─────────────────────────────────────────────
spinner() {
    local pid=$1
    local msg=$2
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${CYAN}${frames[$i]}${RESET}  ${WHITE}$msg${RESET}"
        i=$(( (i+1) % ${#frames[@]} ))
        sleep 0.1
    done
    printf "\r  ${GREEN}✓${RESET}  ${WHITE}$msg${RESET}\n"
}
 
# ─── Check Image Lock ─────────────────────────────────────────────
# Pass --check-only as $3 for a non-interactive, silent check (returns 0=free, 1=locked).
# Used internally by show_vm_info to avoid blocking reads.
check_image_lock() {
    local img_file=$1
    local vm_name=$2
    local check_only="${3:-}"          # FIX 4: non-interactive flag
 
    if lsof "$img_file" 2>/dev/null | grep -q qemu-system; then
        [[ "$check_only" == "--check-only" ]] && return 1   # FIX 4: bail silently
        print_status "WARN" "🔒 Image file is already in use by another QEMU process"
        local pid
        pid=$(lsof "$img_file" 2>/dev/null | awk '/qemu-system/{print $2; exit}')
        if [[ -n "$pid" ]]; then
            print_status "INFO" "🔍 Process ID: $pid"
            if ps -p "$pid" -o cmd= 2>/dev/null | grep -q "$vm_name"; then
                print_status "INFO" "🤔 This appears to be the same VM already running"
                read -rp "$(print_status "INPUT" "🔄 Kill existing process and restart? (y/N): ")" kill_choice
                if [[ "$kill_choice" =~ ^[Yy]$ ]]; then
                    kill "$pid" 2>/dev/null
                    sleep 2
                    if kill -0 "$pid" 2>/dev/null; then
                        kill -9 "$pid" 2>/dev/null
                        print_status "WARN" "⚠️  Forcefully terminated PID $pid"
                    fi
                    return 0
                else
                    return 1
                fi
            else
                print_status "ERROR" "🚫 Another QEMU instance is using this image"
                return 1
            fi
        fi
        return 1
    fi
 
    local lock_file="${img_file}.lock"
    if [[ -f "$lock_file" ]]; then
        [[ "$check_only" == "--check-only" ]] && return 1   # FIX 4: bail silently
        print_status "WARN" "🔒 Lock file found: $lock_file"
        if find "$lock_file" -mmin +5 2>/dev/null | grep -q .; then
            print_status "WARN" "⏰ Lock file is stale (older than 5 minutes)"
            read -rp "$(print_status "INPUT" "🗑️  Remove stale lock file? (y/N): ")" remove_lock
            if [[ "$remove_lock" =~ ^[Yy]$ ]]; then
                rm -f "$lock_file"
                print_status "SUCCESS" "✅ Removed stale lock file"
                return 0
            else
                return 1
            fi
        fi
        return 1
    fi
    return 0
}
 
# ─── Validate Input ───────────────────────────────────────────────
validate_input() {
    local type=$1
    local value=$2
    case $type in
        "number")
            [[ "$value" =~ ^[0-9]+$ ]] || { print_status "ERROR" "Must be a whole number"; return 1; }
            ;;
        "size")
            [[ "$value" =~ ^[0-9]+[GgMm]$ ]] || { print_status "ERROR" "Must be a size with unit (e.g., 100G, 512M)"; return 1; }
            ;;
        "port")
            if ! [[ "$value" =~ ^[0-9]+$ ]] || (( value < 23 || value > 65535 )); then
                print_status "ERROR" "Must be a valid port number (23–65535)"
                return 1
            fi
            ;;
        "name")
            [[ "$value" =~ ^[a-zA-Z0-9_-]+$ ]] || { print_status "ERROR" "Only letters, numbers, hyphens and underscores allowed"; return 1; }
            ;;
        "username")
            [[ "$value" =~ ^[a-z_][a-z0-9_-]*$ ]] || { print_status "ERROR" "Username must start with a letter/underscore; alphanumeric only"; return 1; }
            ;;
    esac
    return 0
}
 
# ─── Check Dependencies ───────────────────────────────────────────
check_dependencies() {
    print_status "INFO" "Checking dependencies..."
    local deps=("qemu-system-x86_64" "wget" "cloud-localds" "qemu-img" "lsof")
    local missing=()
    for dep in "${deps[@]}"; do
        command -v "$dep" &>/dev/null || missing+=("$dep")
    done
    if (( ${#missing[@]} > 0 )); then
        print_status "ERROR" "Missing: ${missing[*]}"
        print_status "INFO"  "Fix:  sudo apt install qemu-system cloud-image-utils wget lsof"
        exit 1
    fi
    print_status "SUCCESS" "All dependencies satisfied"
}
 
# ─── Cleanup ──────────────────────────────────────────────────────
cleanup() {
    rm -f "user-data" "meta-data" 2>/dev/null
}
trap cleanup EXIT
 
# ─── VM List ──────────────────────────────────────────────────────
get_vm_list() {
    find "$VM_DIR" -name "*.conf" -exec basename {} .conf \; 2>/dev/null | sort
}
 
# ─── Load Config ──────────────────────────────────────────────────
load_vm_config() {
    local vm_name=$1
    local config_file="$VM_DIR/$vm_name.conf"
    if [[ -f "$config_file" ]]; then
        unset VM_NAME OS_TYPE CODENAME IMG_URL HOSTNAME USERNAME PASSWORD \
              DISK_SIZE MEMORY CPUS SSH_PORT GUI_MODE PORT_FORWARDS IMG_FILE SEED_FILE CREATED
        # shellcheck source=/dev/null
        source "$config_file"
        return 0
    else
        print_status "ERROR" "Configuration for VM '$vm_name' not found"
        return 1
    fi
}
 
# ─── Save Config ──────────────────────────────────────────────────
save_vm_config() {
    local config_file="$VM_DIR/$VM_NAME.conf"
    cat > "$config_file" <<EOF
VM_NAME="$VM_NAME"
OS_TYPE="$OS_TYPE"
CODENAME="$CODENAME"
IMG_URL="$IMG_URL"
HOSTNAME="$HOSTNAME"
USERNAME="$USERNAME"
PASSWORD="$PASSWORD"
DISK_SIZE="$DISK_SIZE"
MEMORY="$MEMORY"
CPUS="$CPUS"
SSH_PORT="$SSH_PORT"
GUI_MODE="$GUI_MODE"
PORT_FORWARDS="$PORT_FORWARDS"
IMG_FILE="$IMG_FILE"
SEED_FILE="$SEED_FILE"
CREATED="$CREATED"
EOF
    print_status "SUCCESS" "💾 Config saved → $config_file"
}
 
# ─── Rebuild Cloud-Init Seed Only (FIX 7) ────────────────────────
# Separated from setup_vm_image so edits only rebuild the seed,
# not the full image (no download attempt, no disk resize).
rebuild_seed() {
    print_status "INFO" "🔄 Rebuilding cloud-init seed image..."
 
    local hashed_pw
    hashed_pw=$(openssl passwd -6 "$PASSWORD" | tr -d '\n')
 
    cat > user-data <<EOF
#cloud-config
hostname: $HOSTNAME
ssh_pwauth: true
disable_root: false
users:
  - name: $USERNAME
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    password: $hashed_pw
chpasswd:
  list: |
    root:$PASSWORD
    $USERNAME:$PASSWORD
  expire: false
EOF
 
    cat > meta-data <<EOF
instance-id: iid-$VM_NAME
local-hostname: $HOSTNAME
EOF
 
    rm -f "$SEED_FILE"
    if ! cloud-localds "$SEED_FILE" user-data meta-data; then
        print_status "ERROR" "Failed to create cloud-init seed image"
        return 1
    fi
    print_status "SUCCESS" "✅ Seed image rebuilt"
}
 
# ─── Setup VM Image ───────────────────────────────────────────────
setup_vm_image() {
    print_status "SECTION" "Image Setup"
    mkdir -p "$VM_DIR"
 
    # Download image if not present
    if [[ -f "$IMG_FILE" ]]; then
        print_status "INFO" "✅ Image already exists — skipping download"
    else
        print_status "INFO" "🌐 Downloading: $IMG_URL"
        if ! wget --progress=bar:force "$IMG_URL" -O "${IMG_FILE}.tmp"; then
            print_status "ERROR" "Download failed from $IMG_URL"
            exit 1
        fi
        mv "${IMG_FILE}.tmp" "$IMG_FILE"
        print_status "SUCCESS" "Download complete"
    fi
 
    # ── FIX 6: Resize safely ──────────────────────────────────────
    # The old overlay method created a qcow2 that referenced $IMG_FILE
    # as its backing store, then overwrote $IMG_FILE with that overlay —
    # producing a file that references itself (circular / broken image).
    # Instead, do an in-place resize; if that fails, convert to a new
    # standalone image at the target size, then replace the original.
    if ! qemu-img resize "$IMG_FILE" "$DISK_SIZE" 2>/dev/null; then
        print_status "WARN" "In-place resize failed — converting to new image at $DISK_SIZE..."
        local tmp="${IMG_FILE}.converting"
        if qemu-img convert -f qcow2 -O qcow2 "$IMG_FILE" "$tmp" && \
           qemu-img resize "$tmp" "$DISK_SIZE"; then
            mv "$tmp" "$IMG_FILE"
            print_status "SUCCESS" "Converted and resized successfully"
        else
            rm -f "$tmp"
            print_status "ERROR" "Could not resize image — leaving original intact"
            exit 1
        fi
    fi
 
    # Build cloud-init seed using the shared helper
    rebuild_seed
 
    echo
    box_top
    box_line "🎉  VM '$VM_NAME' created successfully!"
    box_line ""
    box_line "  👤  Username : $USERNAME"
    box_line "  🔑  Password : $PASSWORD"
    box_line "  🔌  SSH      : ssh -p $SSH_PORT $USERNAME@localhost"
    box_bottom
    echo
}
 
# ─── Create New VM ────────────────────────────────────────────────
create_new_vm() {
    print_status "SECTION" "Create New VM"
 
    # Build sorted OS list
    local os_keys=()
    mapfile -t os_keys < <(printf '%s\n' "${!OS_OPTIONS[@]}" | sort)
 
    echo -e "  ${CYAN}${BOLD}🌍 Available Operating Systems:${RESET}\n"
    local i=1
    for os in "${os_keys[@]}"; do
        printf "  ${GOLD}  %2d)${RESET}  ${WHITE}%s${RESET}\n" "$i" "$os"
        ((i++))
    done
    echo
 
    local os_count=${#os_keys[@]}
    while true; do
        read -rp "$(print_status "INPUT" "Select OS (1–$os_count): ")" choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= os_count )); then
            local os="${os_keys[$((choice-1))]}"
            IFS='|' read -r OS_TYPE CODENAME IMG_URL DEFAULT_HOSTNAME DEFAULT_USERNAME DEFAULT_PASSWORD \
                <<< "${OS_OPTIONS[$os]}"
            print_status "SUCCESS" "Selected: $os"
            break
        fi
        print_status "ERROR" "Invalid selection"
    done
 
    divider
    echo
 
    while true; do
        read -rp "$(print_status "INPUT" "🏷️  VM name        [default: $DEFAULT_HOSTNAME]: ")" VM_NAME
        VM_NAME="${VM_NAME:-$DEFAULT_HOSTNAME}"
        if validate_input "name" "$VM_NAME"; then
            if [[ -f "$VM_DIR/$VM_NAME.conf" ]]; then
                print_status "ERROR" "VM '$VM_NAME' already exists"
            else
                break
            fi
        fi
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "🏠 Hostname       [default: $VM_NAME]: ")" HOSTNAME
        HOSTNAME="${HOSTNAME:-$VM_NAME}"
        validate_input "name" "$HOSTNAME" && break
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "👤 Username       [default: $DEFAULT_USERNAME]: ")" USERNAME
        USERNAME="${USERNAME:-$DEFAULT_USERNAME}"
        validate_input "username" "$USERNAME" && break
    done
 
    while true; do
        read -rsp "$(print_status "INPUT" "🔑 Password       [default: $DEFAULT_PASSWORD]: ")" PASSWORD
        PASSWORD="${PASSWORD:-$DEFAULT_PASSWORD}"
        echo
        [[ -n "$PASSWORD" ]] && break
        print_status "ERROR" "Password cannot be empty"
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "💾 Disk size      [default: 20G]: ")" DISK_SIZE
        DISK_SIZE="${DISK_SIZE:-20G}"
        validate_input "size" "$DISK_SIZE" && break
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "🧠 Memory (MB)    [default: 2048]: ")" MEMORY
        MEMORY="${MEMORY:-2048}"
        validate_input "number" "$MEMORY" && break
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "⚡ CPUs           [default: 2]: ")" CPUS
        CPUS="${CPUS:-2}"
        validate_input "number" "$CPUS" && break
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "🔌 SSH Port       [default: 2222]: ")" SSH_PORT
        SSH_PORT="${SSH_PORT:-2222}"
        if validate_input "port" "$SSH_PORT"; then
            if ss -tln 2>/dev/null | grep -q ":$SSH_PORT "; then
                print_status "ERROR" "Port $SSH_PORT is already in use"
            else
                break
            fi
        fi
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "🖥️  Enable GUI     [y/n, default: n]: ")" gui_input
        gui_input="${gui_input:-n}"
        if [[ "$gui_input" =~ ^[Yy]$ ]]; then GUI_MODE=true; break
        elif [[ "$gui_input" =~ ^[Nn]$ ]]; then GUI_MODE=false; break
        else print_status "ERROR" "Please answer y or n"
        fi
    done
 
    read -rp "$(print_status "INPUT" "🌐 Extra port-forwards (e.g. 8080:80,3000:3000 or Enter for none): ")" PORT_FORWARDS
 
    IMG_FILE="$VM_DIR/$VM_NAME.img"
    SEED_FILE="$VM_DIR/$VM_NAME-seed.iso"
    CREATED="$(date)"
 
    setup_vm_image
    save_vm_config
}
 
# ─── Is VM Running? ───────────────────────────────────────────────
is_vm_running() {
    local vm_name=$1
    pgrep -f "qemu-system.*$vm_name" >/dev/null 2>&1 && return 0
    if load_vm_config "$vm_name" 2>/dev/null && [[ -n "${IMG_FILE:-}" ]]; then
        pgrep -f "qemu-system.*$IMG_FILE" >/dev/null 2>&1 && return 0
    fi
    return 1
}
 
# ─── Stop VM ──────────────────────────────────────────────────────
stop_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    if is_vm_running "$vm_name"; then
        print_status "INFO" "🛑 Stopping VM: $vm_name"
        pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
        sleep 2
        if is_vm_running "$vm_name"; then
            print_status "WARN" "VM did not stop gracefully — forcing termination..."
            pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            sleep 1
        fi
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true
        if is_vm_running "$vm_name"; then
            print_status "ERROR" "Failed to stop VM"
            return 1
        fi
        print_status "SUCCESS" "✅ VM $vm_name stopped"
    else
        print_status "INFO" "💤 VM $vm_name is already stopped"
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true
    fi
}
 
# ─── Start VM ─────────────────────────────────────────────────────
start_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    if ! check_image_lock "$IMG_FILE" "$vm_name"; then
        print_status "ERROR" "🔒 Image file is locked by another process"
        read -rp "$(print_status "INPUT" "Force kill all QEMU processes using this image? (y/N): ")" force_kill
        if [[ "$force_kill" =~ ^[Yy]$ ]]; then
            pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            sleep 2
            pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            rm -f "${IMG_FILE}.lock" 2>/dev/null || true
            print_status "SUCCESS" "Cleared"
        else
            return 1
        fi
    fi
 
    if is_vm_running "$vm_name"; then
        print_status "WARN" "VM '$vm_name' is already running"
        read -rp "$(print_status "INPUT" "Stop and restart? (y/N): ")" restart_choice
        [[ "$restart_choice" =~ ^[Yy]$ ]] && stop_vm "$vm_name" && sleep 2 || return 1
    fi
 
    [[ -f "$IMG_FILE" ]] || { print_status "ERROR" "VM image not found: $IMG_FILE"; return 1; }
    if [[ ! -f "$SEED_FILE" ]]; then
        print_status "WARN" "Seed file missing — recreating..."
        rebuild_seed    # FIX 7: use focused helper, not full setup_vm_image
    fi
 
    echo
    box_top
    box_line "🚀  Starting VM: $vm_name"
    box_line ""
    box_line "  🔌  SSH  : ssh -p $SSH_PORT $USERNAME@localhost"
    box_line "  🔑  Pass : $PASSWORD"
    box_line "  💿  RAM  : ${MEMORY}MB   CPUs: ${CPUS}   Disk: ${DISK_SIZE}"
    box_line "  🐌  Mode : Pure software emulation (TCG)"
    box_bottom
    echo
 
    # ── FIX 3: Build a single netdev string with all hostfwd entries ──
    # The original code added a new NIC (-device virtio-net-pci + -netdev)
    # for every extra port forward, causing the guest OS to see multiple
    # unexpected network interfaces.  QEMU supports multiple hostfwd=
    # options on one netdev, which is the correct approach.
    local netdev_str="user,id=net0,hostfwd=tcp::${SSH_PORT}-:22"
    if [[ -n "${PORT_FORWARDS:-}" ]]; then
        IFS=',' read -ra forwards <<< "$PORT_FORWARDS"
        for forward in "${forwards[@]}"; do
            forward="${forward// /}"   # strip any stray spaces
            IFS=':' read -r host_port guest_port <<< "$forward"
            netdev_str+=",hostfwd=tcp::${host_port}-:${guest_port}"
        done
    fi
 
    local qemu_cmd=(
        qemu-system-x86_64
        -m "$MEMORY"
        -smp "$CPUS"
        -cpu qemu64
        -machine type=pc,accel=tcg
        -drive "file=$IMG_FILE,format=qcow2,if=virtio"
        -drive "file=$SEED_FILE,format=raw,if=virtio"
        -boot order=c
        -device virtio-net-pci,netdev=net0
        -netdev "$netdev_str"
        -device virtio-balloon-pci
        -object "rng-random,filename=/dev/urandom,id=rng0"
        -device virtio-rng-pci,rng=rng0
        -no-hpet
        -rtc base=utc,clock=host
    )
 
    if [[ "${GUI_MODE}" == true ]]; then
        qemu_cmd+=(-vga virtio -display gtk,gl=on)
        print_status "INFO" "🖥️  GUI mode active"
    else
        qemu_cmd+=(-nographic -serial mon:stdio)
        print_status "INFO" "📟 Console mode  |  Ctrl+A then X to quit"
    fi
 
    if ! "${qemu_cmd[@]}"; then
        print_status "ERROR" "QEMU failed to start. Check config or image integrity."
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true
        return 1
    fi
 
    print_status "INFO" "VM $vm_name has shut down"
}
 
# ─── Delete VM ────────────────────────────────────────────────────
delete_vm() {
    local vm_name=$1
    echo
    print_status "WARN" "⚠️  This will PERMANENTLY delete VM '$vm_name' and all data!"
    read -rp "$(print_status "INPUT" "Type the VM name to confirm deletion: ")" confirm_name
    if [[ "$confirm_name" == "$vm_name" ]]; then
        load_vm_config "$vm_name" || return 1
        if is_vm_running "$vm_name"; then
            print_status "WARN" "VM is running — stopping first..."
            stop_vm "$vm_name"
            sleep 2
        fi
        rm -f "$IMG_FILE" "$SEED_FILE" "$VM_DIR/$vm_name.conf" "${IMG_FILE}.lock" 2>/dev/null || true
        print_status "SUCCESS" "VM '$vm_name' permanently deleted"
    else
        print_status "INFO" "Name mismatch — deletion cancelled"
    fi
}
 
# ─── Show VM Info ─────────────────────────────────────────────────
show_vm_info() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 

                        fi
                    fi
                done ;;
            5)
                while true; do
                    read -rp "$(print_status "INPUT" "Enable GUI? (y/n) [current: ${GOLD}$GUI_MODE${RESET}]: ")" v
                    v="${v:-}"
                    if [[ "$v" =~ ^[Yy]$ ]]; then GUI_MODE=true; break

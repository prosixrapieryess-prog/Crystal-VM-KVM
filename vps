# ─── Colored Status Printer ───────────────────────────────────────
print_status() {
    local type=$1
    local message=$2
    case $type in
        "INFO")    echo -e "  ${LBLUE}${BOLD}📋 INFO   ${RESET}${WHITE}$message${RESET}" ;;
        "WARN")    echo -e "  ${GOLD}${BOLD}⚠️  WARN   ${RESET}${YELLOW}$message${RESET}" ;;
        "ERROR")   echo -e "  ${RED}${BOLD}❌ ERROR  ${RESET}${RED}$message${RESET}" ;;
        "SUCCESS") echo -e "  ${LGREEN}${BOLD}✅ SUCCESS${RESET}${GREEN}$message${RESET}" ;;
        "INPUT")   echo -e "${CYAN}${BOLD}  🎯 ${message}${RESET}" ;;
        "SECTION") echo -e "\n  ${MAGENTA}${BOLD}━━━  $message  ━━━${RESET}\n" ;;
        *)         echo -e "  [$type] $message" ;;
    esac
}
 
# ─── Divider / Decorators ─────────────────────────────────────────
divider() {

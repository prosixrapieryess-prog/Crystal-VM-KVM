            printf "  ${CYAN}║${RESET}  ${GOLD}  2)${RESET}  🚀  ${LIME}Start a VM%62s${CYAN}║${RESET}\n" ""
            printf "  ${CYAN}║${RESET}  ${GOLD}  3)${RESET}  🛑  ${CORAL}Stop a VM%63s${CYAN}║${RESET}\n" ""
            printf "  ${CYAN}║${RESET}  ${GOLD}  4)${RESET}  📊  ${SKY}Show VM info%60s${CYAN}║${RESET}\n" ""
            printf "  ${CYAN}║${RESET}  ${GOLD}  5)${RESET}  ✏️   ${AMBER}Edit VM configuration%51s${CYAN}║${RESET}\n" ""
            printf "  ${CYAN}║${RESET}  ${GOLD}  6)${RESET}  🗑️   ${RED}Delete a VM%61s${CYAN}║${RESET}\n" ""
            printf "  ${CYAN}║${RESET}  ${GOLD}  7)${RESET}  📈  ${TEAL}Resize VM disk%58s${CYAN}║${RESET}\n" ""
            printf "  ${CYAN}║${RESET}  ${GOLD}  8)${RESET}  📊  ${LBLUE}Show performance%56s${CYAN}║${RESET}\n" ""
            printf "  ${CYAN}║${RESET}  ${GOLD}  9)${RESET}  🔧  ${VIOLET}Fix VM issues%59s${CYAN}║${RESET}\n" ""
        fi
        box_sep
        printf "  ${CYAN}║${RESET}  ${RED}  0)${RESET}  👋  ${CORAL}Exit%68s${CYAN}║${RESET}\n" ""
        box_bottom
        echo
 
        read -rp "$(print_status "INPUT" "Your choice: ")" choice
 
        local vm
        case $choice in
            1) create_new_vm ;;
            2)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "Select VM to start"); [[ -n "$vm" ]] && start_vm "$vm" ;;
            3)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "Select VM to stop"); [[ -n "$vm" ]] && stop_vm "$vm" ;;
            4)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "Select VM to inspect"); [[ -n "$vm" ]] && show_vm_info "$vm" ;;
            5)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "Select VM to edit"); [[ -n "$vm" ]] && edit_vm_config "$vm" ;;
            6)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "Select VM to delete"); [[ -n "$vm" ]] && delete_vm "$vm" ;;
            7)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "Select VM to resize"); [[ -n "$vm" ]] && resize_vm_disk "$vm" ;;
            8)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "Select VM to inspect"); [[ -n "$vm" ]] && show_vm_performance "$vm" ;;
            9)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "Select VM to fix"); [[ -n "$vm" ]] && fix_vm_issues "$vm" ;;
            0)
                echo
                gradient_line 60
                echo -e "  ${PURPLE}${BOLD}  👋  Thanks for using ProXLegendYT VM Manager!${RESET}"
                echo -e "  ${DIM}${PINK}  ✦  Ultra Edition  •  v4.2.0  •  See you next time!  ${RESET}"
                gradient_line 60
                echo
                exit 0 ;;
            *)
                print_status "ERROR" "Invalid option — please choose from the menu" ;;
        esac
 
        echo
        read -rp "$(print_status "INPUT" "⏎  Press Enter to continue...")"
    done
}
 

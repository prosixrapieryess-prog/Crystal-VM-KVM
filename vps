cleanup() {
    rm -f "user-data" "meta-data" 2>/dev/null
}
trap cleanup EXIT
 
# ─── VM List ──────────────────────────────────────────────────────────────────
get_vm_list() {
    find "$VM_DIR" -name "*.conf" -exec basename {} .conf \; 2>/dev/null | sort
}
 
# ─── Load Config ──────────────────────────────────────────────────────────────
load_vm_config() {
    local vm_name=$1
    local config_file="$VM_DIR/$vm_name.conf"
    if [[ -f "$config_file" ]]; then
        unset VM_NAME OS_TYPE CODENAME IMG_URL HOSTNAME USERNAME PASSWORD \
              DISK_SIZE MEMORY CPUS SSH_PORT GUI_MODE PORT_FORWARDS IMG_FILE SEED_FILE CREATED
        # shellcheck source=/dev/null
        source "$config_file"
        return 0
    else
        print_status "ERROR" "Configuration for VM '${GOLD}$vm_name${RESET}' not found"
        return 1
    fi
}
 
# ─── Save Config ──────────────────────────────────────────────────────────────
save_vm_config() {
    local config_file="$VM_DIR/$VM_NAME.conf"
    cat > "$config_file" <<EOF
VM_NAME="$VM_NAME"
OS_TYPE="$OS_TYPE"
CODENAME="$CODENAME"
IMG_URL="$IMG_URL"
HOSTNAME="$HOSTNAME"
USERNAME="$USERNAME"
PASSWORD="$PASSWORD"
DISK_SIZE="$DISK_SIZE"
MEMORY="$MEMORY"
CPUS="$CPUS"
SSH_PORT="$SSH_PORT"
GUI_MODE="$GUI_MODE"
PORT_FORWARDS="$PORT_FORWARDS"
IMG_FILE="$IMG_FILE"
SEED_FILE="$SEED_FILE"
CREATED="$CREATED"
EOF
    print_status "SUCCESS" "💾 Config saved  →  ${SKY}$config_file${RESET}"
}
 
# ─── Rebuild Cloud-Init Seed ──────────────────────────────────────────────────
rebuild_seed() {
    print_status "INFO" "🔄 Rebuilding cloud-init seed image..."
 
    local hashed_pw
    hashed_pw=$(openssl passwd -6 "$PASSWORD" | tr -d '\n')
 
    cat > user-data <<EOF
#cloud-config
hostname: $HOSTNAME
ssh_pwauth: true
disable_root: false
users:
  - name: $USERNAME
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    password: $hashed_pw
chpasswd:
  list: |
    root:$PASSWORD
    $USERNAME:$PASSWORD
  expire: false
EOF
 
    cat > meta-data <<EOF
instance-id: iid-$VM_NAME
local-hostname: $HOSTNAME
EOF
 
    rm -f "$SEED_FILE"
    if ! cloud-localds "$SEED_FILE" user-data meta-data; then
        print_status "ERROR" "Failed to create cloud-init seed image"
        return 1
    fi
    print_status "SUCCESS" "✅ Seed image rebuilt successfully"
}
 
# ─── Setup VM Image ───────────────────────────────────────────────────────────
setup_vm_image() {
    print_status "SECTION" "🖥️  Image Setup"
    mkdir -p "$VM_DIR"
 
    if [[ -f "$IMG_FILE" ]]; then
        print_status "INFO" "✅ Image already exists — skipping download"
    else
        print_status "INFO" "🌐 Downloading: ${SKY}$IMG_URL${RESET}"
        if ! wget --progress=bar:force "$IMG_URL" -O "${IMG_FILE}.tmp"; then
            print_status "ERROR" "Download failed from $IMG_URL"
            exit 1
        fi
        mv "${IMG_FILE}.tmp" "$IMG_FILE"
        print_status "SUCCESS" "Download complete"
    fi
 
    if ! qemu-img resize "$IMG_FILE" "$DISK_SIZE" 2>/dev/null; then
        print_status "WARN" "In-place resize failed — converting to new image at $DISK_SIZE..."
        local tmp="${IMG_FILE}.converting"
        if qemu-img convert -f qcow2 -O qcow2 "$IMG_FILE" "$tmp" && \
           qemu-img resize "$tmp" "$DISK_SIZE"; then
            mv "$tmp" "$IMG_FILE"
            print_status "SUCCESS" "Converted and resized successfully"
        else
            rm -f "$tmp"
            print_status "ERROR" "Could not resize image — leaving original intact"
            exit 1
        fi
    fi
 
    rebuild_seed
 
    echo
    gradient_line 76
    box_top
    box_line ""
    box_line "  🎉  VM '${VM_NAME}' created successfully!" "${GOLD}${BOLD}"
    box_sep
    box_line ""
    box_line_colored "  👤  Username" "$USERNAME"
    box_line_colored "  🔑  Password" "$PASSWORD"
    box_line_colored "  🔌  SSH"      "ssh -p $SSH_PORT $USERNAME@localhost"
    box_line_colored "  💾  Disk"     "$DISK_SIZE  |  🧠 RAM: ${MEMORY}MB  |  ⚡ CPUs: $CPUS"
    box_line ""
    box_bottom
    gradient_line 76
    echo
}
 
# ─── Create New VM ────────────────────────────────────────────────────────────
create_new_vm() {
    print_status "SECTION" "🆕  Create New Virtual Machine"
 
    local os_keys=()
    mapfile -t os_keys < <(printf '%s\n' "${!OS_OPTIONS[@]}" | sort)
 
    echo
    box_top
    box_line "  🌍  Available Operating Systems" "${GOLD}${BOLD}"
    box_sep
    local i=1
    for os in "${os_keys[@]}"; do
        local icon="🐧"
        [[ "$os" == *Ubuntu* ]]  && icon="🟠"
        [[ "$os" == *Debian* ]]  && icon="🔴"
        [[ "$os" == *Fedora* ]]  && icon="🔵"
        [[ "$os" == *CentOS* ]]  && icon="🟣"
        [[ "$os" == *Alma* ]]    && icon="⚡"
        [[ "$os" == *Rocky* ]]   && icon="🟢"
        # Pick a gradient color per entry
        local entry_colors=("${RED}" "${ORANGE}" "${GOLD}" "${LIME}" "${TEAL}" "${CYAN}" "${LBLUE}" "${BLUE}" "${VIOLET}")
        local ec="${entry_colors[$((($i-1) % ${#entry_colors[@]}))]}"
        printf "  ${CYAN}║${RESET}  ${GOLD}%3d)${RESET}  ${ec}${icon}  %-55s${RESET}  ${CYAN}║${RESET}\n" "$i" "$os"
        ((i++))
    done
    box_bottom
    echo
 
    local os_count=${#os_keys[@]}
    while true; do
        read -rp "$(print_status "INPUT" "Select OS (1–$os_count): ")" choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= os_count )); then
            local os="${os_keys[$((choice-1))]}"
            IFS='|' read -r OS_TYPE CODENAME IMG_URL DEFAULT_HOSTNAME DEFAULT_USERNAME DEFAULT_PASSWORD \
                <<< "${OS_OPTIONS[$os]}"
            print_status "SUCCESS" "Selected: ${GOLD}$os${RESET}"
            break
        fi
        print_status "ERROR" "Invalid selection — enter a number from 1 to $os_count"
    done
 
    neon_divider
    echo
 
    while true; do
        read -rp "$(print_status "INPUT" "🏷️   VM name        [default: ${GOLD}$DEFAULT_HOSTNAME${RESET}]: ")" VM_NAME
        VM_NAME="${VM_NAME:-$DEFAULT_HOSTNAME}"
        if validate_input "name" "$VM_NAME"; then
            if [[ -f "$VM_DIR/$VM_NAME.conf" ]]; then
                print_status "ERROR" "VM '${GOLD}$VM_NAME${RESET}' already exists — choose another name"
            else
                break
            fi
        fi
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "🏠  Hostname       [default: ${GOLD}$VM_NAME${RESET}]: ")" HOSTNAME
        HOSTNAME="${HOSTNAME:-$VM_NAME}"
        validate_input "name" "$HOSTNAME" && break
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "👤  Username       [default: ${GOLD}$DEFAULT_USERNAME${RESET}]: ")" USERNAME
        USERNAME="${USERNAME:-$DEFAULT_USERNAME}"
        validate_input "username" "$USERNAME" && break
    done
 
    while true; do
        read -rsp "$(print_status "INPUT" "🔑  Password       [default: ${GOLD}$DEFAULT_PASSWORD${RESET}]: ")" PASSWORD
        PASSWORD="${PASSWORD:-$DEFAULT_PASSWORD}"
        echo
        [[ -n "$PASSWORD" ]] && break
        print_status "ERROR" "Password cannot be empty"
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "💾  Disk size      [default: ${GOLD}20G${RESET}]: ")" DISK_SIZE
        DISK_SIZE="${DISK_SIZE:-20G}"
        validate_input "size" "$DISK_SIZE" && break
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "🧠  Memory (MB)    [default: ${GOLD}2048${RESET}]: ")" MEMORY
        MEMORY="${MEMORY:-2048}"
        validate_input "number" "$MEMORY" && break
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "⚡  CPUs           [default: ${GOLD}2${RESET}]: ")" CPUS
        CPUS="${CPUS:-2}"
        validate_input "number" "$CPUS" && break
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "🔌  SSH Port       [default: ${GOLD}2222${RESET}]: ")" SSH_PORT
        SSH_PORT="${SSH_PORT:-2222}"
        if validate_input "port" "$SSH_PORT"; then
            if ss -tln 2>/dev/null | grep -q ":$SSH_PORT "; then
                print_status "ERROR" "Port $SSH_PORT is already in use — try another"
            else
                break
            fi
        fi
    done
 
    while true; do
        read -rp "$(print_status "INPUT" "🖥️   Enable GUI     [y/n, default: ${GOLD}n${RESET}]: ")" gui_input
        gui_input="${gui_input:-n}"
        if [[ "$gui_input" =~ ^[Yy]$ ]]; then GUI_MODE=true; break
        elif [[ "$gui_input" =~ ^[Nn]$ ]]; then GUI_MODE=false; break
        else print_status "ERROR" "Please answer y or n"
        fi
    done
 
    read -rp "$(print_status "INPUT" "🌐  Port-forwards  [e.g. ${GOLD}8080:80,3000:3000${RESET} or Enter for none]: ")" PORT_FORWARDS
 
    IMG_FILE="$VM_DIR/$VM_NAME.img"
    SEED_FILE="$VM_DIR/$VM_NAME-seed.iso"
    CREATED="$(date)"
 
    setup_vm_image
    save_vm_config
}
 
# ─── Is VM Running? ───────────────────────────────────────────────────────────
is_vm_running() {
    local vm_name=$1
    pgrep -f "qemu-system.*$vm_name" >/dev/null 2>&1 && return 0
    if load_vm_config "$vm_name" 2>/dev/null && [[ -n "${IMG_FILE:-}" ]]; then
        pgrep -f "qemu-system.*$IMG_FILE" >/dev/null 2>&1 && return 0
    fi
    return 1
}
 
# ─── Stop VM ──────────────────────────────────────────────────────────────────
stop_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    if is_vm_running "$vm_name"; then
        print_status "INFO" "🛑 Stopping VM: ${GOLD}$vm_name${RESET}"
        pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
        sleep 2
        if is_vm_running "$vm_name"; then
            print_status "WARN" "VM did not stop gracefully — forcing termination..."
            pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            sleep 1
        fi
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true
        if is_vm_running "$vm_name"; then
            print_status "ERROR" "Failed to stop VM"
            return 1
        fi
        print_status "SUCCESS" "✅ VM ${GOLD}$vm_name${RESET} stopped"
    else
        print_status "INFO" "💤 VM ${GOLD}$vm_name${RESET} is already stopped"
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true
    fi
}
 
# ─── Start VM ─────────────────────────────────────────────────────────────────
start_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    if ! check_image_lock "$IMG_FILE" "$vm_name"; then
        print_status "ERROR" "🔒 Image file is locked by another process"
        read -rp "$(print_status "INPUT" "Force kill all QEMU processes using this image? (y/N): ")" force_kill
        if [[ "$force_kill" =~ ^[Yy]$ ]]; then
            pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            sleep 2
            pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            rm -f "${IMG_FILE}.lock" 2>/dev/null || true
            print_status "SUCCESS" "Cleared"
        else
            return 1
        fi
    fi
 
    if is_vm_running "$vm_name"; then
        print_status "WARN" "VM '${GOLD}$vm_name${RESET}' is already running"
        read -rp "$(print_status "INPUT" "Stop and restart? (y/N): ")" restart_choice
        [[ "$restart_choice" =~ ^[Yy]$ ]] && stop_vm "$vm_name" && sleep 2 || return 1
    fi
 
    [[ -f "$IMG_FILE" ]] || { print_status "ERROR" "VM image not found: ${CORAL}$IMG_FILE${RESET}"; return 1; }
    if [[ ! -f "$SEED_FILE" ]]; then
        print_status "WARN" "Seed file missing — recreating..."
        rebuild_seed
    fi
 
    echo
    gradient_line 76
    box_top
    box_line ""
    box_line "  🚀  Launching VM: ${vm_name}" "${GOLD}${BOLD}"
    box_sep
    box_line ""
    box_line_colored "  🔌  SSH"       "ssh -p $SSH_PORT $USERNAME@localhost"
    box_line_colored "  🔑  Password"  "$PASSWORD"
    box_line_colored "  🧠  RAM"       "${MEMORY}MB"
    box_line_colored "  ⚡  CPUs"      "$CPUS"
    box_line_colored "  💾  Disk"      "$DISK_SIZE"
    box_line_colored "  🌐  Forwards"  "${PORT_FORWARDS:-None}"
    box_line_colored "  🐢  Engine"    "Pure Software Emulation (TCG)"
    box_line ""
    box_bottom
    gradient_line 76
    echo
 
    local netdev_str="user,id=net0,hostfwd=tcp::${SSH_PORT}-:22"
    if [[ -n "${PORT_FORWARDS:-}" ]]; then
        IFS=',' read -ra forwards <<< "$PORT_FORWARDS"
        for forward in "${forwards[@]}"; do
            forward="${forward// /}"
            IFS=':' read -r host_port guest_port <<< "$forward"
            netdev_str+=",hostfwd=tcp::${host_port}-:${guest_port}"
        done
    fi
 
    local qemu_cmd=(
        qemu-system-x86_64
        -m "$MEMORY"
        -smp "$CPUS"
        -cpu qemu64
        -machine type=pc,accel=tcg
        -drive "file=$IMG_FILE,format=qcow2,if=virtio"
        -drive "file=$SEED_FILE,format=raw,if=virtio"
        -boot order=c
        -device virtio-net-pci,netdev=net0
        -netdev "$netdev_str"
        -device virtio-balloon-pci
        -object "rng-random,filename=/dev/urandom,id=rng0"
        -device virtio-rng-pci,rng=rng0
        -no-hpet
        -rtc base=utc,clock=host
    )
 
    if [[ "${GUI_MODE}" == true ]]; then
        qemu_cmd+=(-vga virtio -display gtk,gl=on)
        print_status "INFO" "🖥️  GUI mode active"
    else
        qemu_cmd+=(-nographic -serial mon:stdio)
        print_status "INFO" "📟 Console mode  |  ${GOLD}Ctrl+A then X${RESET} to quit"
    fi
 
    if ! "${qemu_cmd[@]}"; then
        print_status "ERROR" "QEMU failed to start — check config or image integrity"
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true
        return 1
    fi
 
    print_status "INFO" "VM ${GOLD}$vm_name${RESET} has shut down"
}
 
# ─── Delete VM ────────────────────────────────────────────────────────────────
delete_vm() {
    local vm_name=$1
    echo
    echo -e "  ${BG_RED}${BOLD}${CREAM}  ⚠️  DANGER ZONE  ⚠️  ${RESET}"
    echo
    print_status "WARN" "This will ${RED}${BOLD}PERMANENTLY${RESET}${AMBER} delete VM '${GOLD}$vm_name${RESET}${AMBER}' and ALL its data!"
    echo
    read -rp "$(print_status "INPUT" "Type the VM name to confirm deletion: ")" confirm_name
    if [[ "$confirm_name" == "$vm_name" ]]; then
        load_vm_config "$vm_name" || return 1
        if is_vm_running "$vm_name"; then
            print_status "WARN" "VM is running — stopping first..."
            stop_vm "$vm_name"
            sleep 2
        fi
        rm -f "$IMG_FILE" "$SEED_FILE" "$VM_DIR/$vm_name.conf" "${IMG_FILE}.lock" 2>/dev/null || true
        print_status "SUCCESS" "🗑️  VM '${GOLD}$vm_name${RESET}' permanently deleted"
    else
        print_status "INFO" "Name mismatch — deletion cancelled"
    fi
}
 

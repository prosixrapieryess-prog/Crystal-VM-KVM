    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "🌍 OS"        "$OS_TYPE ($CODENAME)"
    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "🏷️  Hostname"   "$HOSTNAME"
    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "👤 Username"   "$USERNAME"
    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "🔑 Password"   "$PASSWORD"

    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "🧠 Memory"     "${MEMORY} MB"
    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "⚡ CPUs"       "$CPUS"
    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "💾 Disk"       "$DISK_SIZE"
    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "🖥️  GUI Mode"   "$GUI_MODE"
    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "🌐 Forwards"   "${PORT_FORWARDS:-None}"
    printf "  ${CYAN}║${RESET}  ${GOLD}%-16s${RESET}  ${WHITE}%-50s${RESET}  ${CYAN}║${RESET}\n" "📅 Created"    "$CREATED"
    box_line ""
    echo -e "  ${CYAN}║${RESET}  ${GOLD}$(printf '%-16s' '🔒 Lock Status')${RESET}  ${lock_status}$(printf '%*s' 50 '')${CYAN}║${RESET}"
    echo -e "  ${CYAN}║${RESET}  ${GOLD}$(printf '%-16s' '⚡ VM Status')${RESET}    ${run_status}$(printf '%*s' 48 '')${CYAN}║${RESET}"
    box_bottom
    echo
    read -rp "$(print_status "INPUT" "⏎  Press Enter to continue...")"
}
 
# ─── Edit VM Config ───────────────────────────────────────────────
edit_vm_config() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
    print_status "SECTION" "Edit VM — $vm_name"
 
    while true; do
        echo -e "  ${CYAN}${BOLD}📝 What would you like to edit?${RESET}\n"
        echo -e "  ${GOLD}  1)${RESET} 🏷️   Hostname        ${DIM}(current: $HOSTNAME)${RESET}"
        echo -e "  ${GOLD}  2)${RESET} 👤  Username        ${DIM}(current: $USERNAME)${RESET}"
        echo -e "  ${GOLD}  3)${RESET} 🔑  Password        ${DIM}(current: ****)${RESET}"
        echo -e "  ${GOLD}  4)${RESET} 🔌  SSH Port        ${DIM}(current: $SSH_PORT)${RESET}"
        echo -e "  ${GOLD}  5)${RESET} 🖥️   GUI Mode        ${DIM}(current: $GUI_MODE)${RESET}"
        echo -e "  ${GOLD}  6)${RESET} 🌐  Port Forwards   ${DIM}(current: ${PORT_FORWARDS:-None})${RESET}"
        echo -e "  ${GOLD}  7)${RESET} 🧠  Memory          ${DIM}(current: ${MEMORY}MB)${RESET}"
        echo -e "  ${GOLD}  8)${RESET} ⚡  CPUs            ${DIM}(current: $CPUS)${RESET}"
        echo -e "  ${GOLD}  9)${RESET} 💾  Resize Disk     ${DIM}(current: $DISK_SIZE)${RESET}"
        echo -e "  ${RED}  0)${RESET} ↩️   Back\n"
 
        read -rp "$(print_status "INPUT" "Your choice: ")" edit_choice
 
        local needs_reseed=false
        case $edit_choice in
            1)
                while true; do
                    read -rp "$(print_status "INPUT" "New hostname [current: $HOSTNAME]: ")" v
                    v="${v:-$HOSTNAME}"
                    validate_input "name" "$v" && HOSTNAME="$v" && needs_reseed=true && break
                done ;;
            2)
                while true; do
                    read -rp "$(print_status "INPUT" "New username [current: $USERNAME]: ")" v
                    v="${v:-$USERNAME}"
                    validate_input "username" "$v" && USERNAME="$v" && needs_reseed=true && break
                done ;;
            3)
                while true; do
                    read -rsp "$(print_status "INPUT" "New password: ")" v; echo
                    v="${v:-$PASSWORD}"
                    [[ -n "$v" ]] && PASSWORD="$v" && needs_reseed=true && break
                    print_status "ERROR" "Password cannot be empty"
                done ;;
            4)
                while true; do
                    read -rp "$(print_status "INPUT" "New SSH port [current: $SSH_PORT]: ")" v
                    v="${v:-$SSH_PORT}"
                    if validate_input "port" "$v"; then
                        if [[ "$v" != "$SSH_PORT" ]] && ss -tln 2>/dev/null | grep -q ":$v "; then
                            print_status "ERROR" "Port $v is already in use"
                        else
                            SSH_PORT="$v"; break
                        fi
                    fi
                done ;;
            5)
                while true; do
                    read -rp "$(print_status "INPUT" "Enable GUI? (y/n) [current: $GUI_MODE]: ")" v
                    v="${v:-}"
                    if [[ "$v" =~ ^[Yy]$ ]]; then GUI_MODE=true; break
                    elif [[ "$v" =~ ^[Nn]$ ]]; then GUI_MODE=false; break
                    elif [[ -z "$v" ]]; then break
                    else print_status "ERROR" "Please answer y or n"
                    fi
                done ;;
            6)
                read -rp "$(print_status "INPUT" "Port forwards [current: ${PORT_FORWARDS:-None}]: ")" v
                PORT_FORWARDS="${v:-$PORT_FORWARDS}" ;;
            7)
                while true; do
                    read -rp "$(print_status "INPUT" "New memory MB [current: $MEMORY]: ")" v
                    v="${v:-$MEMORY}"
                    validate_input "number" "$v" && MEMORY="$v" && break
                done ;;
            8)
                while true; do
                    read -rp "$(print_status "INPUT" "New CPU count [current: $CPUS]: ")" v
                    v="${v:-$CPUS}"
                    validate_input "number" "$v" && CPUS="$v" && break
                done ;;
            # FIX 5: Disk resize now actually resizes the image file.
            # Original code only updated the DISK_SIZE variable in memory
            # and config without ever calling qemu-img resize.
            9)
                save_vm_config          # persist any other edits first
                resize_vm_disk "$vm_name"
                load_vm_config "$vm_name"  # reload so DISK_SIZE reflects new size
                continue ;;
            0) return 0 ;;
            *) print_status "ERROR" "Invalid selection"; continue ;;
        esac
 
        # FIX 7: Only rebuild the seed (credentials/hostname changed),
        # not the full setup_vm_image which would also attempt resize.
        if $needs_reseed; then
            rebuild_seed
        fi
 
        save_vm_config
        echo
        read -rp "$(print_status "INPUT" "Continue editing? (y/N): ")" more
        [[ "$more" =~ ^[Yy]$ ]] || break
    done
}
 
# ─── Resize Disk ──────────────────────────────────────────────────
resize_vm_disk() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    if is_vm_running "$vm_name"; then
        print_status "ERROR" "Stop the VM before resizing its disk"
        return 1
    fi
 
    print_status "INFO" "Current disk: $DISK_SIZE"
 
    while true; do
        read -rp "$(print_status "INPUT" "New disk size (e.g. 50G): ")" new_size
        if validate_input "size" "$new_size"; then
            [[ "$new_size" == "$DISK_SIZE" ]] && { print_status "INFO" "Same size — no change"; return 0; }
 
            # Size comparison (in MB)
            local cur_n=${DISK_SIZE%[GgMm]} cur_u=${DISK_SIZE: -1}
            local new_n=${new_size%[GgMm]}  new_u=${new_size: -1}
            [[ "$cur_u" =~ [Gg] ]] && cur_n=$((cur_n * 1024))
            [[ "$new_u" =~ [Gg] ]] && new_n=$((new_n * 1024))
 
            if (( new_n < cur_n )); then
                print_status "WARN" "Shrinking disk may cause DATA LOSS!"
                read -rp "$(print_status "INPUT" "Are you sure? (y/N): ")" ok
                [[ "$ok" =~ ^[Yy]$ ]] || { print_status "INFO" "Cancelled"; return 0; }
            fi
 
            if qemu-img resize "$IMG_FILE" "$new_size"; then
                DISK_SIZE="$new_size"
                save_vm_config
                print_status "SUCCESS" "Disk resized to $new_size"
            else
                print_status "ERROR" "qemu-img resize failed"
                return 1
            fi
            break
        fi
    done
}
 
# ─── Performance Metrics ──────────────────────────────────────────
show_vm_performance() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
    print_status "SECTION" "Performance — $vm_name"
 
    if is_vm_running "$vm_name"; then
        local qemu_pid
        qemu_pid=$(pgrep -f "qemu-system.*$IMG_FILE" | head -1)
        if [[ -n "$qemu_pid" ]]; then
            echo -e "  ${CYAN}${BOLD}⚡ QEMU Process (PID $qemu_pid):${RESET}"
            ps -p "$qemu_pid" -o pid,%cpu,%mem,rss,vsz --no-headers \
                | awk '{printf "     PID: %s  CPU: %s%%  MEM: %s%%  RSS: %s kB\n",$1,$2,$3,$4}'
            echo
            echo -e "  ${CYAN}${BOLD}🧠 System Memory:${RESET}"
            free -h | awk 'NR==1{printf "     %-10s %8s %8s %8s\n",$1,$2,$3,$4}
                           NR==2{printf "     %-10s %8s %8s %8s\n",$1,$2,$3,$4}'
            echo
            echo -e "  ${CYAN}${BOLD}💾 Image File:${RESET}"
            du -h "$IMG_FILE" | awk '{printf "     %s  →  %s\n",$1,$2}'
        else
            print_status "ERROR" "Cannot find QEMU process for $vm_name"
        fi
    else
        echo -e "  ${DIM}VM is not running — showing config:${RESET}"
        echo -e "  🧠 ${MEMORY}MB RAM   ⚡ ${CPUS} CPUs   💾 ${DISK_SIZE}"
    fi
 
    echo
    read -rp "$(print_status "INPUT" "⏎  Press Enter to continue...")"
}
 
# ─── Fix Issues ───────────────────────────────────────────────────
fix_vm_issues() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
    print_status "SECTION" "Fix Issues — $vm_name"
 
    echo -e "  ${CYAN}${BOLD}🔧 Select fix:${RESET}\n"
    echo -e "  ${GOLD}  1)${RESET} 🔓  Remove lock files"
    echo -e "  ${GOLD}  2)${RESET} 🗑️   Recreate seed image"
    echo -e "  ${GOLD}  3)${RESET} 🔄  Rewrite configuration file"
    echo -e "  ${GOLD}  4)${RESET} 💀  Kill stuck QEMU processes"
    echo -e "  ${RED}  0)${RESET} ↩️   Back\n"
 
    read -rp "$(print_status "INPUT" "Choice: ")" fix_choice
 
    case $fix_choice in
        1)
            rm -f "${IMG_FILE}.lock" "${IMG_FILE}"*.lock 2>/dev/null || true
            print_status "SUCCESS" "Lock files removed" ;;
        2)
            rebuild_seed    # FIX 7: use focused helper
            print_status "SUCCESS" "Seed image recreated" ;;
        3)
            save_vm_config
            print_status "SUCCESS" "Configuration rewritten" ;;
        4)
            pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            sleep 1
            pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            rm -f "${IMG_FILE}.lock" 2>/dev/null || true
            print_status "SUCCESS" "Processes killed and lock cleared" ;;
        0) return 0 ;;
        *) print_status "ERROR" "Invalid selection" ;;
    esac
}
 
# ─── Pick VM Helper (FIX 1 + FIX 2) ──────────────────────────────
# Moved OUTSIDE the main_menu while-loop so it is defined once, not
# re-defined on every iteration.
#
# FIX 2: All output except the final "echo <vm-name>" is redirected
# to stderr (>&2).  When called as  vm=$(pick_vm "..."),  only the
# actual VM name ends up in $vm; prompts and error messages still
# appear on the terminal via stderr.
pick_vm() {
    local prompt=$1
    local num
    # Print the prompt to stderr so it isn't captured by $()
    read -rp "$(echo -e "${CYAN}${BOLD}  🎯 ${prompt} (1–${vm_count}): ${RESET}")" num
    if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= vm_count )); then
        echo "${vms[$((num-1))]}"          # ← only this goes to stdout / $()
    else
        echo -e "  ${RED}${BOLD}❌ ERROR  ${RESET}${RED}Invalid selection${RESET}" >&2
        echo ""   # empty string signals failure to caller
    fi
}
 
# ─── Main Menu ────────────────────────────────────────────────────
main_menu() {
    while true; do
        display_header
 
        mapfile -t vms < <(get_vm_list)
        local vm_count=${#vms[@]}
 
        if (( vm_count > 0 )); then
            echo -e "  ${CYAN}${BOLD}📁 Your VMs:${RESET}\n"
            for i in "${!vms[@]}"; do
                local badge
                is_vm_running "${vms[$i]}" \
                    && badge="${GREEN}🚀 Running${RESET}" \
                    || badge="${DIM}💤 Stopped${RESET}"
                printf "  ${GOLD}  %2d)${RESET}  ${WHITE}%-30s${RESET}  %b\n" $((i+1)) "${vms[$i]}" "$badge"
            done
            echo
        fi
 
        divider
        echo -e "\n  ${CYAN}${BOLD}📋 Menu:${RESET}\n"
        echo -e "  ${GOLD}  1)${RESET} 🆕  Create a new VM"
        if (( vm_count > 0 )); then
            echo -e "  ${GOLD}  2)${RESET} 🚀  Start a VM"
            echo -e "  ${GOLD}  3)${RESET} 🛑  Stop a VM"
            echo -e "  ${GOLD}  4)${RESET} 📊  Show VM info"
            echo -e "  ${GOLD}  5)${RESET} ✏️   Edit VM configuration"
            echo -e "  ${GOLD}  6)${RESET} 🗑️   Delete a VM"
            echo -e "  ${GOLD}  7)${RESET} 📈  Resize VM disk"
            echo -e "  ${GOLD}  8)${RESET} 📊  Show performance"
            echo -e "  ${GOLD}  9)${RESET} 🔧  Fix VM issues"
        fi
        echo -e "  ${RED}  0)${RESET} 👋  Exit\n"
 
        read -rp "$(print_status "INPUT" "Your choice: ")" choice
 
        local vm
        case $choice in
            1) create_new_vm ;;
            2)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "VM to start"); [[ -n "$vm" ]] && start_vm "$vm" ;;
            3)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "VM to stop"); [[ -n "$vm" ]] && stop_vm "$vm" ;;
            4)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "VM to inspect"); [[ -n "$vm" ]] && show_vm_info "$vm" ;;
            5)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "VM to edit"); [[ -n "$vm" ]] && edit_vm_config "$vm" ;;
            6)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "VM to delete"); [[ -n "$vm" ]] && delete_vm "$vm" ;;
            7)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "VM to resize"); [[ -n "$vm" ]] && resize_vm_disk "$vm" ;;
            8)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "VM to inspect"); [[ -n "$vm" ]] && show_vm_performance "$vm" ;;
            9)
                (( vm_count > 0 )) || continue
                vm=$(pick_vm "VM to fix"); [[ -n "$vm" ]] && fix_vm_issues "$vm" ;;
            0)
                echo
                print_status "INFO" "👋 See you next time!"
                echo
                exit 0 ;;
            *)
                print_status "ERROR" "Invalid option" ;;
        esac
 
        echo
        read -rp "$(print_status "INPUT" "⏎  Press Enter to continue...")"
    done
}
 

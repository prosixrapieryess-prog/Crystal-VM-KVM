        fi

        # Main menu options
        echo -e "  ${BD}${CY}  ┌─── MENU ───────────────────────────────────────────────┐${RST}"
        echo -e "  ${CY}  │${RST}  ${G}${BD}1)${RST}  🆕  Create New VM                              ${CY}│${RST}"
        echo -e "  ${CY}  │${RST}  ${G}${BD}2)${RST}  🐙  GitHub VPS (Docker)                        ${CY}│${RST}"
        echo -e "  ${CY}  │${RST}  ${G}${BD}3)${RST}  🔧  IDX Tool Setup                             ${CY}│${RST}"
        echo -e "  ${CY}  │${RST}  ${G}${BD}4)${RST}  🌐  Real VPS Installer (DD)                    ${CY}│${RST}"

        if [[ $vm_count -gt 0 ]]; then
            echo -e "  ${CY}  ├────────────────────────────────────────────────────────┤${RST}"
            echo -e "  ${CY}  │${RST}  ${CY}${BD}5)${RST}  🚀  Start VM         ${CY}${BD}6)${RST}  🛑  Stop VM          ${CY}│${RST}"
            echo -e "  ${CY}  │${RST}  ${CY}${BD}7)${RST}  📊  VM Info          ${CY}${BD}8)${RST}  ✏️   Edit VM          ${CY}│${RST}"
            echo -e "  ${CY}  │${RST}  ${CY}${BD}9)${RST}  💾  Resize Disk      ${CY}${BD}10)${RST} 📈  Performance      ${CY}│${RST}"
            echo -e "  ${CY}  │${RST}  ${Y}${BD}11)${RST} 🔧  Fix Issues       ${R}${BD}12)${RST} 🗑️   Delete VM        ${CY}│${RST}"
        fi

        echo -e "  ${CY}  ├────────────────────────────────────────────────────────┤${RST}"
        echo -e "  ${CY}  │${RST}  ${R}${BD}0)${RST}  ❌  Exit                                       ${CY}│${RST}"
        echo -e "  ${BD}${CY}  └────────────────────────────────────────────────────────┘${RST}"
        echo ""

        print_status INPUT "Select option: "; read -r op
        echo ""

        local SELECTED_VM=""
        case $op in
            1) create_new_vm ;;
            2) print_status INFO "Launching GitHub VPS via Docker..."
               docker run -it --rm --device /dev/kvm Tyrkrox/debain12 2>/dev/null \
                   || print_status ERROR "Docker not available or image missing" ;;
            3) setup_idx_tool ;;
            4) print_status INFO "Launching Real VPS installer..."
               bash <(curl -fsSL https://raw.githubusercontent.com/nobita329/The-Coding-Hub/main/srv/vm/dd.sh) 2>/dev/null \
                   || print_status ERROR "Could not fetch installer script" ;;
            5) [[ $vm_count -gt 0 ]] && select_vm_prompt "START" "${vms[@]}" && start_vm "$SELECTED_VM" ;;
            6) [[ $vm_count -gt 0 ]] && select_vm_prompt "STOP" "${vms[@]}" && stop_vm "$SELECTED_VM" ;;
            7) [[ $vm_count -gt 0 ]] && select_vm_prompt "INFO" "${vms[@]}" && show_vm_info "$SELECTED_VM" ;;
            8) [[ $vm_count -gt 0 ]] && select_vm_prompt "EDIT" "${vms[@]}" && edit_vm_config "$SELECTED_VM" ;;
            9) [[ $vm_count -gt 0 ]] && select_vm_prompt "RESIZE" "${vms[@]}" && resize_vm_disk "$SELECTED_VM" ;;
            10) [[ $vm_count -gt 0 ]] && select_vm_prompt "STATS" "${vms[@]}" && show_vm_performance "$SELECTED_VM" ;;
            11) [[ $vm_count -gt 0 ]] && select_vm_prompt "FIX" "${vms[@]}" && fix_vm_issues "$SELECTED_VM" ;;
            12) [[ $vm_count -gt 0 ]] && select_vm_prompt "DELETE" "${vms[@]}" && delete_vm "$SELECTED_VM" ;;
            0)  echo -e "\n  ${CY}${BD}  Thanks for using PROXLEGENDYT! Goodbye. 👋${RST}\n"; exit 0 ;;
            *)  print_status ERROR "Invalid option '$op'" ;;
        esac

        echo ""
        print_status INPUT "Press Enter to return to menu..."; read -r
    done
}


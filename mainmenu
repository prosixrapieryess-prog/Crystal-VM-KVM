# ─── EDIT VM CONFIG ─────────────────────────────────────────
edit_vm_config() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1

    while true; do
        print_header
        echo -e "  ${BD}${CY}  ✏️  EDIT VM: ${W}$vm_name${RST}\n"
        divider
        echo -e "  ${CY} 1)${RST} Hostname       ${DIM}(${HOSTNAME})${RST}"
        echo -e "  ${CY} 2)${RST} Username       ${DIM}(${USERNAME})${RST}"
        echo -e "  ${CY} 3)${RST} Password       ${DIM}(${PASSWORD})${RST}"
        echo -e "  ${CY} 4)${RST} SSH Port       ${DIM}(${SSH_PORT})${RST}"
        echo -e "  ${CY} 5)${RST} GUI Mode       ${DIM}(${GUI_MODE})${RST}"
        echo -e "  ${CY} 6)${RST} Port Forwards  ${DIM}(${PORT_FORWARDS:-None})${RST}"
        echo -e "  ${CY} 7)${RST} Memory RAM     ${DIM}(${MEMORY}MB)${RST}"
        echo -e "  ${CY} 8)${RST} CPU Count      ${DIM}(${CPUS})${RST}"
        echo -e "  ${CY} 9)${RST} Disk Size      ${DIM}(${DISK_SIZE})${RST}"
        echo -e "  ${R} 0)${RST} Back"
        divider
        print_status INPUT "Choice: "; read -r ec

        case $ec in
            1) while true; do
                   print_status INPUT "New hostname [$HOSTNAME]: "; read -r v
                   v="${v:-$HOSTNAME}"; validate_input "name" "$v" && HOSTNAME="$v" && break
               done; setup_vm_image ;;
            2) while true; do
                   print_status INPUT "New username [$USERNAME]: "; read -r v
                   v="${v:-$USERNAME}"; validate_input "username" "$v" && USERNAME="$v" && break
               done; setup_vm_image ;;
            3) while true; do
                   print_status INPUT "New password: "; read -rs v; echo ""
                   v="${v:-$PASSWORD}"; [[ -n "$v" ]] && PASSWORD="$v" && break
                   print_status ERROR "Cannot be empty"
               done; setup_vm_image ;;
            4) while true; do
                   print_status INPUT "New SSH port [$SSH_PORT]: "; read -r v
                   v="${v:-$SSH_PORT}"; validate_input "port" "$v" || continue
                   [[ "$v" != "$SSH_PORT" ]] && ss -tln 2>/dev/null | grep -q ":${v} " && { print_status ERROR "Port in use"; continue; }
                   SSH_PORT="$v"; break
               done ;;
            5) while true; do
                   print_status INPUT "GUI mode? [y/n, current: $GUI_MODE]: "; read -r v
                   case "$v" in [Yy]) GUI_MODE=true; break;; [Nn]) GUI_MODE=false; break;;
                   "") break;; *) print_status ERROR "Enter y or n";; esac
               done ;;
            6) print_status INPUT "Port forwards [$PORT_FORWARDS]: "; read -r v; PORT_FORWARDS="${v:-$PORT_FORWARDS}" ;;
            7) while true; do
                   print_status INPUT "Memory MB [$MEMORY]: "; read -r v
                   v="${v:-$MEMORY}"; validate_input "number" "$v" && MEMORY="$v" && break
               done ;;
            8) while true; do
                   print_status INPUT "CPU count [$CPUS]: "; read -r v
                   v="${v:-$CPUS}"; validate_input "number" "$v" && CPUS="$v" && break
               done ;;
            9) while true; do
                   print_status INPUT "Disk size [$DISK_SIZE]: "; read -r v
                   v="${v:-$DISK_SIZE}"; validate_input "size" "$v" && DISK_SIZE="$v" && break
               done ;;
            0) return 0 ;;
            *) print_status ERROR "Invalid"; continue ;;
        esac

        save_vm_config
        print_status SUCCESS "Saved!"
        print_status INPUT "Continue editing? [y/N]: "; read -r cont
        [[ ! "$cont" =~ ^[Yy]$ ]] && break
    done
}

# ─── DELETE VM ──────────────────────────────────────────────
delete_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1

    echo -e "\n  ${BG_R}${BD}  ⚠️  WARNING: This will permanently delete VM '$vm_name' and all data!  ${RST}\n"
    print_status INPUT "Type VM name to confirm deletion: "; read -r confirm
    if [[ "$confirm" == "$vm_name" ]]; then
        if is_vm_running "$vm_name"; then
            stop_vm "$vm_name"
            sleep 2
        fi
        rm -f "$IMG_FILE" "$SEED_FILE" "$VM_DIR/$vm_name.conf" "${IMG_FILE}.lock" 2>/dev/null
        print_status SUCCESS "VM '$vm_name' deleted permanently"
    else
        print_status INFO "Deletion cancelled (name mismatch)"
    fi
}

# ─── RESIZE DISK ────────────────────────────────────────────
resize_vm_disk() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
    is_vm_running "$vm_name" && { print_status ERROR "Stop VM before resizing disk"; return 1; }

    print_status INFO "Current disk: ${BD}$DISK_SIZE${RST}"
    while true; do
        print_status INPUT "New disk size (e.g. 50G): "; read -r new_size
        validate_input "size" "$new_size" || continue
        [[ "$new_size" == "$DISK_SIZE" ]] && { print_status INFO "Same size — no change"; return 0; }
        print_status STEP "Resizing $IMG_FILE → $new_size"
        if qemu-img resize "$IMG_FILE" "$new_size"; then
            DISK_SIZE="$new_size"
            save_vm_config
            print_status SUCCESS "Disk resized to $new_size"
        else
            print_status ERROR "Resize failed"
        fi
        break
    done
}

# ─── PERFORMANCE STATS ──────────────────────────────────────
show_vm_performance() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1

    bold_divider
    echo -e "  ${BD}${CY}  📊 PERFORMANCE: ${W}$vm_name${RST}"
    bold_divider

    if is_vm_running "$vm_name"; then
        local qemu_pid
        qemu_pid=$(pgrep -f "qemu-system.*${IMG_FILE}" | head -1)
        if [[ -n "$qemu_pid" ]]; then
            echo -e "  ${CY}QEMU PID:${RST} ${W}$qemu_pid${RST}"
            echo ""
            echo -e "  ${CY}Process Stats:${RST}"
            ps -p "$qemu_pid" -o pid,%cpu,%mem,rss,vsz --no-headers \
                | awk '{printf "  CPU: %s%%  MEM: %s%%  RSS: %sMB  VSZ: %sMB\n",$2,$3,int($4/1024),int($5/1024)}'
            echo ""
            echo -e "  ${CY}System Memory:${RST}"
            free -h | awk 'NR==2{printf "  Used: %s / Total: %s (Free: %s)\n",$3,$2,$4}'
        fi
    else
        echo -e "  ${Y}VM is not running${RST}"
    fi
    echo ""
    echo -e "  ${CY}Disk Usage:${RST}"
    if [[ -f "$IMG_FILE" ]]; then
        local disk_info
        disk_info=$(qemu-img info "$IMG_FILE" 2>/dev/null | grep -E 'virtual size|disk size')
        echo "$disk_info" | while IFS= read -r line; do echo "  $line"; done
    fi
    bold_divider
    echo ""
    print_status INPUT "Press Enter..."; read -r
}

# ─── FIX VM ISSUES ──────────────────────────────────────────
fix_vm_issues() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1

    echo ""
    divider
    echo -e "  ${BD}${Y}  🔧 FIX ISSUES: ${W}$vm_name${RST}\n"
    echo -e "  ${CY}1)${RST} Remove lock files"
    echo -e "  ${CY}2)${RST} Recreate cloud-init seed"
    echo -e "  ${CY}3)${RST} Resave configuration"
    echo -e "  ${CY}4)${RST} Kill stuck QEMU processes"
    echo -e "  ${CY}5)${RST} Repair image (qemu-img check)"
    echo -e "  ${R}0)${RST} Back"
    divider
    print_status INPUT "Choice: "; read -r fc

    case $fc in
        1) rm -f "${IMG_FILE}.lock" "${IMG_FILE}"*.lock 2>/dev/null
           print_status SUCCESS "Lock files cleared" ;;
        2) rm -f "$SEED_FILE"; setup_vm_image ;;
        3) save_vm_config ;;
        4) pkill -f "qemu-system.*${IMG_FILE}" 2>/dev/null; sleep 1
           pkill -9 -f "qemu-system.*${IMG_FILE}" 2>/dev/null
           rm -f "${IMG_FILE}.lock" 2>/dev/null
           print_status SUCCESS "Processes terminated" ;;
        5) print_status STEP "Checking image integrity..."
           if qemu-img check "$IMG_FILE" 2>&1; then
               print_status SUCCESS "Image OK"
           else
               print_status WARN "Attempting repair..."
               qemu-img check -r all "$IMG_FILE" && print_status SUCCESS "Repaired" || print_status ERROR "Repair failed — backup and recreate"
           fi ;;
        0) return 0 ;;
        *) print_status ERROR "Invalid" ;;
    esac
    echo ""
    print_status INPUT "Press Enter..."; read -r
}

# ─── IDX TOOL SETUP ─────────────────────────────────────────
setup_idx_tool() {
    print_status STEP "Setting up IDX dev.nix environment..."
    local idx_dir="$HOME/vps123/.idx"
    mkdir -p "$idx_dir"
    cat > "$idx_dir/dev.nix" <<'EOF'
{ pkgs, ... }: {
  channel = "stable-24.05";
  packages = with pkgs; [
    unzip git qemu_kvm sudo cloud-image-utils wget lsof openssl
  ];
  env = {};
  idx = {
    extensions = [];
    workspace = {
      onCreate = { default.openFiles = [ ".idx/dev.nix" ]; };
    };
  };
}
EOF
    print_status SUCCESS "IDX config written → $idx_dir/dev.nix"
}

# ─── VM SELECT PROMPT ───────────────────────────────────────
select_vm_prompt() {
    local action=$1
    local -a vms=("${@:2}")
    local count=${#vms[@]}
    [[ $count -eq 0 ]] && { print_status ERROR "No VMs found"; return 1; }

    echo ""
    divider
    echo -e "  ${BD}${CY}  Select VM to $action:${RST}\n"
    for i in "${!vms[@]}"; do
        local st="${R}○${RST}"
        is_vm_running "${vms[$i]}" && st="${G}●${RST}"
        printf "  ${CY}%2d)${RST} $st ${W}%s${RST}\n" $((i+1)) "${vms[$i]}"
    done
    divider
    print_status INPUT "Enter number [1-$count] or 0 to cancel: "; read -r sel

    if [[ "$sel" == "0" ]]; then return 1; fi
    if [[ "$sel" =~ ^[0-9]+$ ]] && [ "$sel" -ge 1 ] && [ "$sel" -le "$count" ]; then
        SELECTED_VM="${vms[$((sel-1))]}"
        return 0
    fi
    print_status ERROR "Invalid selection"
    return 1
}


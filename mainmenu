# ─── MAIN MENU ──────────────────────────────────────────────
main_menu() {
    while true; do
        print_header

        local -a vms
        mapfile -t vms < <(get_vm_list)
        local vm_count=${#vms[@]}

        # VM Summary panel
        if [[ $vm_count -gt 0 ]]; then
            echo -e "  ${BD}${CY}  ┌──────────────────────────────────────────────────────────┐${RST}"
            printf   "  ${BD}${CY}  │${RST}  ${W}${BD}%-58s${RST}${CY}│${RST}\n" "YOUR VMs ($vm_count found)"
            echo -e  "  ${BD}${CY}  ├──────────────────────────────────────────────────────────┤${RST}"
            for i in "${!vms[@]}"; do
                local badge
                is_vm_running "${vms[$i]}" && badge="${G}${BD} ● RUNNING ${RST}" || badge="${BLK} ○ stopped ${RST}"
                printf "  ${CY}  │${RST}  ${CY}%2d)${RST} ${W}%-30s${RST} %s ${CY}│${RST}\n" \
                    $((i+1)) "${vms[$i]}" "$badge"
            done
            echo -e "  ${BD}${CY}  └──────────────────────────────────────────────────────────┘${RST}"

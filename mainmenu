        echo -e "  ${C}d)${N} ✏️  Edit    ${C}e)${N} 🗑️  Delete  ${C}f)${N} 📈 Resize"
        echo -e "  ${C}g)${N} 📊 Perf    ${C}h)${N} 🔧 Fix     ${R}0)${N} ↩  Back"
        sep_thin; echo

progress_bar() {
    local duration="${1:-2}"; local label="${2:-Loading}"; local width=40
    local step; step=$(awk "BEGIN{printf \"%.4f\", $duration/$width}")
    echo
    for ((i=0; i<=width; i++)); do
        local pct=$(( i * 100 / width )); local bar=""
        for ((f=0; f<i; f++));     do bar+="█"; done
        for ((e=i; e<width; e++)); do bar+="░"; done
        printf "\r  ${C}%-18s${N} [${G}%s${N}] ${Y}%3d%%${N}" "$label" "$bar" "$pct"
        sleep "$step"
    done
    echo -e "  ${G}✔${N}"; echo
}
 

        echo -e "  ${R}0)${N} ↩  Back"
        echo
        read -p "  $(print_status "INPUT" "Choice: ")" ec
        case $ec in
            1) while true; do
                   read -p "  New hostname [$HOSTNAME]: " v; v="${v:-$HOSTNAME}"
                   validate_input "name" "$v" && { HOSTNAME="$v"; break; }
               done ;;
            2) while true; do
                   read -p "  New username [$USERNAME]: " v; v="${v:-$USERNAME}"
                   validate_input "username" "$v" && { USERNAME="$v"; break; }
               done ;;
            3) while true; do
                   read -s -p "  New password: " v; v="${v:-$PASSWORD}"; echo
                   [[ -n "$v" ]] && { PASSWORD="$v"; break; } || print_status "ERROR" "Cannot be empty"
               done ;;
            4) while true; do
                   read -p "  New SSH port [$SSH_PORT]: " v; v="${v:-$SSH_PORT}"
                   validate_input "port" "$v" && { SSH_PORT="$v"; break; }
               done ;;
            5) read -p "  GUI mode? (y/n) [$GUI_MODE]: " v
               [[ "$v" =~ ^[Yy]$ ]] && GUI_MODE=true || GUI_MODE=false ;;
            6) read -p "  Port forwards: " v; PORT_FORWARDS="${v:-$PORT_FORWARDS}" ;;
            7) while true; do
                   read -p "  Memory MB [$MEMORY]: " v; v="${v:-$MEMORY}"
                   validate_input "number" "$v" && { MEMORY="$v"; break; }
               done ;;
            8) while true; do
                   read -p "  vCPUs [$CPUS]: " v; v="${v:-$CPUS}"
                   validate_input "number" "$v" && { CPUS="$v"; break; }
               done ;;
            9) while true; do
                   read -p "  Disk size [$DISK_SIZE]: " v; v="${v:-$DISK_SIZE}"
                   validate_input "size" "$v" && { DISK_SIZE="$v"; break; }
               done ;;
            0) return 0 ;;
            *) print_status "ERROR" "Invalid choice"; continue ;;
        esac
        [[ "$ec" =~ ^[123]$ ]] && {
            print_status "INFO" "Rebuilding cloud-init with new settings..."
            setup_vm_image
        }
        save_vm_config
    done
}
 
# ═══════════════════════════════════════════════════════════════
#  DELETE VM
# ═══════════════════════════════════════════════════════════════
 
delete_vm() {
    load_vm_config "$1" || return 1
    echo
    print_status "WARN" "⚠️  This permanently destroys VM '$1' and ALL its data!"
    echo -e "  ${DIM}Image : $IMG_FILE${N}"
    echo -e "  ${DIM}Seed  : $SEED_FILE${N}"
    echo
    read -p "  Type ${R}DELETE${N} to confirm, or anything else to cancel: " confirm
    if [[ "$confirm" != "DELETE" ]]; then
        print_status "INFO" "Deletion cancelled — nothing was changed"
        return 0
    fi
    is_vm_running "$1" && { print_status "INFO" "Stopping VM first..."; stop_vm "$1"; sleep 1; }
    rm -f "$IMG_FILE" "$SEED_FILE" "$VM_DIR/$1.conf" "${IMG_FILE}.lock" 2>/dev/null
    print_status "SUCCESS" "VM '$1' permanently deleted"
}
 
# ═══════════════════════════════════════════════════════════════
#  RESIZE DISK
# ═══════════════════════════════════════════════════════════════
 
resize_vm_disk() {
    load_vm_config "$1" || return 1
    if is_vm_running "$1"; then
        print_status "ERROR" "Stop the VM before resizing its disk"
        return 1
    fi
    print_status "INFO" "Current disk size: $DISK_SIZE"
    while true; do
        read -p "  $(print_status "INPUT" "New disk size (e.g. 50G): ")" ns
        validate_input "size" "$ns" || continue
        if qemu-img resize "$IMG_FILE" "$ns"; then
            DISK_SIZE="$ns"
            save_vm_config
            print_status "SUCCESS" "Disk resized to $ns"
        else
            print_status "ERROR" "qemu-img resize failed"
        fi
        break
    done
}
 
# ═══════════════════════════════════════════════════════════════
#  PERFORMANCE STATS
# ═══════════════════════════════════════════════════════════════
 
show_vm_performance() {
    load_vm_config "$1" || return 1
    echo
    sep_thin
    echo -e "  ${GOLD}📊 PERFORMANCE — ${W}$1${N}"
    sep_thin
    if is_vm_running "$1"; then
        local pid
        pid=$(pgrep -f "qemu-system.*${IMG_FILE}" | head -1)
        if [[ -n "$pid" ]]; then
            echo -e "  ${C}Process:${N}"
            ps -p "$pid" -o pid,%cpu,%mem,rss --no-headers | \
                awk '{printf "  PID: \033[1;33m%-7s\033[0m  CPU: \033[1;32m%5s%%\033[0m  MEM: \033[1;36m%5s%%\033[0m  RSS: \033[1;35m%s KB\033[0m\n",
                     $1, $2, $3, $4}'
            echo
            echo -e "  ${C}Host Memory:${N}"
            free -h | awk '/^Mem:/{
                printf "  Total: \033[1;37m%-8s\033[0m  Used: \033[1;31m%-8s\033[0m  Free: \033[1;32m%s\033[0m\n",
                $2, $3, $4}'
            echo
            echo -e "  ${C}Image on disk:${N}"
            du -sh "$IMG_FILE" 2>/dev/null | \
                awk '{printf "  \033[1;33m%s\033[0m\n", $1}'
        fi
    else
        print_status "INFO" "VM is not running"
        echo -e "  ${DIM}Configured: ${MEMORY}MB RAM  │  ${CPUS} vCPU(s)  │  ${DISK_SIZE} disk${N}"
    fi
    sep_thin
    echo
    read -p "  Press ${Y}Enter${N} to continue..."
}
 
# ═══════════════════════════════════════════════════════════════
#  FIX VM ISSUES
# ═══════════════════════════════════════════════════════════════
 
fix_vm_issues() {
    load_vm_config "$1" || return 1
    echo
    echo -e "  ${GOLD}🔧 FIX ISSUES — ${W}$1${N}"
    sep_thin
    echo -e "  ${C}1)${N} 🔓 Remove lock files"
    echo -e "  ${C}2)${N} 🌱 Recreate cloud-init seed ISO"
    echo -e "  ${C}3)${N} 💾 Rewrite config file"
    echo -e "  ${C}4)${N} 💀 Kill stuck QEMU processes"
    echo -e "  ${R}0)${N} ↩  Back"
    sep_thin
    echo
    read -p "  $(print_status "INPUT" "Choice: ")" fc
    case $fc in
        1) rm -f "${IMG_FILE}.lock" "${IMG_FILE}"*.lock 2>/dev/null
           print_status "SUCCESS" "Lock files removed" ;;
        2) rm -f "$SEED_FILE"
           setup_vm_image
           print_status "SUCCESS" "Seed ISO rebuilt" ;;
        3) save_vm_config ;;
        4) pkill    -f "qemu-system.*${IMG_FILE}" 2>/dev/null; sleep 1
           pgrep    -f "qemu-system.*${IMG_FILE}" >/dev/null && \
           pkill -9 -f "qemu-system.*${IMG_FILE}" 2>/dev/null
           rm -f "${IMG_FILE}.lock" 2>/dev/null
           print_status "SUCCESS" "Stuck processes terminated" ;;
        0) return 0 ;;
        *) print_status "ERROR" "Invalid choice" ;;
    esac
    echo
    read -p "  Press ${Y}Enter${N} to continue..."
}
 
# ═══════════════════════════════════════════════════════════════
#  VM PICKER HELPER
# ═══════════════════════════════════════════════════════════════
 
pick_vm() {
    local prompt="$1"
    shift
    local vms=("$@")
    while true; do
        read -p "  $(print_status "INPUT" "$prompt [1-${#vms[@]}]: ")" vm_num
        if [[ "$vm_num" =~ ^[0-9]+$ ]] && \
           [ "$vm_num" -ge 1 ] && \
           [ "$vm_num" -le "${#vms[@]}" ]; then
            echo "${vms[$((vm_num - 1))]}"
            return 0
        fi
        print_status "ERROR" "Enter a number between 1 and ${#vms[@]}"
    done
}
 
# ═══════════════════════════════════════════════════════════════
#  VM MANAGEMENT SUBMENU
# ═══════════════════════════════════════════════════════════════
 
vm_submenu() {
    local vms=("$@")
    local vm_count=${#vms[@]}
    [[ $vm_count -eq 0 ]] && return
 
    while true; do
        print_header
        echo -e "  ${GOLD}🖥️  Virtual Machine Manager  (${vm_count} VMs)${N}\n"
        for i in "${!vms[@]}"; do
            if is_vm_running "${vms[$i]}"; then
                echo -e "  ${G}$((i+1)))${N}  ${W}${vms[$i]}${N}  ${G}● RUNNING${N}"
            else
                echo -e "  ${C}$((i+1)))${N}  ${W}${vms[$i]}${N}  ${DIM}○ stopped${N}"
            fi
        done
        echo
        sep_thin
        echo -e "  ${C}a)${N} 🚀 Start     ${C}b)${N} 🛑 Stop      ${C}c)${N} 📋 Info"
        echo -e "  ${C}d)${N} ✏️  Edit      ${C}e)${N} 🗑️  Delete    ${C}f)${N} 📈 Resize"
        echo -e "  ${C}g)${N} 📊 Perf      ${C}h)${N} 🔧 Fix       ${R}0)${N} ↩  Back"
        sep_thin
        echo
 
        local vm
        read -p "  $(print_status "INPUT" "Action: ")" action
        case $action in
            a) vm=$(pick_vm "Start VM"    "${vms[@]}"); start_vm           "$vm" ;;
            b) vm=$(pick_vm "Stop VM"     "${vms[@]}"); stop_vm            "$vm" ;;
            c) vm=$(pick_vm "Show info"   "${vms[@]}"); show_vm_info       "$vm" ;;
            d) vm=$(pick_vm "Edit VM"     "${vms[@]}"); edit_vm_config     "$vm" ;;
            e) vm=$(pick_vm "Delete VM"   "${vms[@]}"); delete_vm          "$vm" ;;
            f) vm=$(pick_vm "Resize disk" "${vms[@]}"); resize_vm_disk     "$vm" ;;
            g) vm=$(pick_vm "Show perf"   "${vms[@]}"); show_vm_performance "$vm" ;;
            h) vm=$(pick_vm "Fix VM"      "${vms[@]}"); fix_vm_issues      "$vm" ;;
            0) return 0 ;;
            *) print_status "ERROR" "Invalid action" ;;
        esac
        read -p "  Press ${Y}Enter${N} to continue..."
    done
}
 

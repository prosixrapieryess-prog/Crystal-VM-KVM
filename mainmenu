# ─── KVM DETECTION ──────────────────────────────────────────
detect_kvm() {
    if [[ -e /dev/kvm ]] && [[ -r /dev/kvm ]] && [[ -w /dev/kvm ]]; then
        if command -v kvm-ok &>/dev/null; then
            kvm-ok &>/dev/null && KVM_AVAILABLE=true || KVM_AVAILABLE=false
        else
            KVM_AVAILABLE=true
        fi
    else
        KVM_AVAILABLE=false
    fi
}


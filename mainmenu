# ─── HEADER ──────────────────────────────────────────────────
print_header() {
    clear
    print_logo
    # Show KVM status
    if kvm_available; then
        echo -e "  ${G}${BLD}⚡ KVM Acceleration:${N} ${G}ENABLED${N}          $(date '+%a %d %b %Y  %H:%M:%S')"
    else
        echo -e "  ${Y}${BLD}🐢 KVM Acceleration:${N} ${Y}DISABLED (TCG mode)${N}  $(date '+%a %d %b %Y  %H:%M:%S')"
    fi

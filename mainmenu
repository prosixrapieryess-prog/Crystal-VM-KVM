# ─── VM SELECTOR HELPER ──────────────────────────────────────
select_vm() {
    local prompt="$1"
    local vms=("${@:2}")
    local count=${#vms[@]}
 
    echo
    for i in "${!vms[@]}"; do
        local status="${D}💤${N}"
        is_vm_running "${vms[$i]}" && status="${G}🚀${N}"
        printf "    ${C}%2d)${N}  %s  %b\n" $((i+1)) "${vms[$i]}" "$status"
    done
    echo
    print_status INPUT "$prompt [1-$count]: "; read -r sel
    if [[ "$sel" =~ ^[0-9]+$ ]] && (( sel >= 1 && sel <= count )); then
        SELECTED_VM="${vms[$((sel-1))]}"
        return 0
    fi
    print_status ERROR "Invalid selection."
    return 1
}
 

# ── PROGRESS BAR ────────────────────────────────────────────────
progress_bar() {
    local duration="${1:-2}"
    local label="${2:-Loading}"
    local width=40
    local step
    step=$(awk "BEGIN{printf \"%.4f\", $duration/$width}")
    echo
    for ((i=0; i<=width; i++)); do
        local pct=$(( i * 100 / width ))
        local bar=""
        for ((f=0; f<i; f++));     do bar+="█"; done
        for ((e=i; e<width; e++)); do bar+="░"; done
        printf "\r  ${C}%-18s${N} [${G}%s${N}] ${Y}%3d%%${N}" "$label" "$bar" "$pct"
        sleep "$step"
    done
    echo -e "  ${G}✔${N}"
    echo
}
 
# ── SPINNER ─────────────────────────────────────────────────────
spin_until() {
    local pid=$!
    local frames=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${C}[%s]${N} Working..." "${frames[$((i % 8))]}"
        sleep 0.1
        ((i++))
    done
    printf "\r  ${G}[✔]${N} Done!          \n"
    wait "$pid"
}
 

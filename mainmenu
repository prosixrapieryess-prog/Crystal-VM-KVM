# ── KVM: IMAGE LOCK CHECK ────────────────────────────────────────────
 
kvm_check_lock() {
    local img_file=$1; local vm_name=$2; local check_only="${3:-}"
    if lsof "$img_file" 2>/dev/null | grep -q qemu-system; then
        [[ "$check_only" == "--check-only" ]] && return 1
        kvm_status "WARN" "🔒 Image file is in use by another QEMU process"
        local pid; pid=$(lsof "$img_file" 2>/dev/null | awk '/qemu-system/{print $2; exit}')
        if [[ -n "$pid" ]]; then
            kvm_status "INFO" "🔍 Process ID: ${KGOLD}$pid${KRESET}"
            read -rp "$(kvm_status "INPUT" " Kill existing process and restart? (y/N): ")" kc
            if [[ "$kc" =~ ^[Yy]$ ]]; then
                kill "$pid" 2>/dev/null; sleep 2
                kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
                return 0
            fi
        fi
        return 1
    fi
    local lock_file="${img_file}.lock"
    if [[ -f "$lock_file" ]]; then
        [[ "$check_only" == "--check-only" ]] && return 1
        kvm_status "WARN" "🔒 Lock file found: $lock_file"
        if find "$lock_file" -mmin +5 2>/dev/null | grep -q .; then
            kvm_status "WARN" "⏰ Lock file is stale (> 5 min)"
            read -rp "$(kvm_status "INPUT" " Remove stale lock? (y/N): ")" rl
            if [[ "$rl" =~ ^[Yy]$ ]]; then
                rm -f "$lock_file"; kvm_status "SUCCESS" "✅ Stale lock removed"; return 0
            fi
        fi
        return 1
    fi
    return 0
}
 

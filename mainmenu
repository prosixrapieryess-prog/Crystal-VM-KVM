    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    password: $hashed_pw
chpasswd:
  list: |
    root:$PASSWORD
    $USERNAME:$PASSWORD
  expire: false
EOF
    cat > meta-data <<EOF
instance-id: iid-$VM_NAME
local-hostname: $HOSTNAME
EOF
    rm -f "$SEED_FILE"
    if ! cloud-localds "$SEED_FILE" user-data meta-data; then

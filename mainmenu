# ── KVM: SETUP VM IMAGE ──────────────────────────────────────────────
 
kvm_setup_image() {
    kvm_status "SECTION" "🖥️  Image Setup"
    mkdir -p "$VM_DIR"
    if [[ -f "$IMG_FILE" ]]; then
        kvm_status "INFO" "✅ Image already exists — skipping download"
    else
        kvm_status "INFO" "🌐 Downloading: ${KSKY}$IMG_URL${KRESET}"
        if ! wget --progress=bar:force "$IMG_URL" -O "${IMG_FILE}.tmp"; then
            kvm_status "ERROR" "Download failed"; exit 1
        fi
        mv "${IMG_FILE}.tmp" "$IMG_FILE"
        kvm_status "SUCCESS" "Download complete"
    fi
    if ! qemu-img resize "$IMG_FILE" "$DISK_SIZE" 2>/dev/null; then
        kvm_status "WARN" "In-place resize failed — converting to new qcow2 at $DISK_SIZE..."
        local tmp="${IMG_FILE}.converting"
        if qemu-img convert -f qcow2 -O qcow2 "$IMG_FILE" "$tmp" && qemu-img resize "$tmp" "$DISK_SIZE"; then
            mv "$tmp" "$IMG_FILE"; kvm_status "SUCCESS" "Converted and resized"
        else
            rm -f "$tmp"; kvm_status "ERROR" "Could not resize image"; exit 1
        fi
    fi
    kvm_rebuild_seed
    echo; kvm_gradient_line 76
    kvm_box_top; kvm_box_line ""
    kvm_box_line "  🎉  VM '${VM_NAME}' created successfully!" "${KGOLD}${KBOLD}"
    kvm_box_sep;  kvm_box_line ""
    kvm_box_lc "  👤  Username" "$USERNAME"
    kvm_box_lc "  🔑  Password" "$PASSWORD"
    kvm_box_lc "  🔌  SSH"      "ssh -p $SSH_PORT $USERNAME@localhost"
    kvm_box_lc "  💾  Disk"     "$DISK_SIZE  |  🧠 ${MEMORY}MB  |  ⚡ $CPUS vCPU(s)"
    kvm_box_line ""; kvm_box_bottom; kvm_gradient_line 76; echo
}
 
# ── KVM: SAVE CONFIG (colorful version) ──────────────────────────────
 
kvm_save_config() {
    cat > "$VM_DIR/$VM_NAME.conf" <<EOF
VM_NAME="$VM_NAME"
OS_TYPE="$OS_TYPE"
CODENAME="$CODENAME"
IMG_URL="$IMG_URL"
HOSTNAME="$HOSTNAME"
USERNAME="$USERNAME"
PASSWORD="$PASSWORD"
DISK_SIZE="$DISK_SIZE"
MEMORY="$MEMORY"
CPUS="$CPUS"
SSH_PORT="$SSH_PORT"
GUI_MODE="$GUI_MODE"
PORT_FORWARDS="$PORT_FORWARDS"
IMG_FILE="$IMG_FILE"
SEED_FILE="$SEED_FILE"
CREATED="$CREATED"
EOF
    kvm_status "SUCCESS" "💾 Config saved  →  ${KSKY}$VM_DIR/$VM_NAME.conf${KRESET}"
}
 
# ── KVM: CREATE NEW VM ───────────────────────────────────────────────
 
declare -A KVM_OS_OPTIONS=(
    ["Ubuntu 22.04 LTS"]="ubuntu|jammy|https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img|ubuntu22|ubuntu|ubuntu"
    ["Ubuntu 24.04 LTS"]="ubuntu|noble|https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img|ubuntu24|ubuntu|ubuntu"
    ["Debian 11 Bullseye"]="debian|bullseye|https://cloud.debian.org/images/cloud/bullseye/latest/debian-11-generic-amd64.qcow2|debian11|debian|debian"
    ["Debian 12 Bookworm"]="debian|bookworm|https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-generic-amd64.qcow2|debian12|debian|debian"
    ["Debian 13 Trixie"]="debian|trixie|https://cloud.debian.org/images/cloud/trixie/daily/latest/debian-13-generic-amd64-daily.qcow2|debian13|debian|debian"
    ["Fedora 40"]="fedora|40|https://download.fedoraproject.org/pub/fedora/linux/releases/40/Cloud/x86_64/images/Fedora-Cloud-Base-40-1.14.x86_64.qcow2|fedora40|fedora|fedora"
    ["CentOS Stream 9"]="centos|stream9|https://cloud.centos.org/centos/9-stream/x86_64/images/CentOS-Stream-GenericCloud-9-latest.x86_64.qcow2|centos9|centos|centos"
    ["AlmaLinux 9"]="almalinux|9|https://repo.almalinux.org/almalinux/9/cloud/x86_64/images/AlmaLinux-9-GenericCloud-latest.x86_64.qcow2|almalinux9|alma|alma"
    ["Rocky Linux 9"]="rockylinux|9|https://download.rockylinux.org/pub/rocky/9/images/x86_64/Rocky-9-GenericCloud.latest.x86_64.qcow2|rocky9|rocky|rocky"
)
 
kvm_create_vm() {
    kvm_status "SECTION" "🆕  Create New Virtual Machine"
    local kos_keys=()
    mapfile -t kos_keys < <(printf '%s\n' "${!KVM_OS_OPTIONS[@]}" | sort)
    local os_count=${#kos_keys[@]}
    echo; kvm_box_top
    kvm_box_line "  🌍  Available Operating Systems" "${KGOLD}${KBOLD}"
    kvm_box_sep
    local i=1
    local ec_arr=("${KR}" "${KORANGE}" "${KGOLD}" "${KLIME}" "${KTEAL}" "${KCYAN}" "${KLBLUE}" "${KBLUE}" "${KVIOLET}")
    for os in "${kos_keys[@]}"; do
        local icon="🐧"
        [[ "$os" == *Ubuntu*  ]] && icon="🟠"; [[ "$os" == *Debian*  ]] && icon="🔴"
        [[ "$os" == *Fedora*  ]] && icon="🔵"; [[ "$os" == *CentOS*  ]] && icon="🟣"
        [[ "$os" == *Alma*    ]] && icon="⚡";  [[ "$os" == *Rocky*   ]] && icon="🟢"
        local ec="${ec_arr[$((($i-1) % ${#ec_arr[@]}))]}"
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}%3d)${KRESET}  ${ec}${icon}  %-55s${KRESET}  ${KCYAN}║${KRESET}\n" "$i" "$os"
        ((i++))
    done
    kvm_box_bottom; echo
    local os_name
    while true; do
        read -rp "$(kvm_status "INPUT" " Select OS (1–$os_count): ")" choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= os_count )); then
            os_name="${kos_keys[$((choice-1))]}"
            IFS='|' read -r OS_TYPE CODENAME IMG_URL DEFAULT_HOSTNAME DEFAULT_USERNAME DEFAULT_PASSWORD \
                <<< "${KVM_OS_OPTIONS[$os_name]}"
            kvm_status "SUCCESS" "Selected: ${KGOLD}$os_name${KRESET}"
            break
        fi
        kvm_status "ERROR" "Invalid — enter 1 to $os_count"
    done
    kvm_neon_divider; echo
    while true; do
        read -rp "$(kvm_status "INPUT" " 🏷️   VM name        [default: ${KGOLD}$DEFAULT_HOSTNAME${KRESET}]: ")" VM_NAME
        VM_NAME="${VM_NAME:-$DEFAULT_HOSTNAME}"
        if validate_input "name" "$VM_NAME"; then
            [[ -f "$VM_DIR/$VM_NAME.conf" ]] && { kvm_status "ERROR" "VM '${KGOLD}$VM_NAME${KRESET}' already exists"; continue; }
            break
        fi
    done
    while true; do
        read -rp "$(kvm_status "INPUT" " 🏠  Hostname       [default: ${KGOLD}$VM_NAME${KRESET}]: ")" HOSTNAME
        HOSTNAME="${HOSTNAME:-$VM_NAME}"; validate_input "name" "$HOSTNAME" && break
    done
    while true; do
        read -rp "$(kvm_status "INPUT" " 👤  Username       [default: ${KGOLD}$DEFAULT_USERNAME${KRESET}]: ")" USERNAME
        USERNAME="${USERNAME:-$DEFAULT_USERNAME}"; validate_input "username" "$USERNAME" && break
    done
    while true; do
        read -rsp "$(kvm_status "INPUT" " 🔑  Password       [default: ${KGOLD}$DEFAULT_PASSWORD${KRESET}]: ")" PASSWORD
        PASSWORD="${PASSWORD:-$DEFAULT_PASSWORD}"; echo
        [[ -n "$PASSWORD" ]] && break; kvm_status "ERROR" "Password cannot be empty"
    done
    while true; do
        read -rp "$(kvm_status "INPUT" " 💾  Disk size      [default: ${KGOLD}20G${KRESET}]: ")" DISK_SIZE
        DISK_SIZE="${DISK_SIZE:-20G}"; validate_input "size" "$DISK_SIZE" && break
    done
    while true; do
        read -rp "$(kvm_status "INPUT" " 🧠  Memory (MB)    [default: ${KGOLD}2048${KRESET}]: ")" MEMORY
        MEMORY="${MEMORY:-2048}"; validate_input "number" "$MEMORY" && break
    done
    while true; do
        read -rp "$(kvm_status "INPUT" " ⚡  CPUs           [default: ${KGOLD}2${KRESET}]: ")" CPUS
        CPUS="${CPUS:-2}"; validate_input "number" "$CPUS" && break
    done
    while true; do
        read -rp "$(kvm_status "INPUT" " 🔌  SSH Port       [default: ${KGOLD}2222${KRESET}]: ")" SSH_PORT
        SSH_PORT="${SSH_PORT:-2222}"
        if validate_input "port" "$SSH_PORT"; then
            ss -tln 2>/dev/null | grep -q ":$SSH_PORT " && { kvm_status "ERROR" "Port $SSH_PORT in use"; continue; }
            break
        fi
    done
    while true; do
        read -rp "$(kvm_status "INPUT" " 🖥️   Enable GUI     [y/n, default: ${KGOLD}n${KRESET}]: ")" gui_input
        gui_input="${gui_input:-n}"
        if   [[ "$gui_input" =~ ^[Yy]$ ]]; then GUI_MODE=true;  break
        elif [[ "$gui_input" =~ ^[Nn]$ ]]; then GUI_MODE=false; break
        else kvm_status "ERROR" "Please answer y or n"; fi
    done
    read -rp "$(kvm_status "INPUT" " 🌐  Port-forwards  [e.g. ${KGOLD}8080:80,3000:3000${KRESET} or Enter for none]: ")" PORT_FORWARDS
    IMG_FILE="$VM_DIR/$VM_NAME.img"; SEED_FILE="$VM_DIR/$VM_NAME-seed.iso"; CREATED="$(date)"
    kvm_setup_image; kvm_save_config
}
 
# ── KVM: STOP VM ─────────────────────────────────────────────────────
 
kvm_stop_vm() {
    local vm_name=$1; load_vm_config "$vm_name" || return 1
    if is_vm_running "$vm_name"; then
        kvm_status "INFO" "🛑 Stopping VM: ${KGOLD}$vm_name${KRESET}"
        pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null || true; sleep 2
        if is_vm_running "$vm_name"; then
            kvm_status "WARN" "Graceful stop failed — forcing termination..."
            pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null || true; sleep 1
        fi
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true
        is_vm_running "$vm_name" && { kvm_status "ERROR" "Failed to stop VM"; return 1; }
        kvm_status "SUCCESS" "✅ VM ${KGOLD}$vm_name${KRESET} stopped"
    else
        kvm_status "INFO" "💤 VM ${KGOLD}$vm_name${KRESET} is already stopped"
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true
    fi
}
 
# ── KVM: START VM ────────────────────────────────────────────────────
 
kvm_start_vm() {
    local vm_name=$1; load_vm_config "$vm_name" || return 1
    if ! kvm_check_lock "$IMG_FILE" "$vm_name"; then
        kvm_status "ERROR" "🔒 Image locked"
        read -rp "$(kvm_status "INPUT" " Force kill all QEMU on this image? (y/N): ")" fk
        if [[ "$fk" =~ ^[Yy]$ ]]; then
            pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null || true; sleep 2
            pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
            rm -f "${IMG_FILE}.lock" 2>/dev/null || true
            kvm_status "SUCCESS" "Cleared"
        else return 1; fi
    fi
    if is_vm_running "$vm_name"; then
        kvm_status "WARN" "VM '${KGOLD}$vm_name${KRESET}' is already running"
        read -rp "$(kvm_status "INPUT" " Stop and restart? (y/N): ")" rc
        [[ "$rc" =~ ^[Yy]$ ]] && { kvm_stop_vm "$vm_name"; sleep 2; } || return 1
    fi
    [[ -f "$IMG_FILE" ]] || { kvm_status "ERROR" "Image not found: ${KCORAL}$IMG_FILE${KRESET}"; return 1; }
    [[ ! -f "$SEED_FILE" ]] && { kvm_status "WARN" "Seed missing — recreating..."; kvm_rebuild_seed; }
    echo; kvm_gradient_line 76
    kvm_box_top; kvm_box_line ""
    kvm_box_line "  🚀  Launching VM: ${vm_name}" "${KGOLD}${KBOLD}"
    kvm_box_sep;  kvm_box_line ""
    kvm_box_lc "  🔌  SSH"      "ssh -p $SSH_PORT $USERNAME@localhost"
    kvm_box_lc "  🔑  Password" "$PASSWORD"
    kvm_box_lc "  🧠  RAM"      "${MEMORY}MB"
    kvm_box_lc "  ⚡  CPUs"     "$CPUS"
    kvm_box_lc "  💾  Disk"     "$DISK_SIZE"
    kvm_box_lc "  🌐  Forwards" "${PORT_FORWARDS:-None}"
    kvm_box_lc "  🐢  Engine"   "Pure TCG Software Emulation"
    kvm_box_line ""; kvm_box_bottom; kvm_gradient_line 76; echo
    local netdev_str="user,id=net0,hostfwd=tcp::${SSH_PORT}-:22"
    if [[ -n "${PORT_FORWARDS:-}" ]]; then
        IFS=',' read -ra forwards <<< "$PORT_FORWARDS"
        for forward in "${forwards[@]}"; do
            forward="${forward// /}"; IFS=':' read -r hp gp <<< "$forward"
            netdev_str+=",hostfwd=tcp::${hp}-:${gp}"
        done
    fi
    local qemu_cmd=(
        qemu-system-x86_64 -m "$MEMORY" -smp "$CPUS" -cpu qemu64
        -machine type=pc,accel=tcg
        -drive "file=$IMG_FILE,format=qcow2,if=virtio"
        -drive "file=$SEED_FILE,format=raw,if=virtio"
        -boot order=c
        -device virtio-net-pci,netdev=net0
        -netdev "$netdev_str"
        -device virtio-balloon-pci
        -object "rng-random,filename=/dev/urandom,id=rng0"
        -device virtio-rng-pci,rng=rng0
        -no-hpet -rtc base=utc,clock=host
    )
    if [[ "${GUI_MODE}" == true ]]; then
        qemu_cmd+=(-vga virtio -display gtk,gl=on)
        kvm_status "INFO" "🖥️  GUI mode active"
    else
        qemu_cmd+=(-nographic -serial mon:stdio)
        kvm_status "INFO" "📟 Console mode  |  ${KGOLD}Ctrl+A then X${KRESET} to quit"
    fi
    if ! "${qemu_cmd[@]}"; then
        kvm_status "ERROR" "QEMU failed — check config or image integrity"
        rm -f "${IMG_FILE}.lock" 2>/dev/null || true; return 1
    fi
    kvm_status "INFO" "VM ${KGOLD}$vm_name${KRESET} has shut down"
}
 
# ── KVM: DELETE VM ───────────────────────────────────────────────────
 
kvm_delete_vm() {
    local vm_name=$1; echo
    echo -e "  ${KBG_RED}${KBOLD}${KCREAM}  ⚠️  DANGER ZONE  ⚠️  ${KRESET}"; echo
    kvm_status "WARN" "This will ${KR}${KBOLD}PERMANENTLY${KRESET}${KAMBER} delete VM '${KGOLD}$vm_name${KRESET}${KAMBER}' and ALL data!"
    echo
    read -rp "$(kvm_status "INPUT" " Type the VM name to confirm: ")" confirm_name
    if [[ "$confirm_name" == "$vm_name" ]]; then
        load_vm_config "$vm_name" || return 1
        if is_vm_running "$vm_name"; then
            kvm_status "WARN" "VM is running — stopping first..."; kvm_stop_vm "$vm_name"; sleep 2
        fi
        rm -f "$IMG_FILE" "$SEED_FILE" "$VM_DIR/$vm_name.conf" "${IMG_FILE}.lock" 2>/dev/null || true
        kvm_status "SUCCESS" "🗑️  VM '${KGOLD}$vm_name${KRESET}' deleted"
    else
        kvm_status "INFO" "Name mismatch — deletion cancelled"
    fi
}
 
# ── KVM: SHOW VM INFO ────────────────────────────────────────────────
 
kvm_show_info() {
    local vm_name=$1; load_vm_config "$vm_name" || return 1
    local run_status; local lock_status
    is_vm_running "$vm_name" \
        && run_status="${KLIME}${KBOLD}🚀 Running${KRESET}" \
        || run_status="${KDIM}${KSKY}💤 Stopped${KRESET}"
    kvm_check_lock "$IMG_FILE" "$vm_name" "--check-only" \
        && lock_status="${KLIME}🔓 Unlocked${KRESET}" \
        || lock_status="${KAMBER}🔒 Locked${KRESET}"
    echo; kvm_gradient_line 76
    kvm_box_top; kvm_box_line ""
    kvm_box_line "  📊  VM Details — $vm_name" "${KGOLD}${KBOLD}"
    kvm_box_sep;  kvm_box_line ""
    kvm_box_lc "  🌍  OS"        "$OS_TYPE ($CODENAME)"
    kvm_box_lc "  🏷️   Hostname"  "$HOSTNAME"
    kvm_box_lc "  👤  Username"  "$USERNAME"
    kvm_box_lc "  🔑  Password"  "$PASSWORD"
    kvm_box_lc "  🔌  SSH Port"  "$SSH_PORT"
    kvm_box_lc "  🧠  Memory"    "${MEMORY} MB"
    kvm_box_lc "  ⚡  CPUs"      "$CPUS"
    kvm_box_lc "  💾  Disk"      "$DISK_SIZE"
    kvm_box_lc "  🖥️   GUI Mode"  "$GUI_MODE"
    kvm_box_lc "  🌐  Forwards"  "${PORT_FORWARDS:-None}"
    kvm_box_lc "  📅  Created"   "$CREATED"
    kvm_box_sep
    printf "  ${KCYAN}║${KRESET}  ${KGOLD}%-18s${KRESET}  ${lock_status}%-38s  ${KCYAN}║${KRESET}\n" "  🔒  Lock" ""
    printf "  ${KCYAN}║${KRESET}  ${KGOLD}%-18s${KRESET}  ${run_status}%-38s  ${KCYAN}║${KRESET}\n"  "  ⚡  Status" ""
    kvm_box_line ""; kvm_box_bottom; kvm_gradient_line 76; echo
    read -rp "$(kvm_status "INPUT" " ⏎  Press Enter to continue...")"
}
 
# ── KVM: EDIT VM CONFIG ──────────────────────────────────────────────
 
kvm_edit_config() {
    local vm_name=$1; load_vm_config "$vm_name" || return 1
    kvm_status "SECTION" "✏️   Edit VM — $vm_name"
    while true; do
        echo; kvm_box_top
        kvm_box_line "  📝  What would you like to edit?" "${KCYAN}${KBOLD}"
        kvm_box_sep
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  1)${KRESET}  🏷️   ${KCREAM}Hostname      ${KDIM}→ ${KSKY}$HOSTNAME${KRESET}%$((42 - ${#HOSTNAME}))s${KCYAN}║${KRESET}\n" ""
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  2)${KRESET}  👤  ${KCREAM}Username      ${KDIM}→ ${KSKY}$USERNAME${KRESET}%$((42 - ${#USERNAME}))s${KCYAN}║${KRESET}\n" ""
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  3)${KRESET}  🔑  ${KCREAM}Password      ${KDIM}→ ${KAMBER}****${KRESET}%46s${KCYAN}║${KRESET}\n" ""
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  4)${KRESET}  🔌  ${KCREAM}SSH Port      ${KDIM}→ ${KSKY}$SSH_PORT${KRESET}%$((42 - ${#SSH_PORT}))s${KCYAN}║${KRESET}\n" ""
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  5)${KRESET}  🖥️   ${KCREAM}GUI Mode      ${KDIM}→ ${KSKY}$GUI_MODE${KRESET}%$((42 - ${#GUI_MODE}))s${KCYAN}║${KRESET}\n" ""
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  6)${KRESET}  🌐  ${KCREAM}Port Forwards ${KDIM}→ ${KSKY}${PORT_FORWARDS:-None}${KRESET}%$((41 - ${#PORT_FORWARDS:-None}))s${KCYAN}║${KRESET}\n" ""
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  7)${KRESET}  🧠  ${KCREAM}Memory MB     ${KDIM}→ ${KSKY}${MEMORY}${KRESET}%$((42 - ${#MEMORY}))s${KCYAN}║${KRESET}\n" ""
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  8)${KRESET}  ⚡  ${KCREAM}CPUs          ${KDIM}→ ${KSKY}$CPUS${KRESET}%$((42 - ${#CPUS}))s${KCYAN}║${KRESET}\n" ""
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  9)${KRESET}  💾  ${KCREAM}Resize Disk   ${KDIM}→ ${KSKY}$DISK_SIZE${KRESET}%$((42 - ${#DISK_SIZE}))s${KCYAN}║${KRESET}\n" ""
        kvm_box_sep
        printf "  ${KCYAN}║${KRESET}  ${KR}  0)${KRESET}  ↩️   ${KCORAL}Back%68s${KCYAN}║${KRESET}\n" ""
        kvm_box_bottom; echo
        read -rp "$(kvm_status "INPUT" " Your choice: ")" ec
        local needs_reseed=false
        case $ec in
            1) while true; do
                   read -rp "$(kvm_status "INPUT" " New hostname [${KGOLD}$HOSTNAME${KRESET}]: ")" v; v="${v:-$HOSTNAME}"
                   validate_input "name" "$v" && { HOSTNAME="$v"; needs_reseed=true; break; }; done ;;
            2) while true; do
                   read -rp "$(kvm_status "INPUT" " New username [${KGOLD}$USERNAME${KRESET}]: ")" v; v="${v:-$USERNAME}"
                   validate_input "username" "$v" && { USERNAME="$v"; needs_reseed=true; break; }; done ;;
            3) while true; do
                   read -rsp "$(kvm_status "INPUT" " New password: ")" v; echo; v="${v:-$PASSWORD}"
                   [[ -n "$v" ]] && { PASSWORD="$v"; needs_reseed=true; break; } || kvm_status "ERROR" "Cannot be empty"; done ;;
            4) while true; do
                   read -rp "$(kvm_status "INPUT" " New SSH port [${KGOLD}$SSH_PORT${KRESET}]: ")" v; v="${v:-$SSH_PORT}"
                   if validate_input "port" "$v"; then
                       [[ "$v" != "$SSH_PORT" ]] && ss -tln 2>/dev/null | grep -q ":$v " \
                           && { kvm_status "ERROR" "Port $v in use"; continue; }
                       SSH_PORT="$v"; break
                   fi; done ;;
            5) while true; do
                   read -rp "$(kvm_status "INPUT" " Enable GUI? (y/n) [${KGOLD}$GUI_MODE${KRESET}]: ")" v
                   if   [[ "$v" =~ ^[Yy]$ ]]; then GUI_MODE=true;  break
                   elif [[ "$v" =~ ^[Nn]$ ]]; then GUI_MODE=false; break
                   elif [[ -z "$v" ]]; then break
                   else kvm_status "ERROR" "Please answer y or n"; fi; done ;;
            6) read -rp "$(kvm_status "INPUT" " Port forwards [${KGOLD}${PORT_FORWARDS:-None}${KRESET}]: ")" v
               PORT_FORWARDS="${v:-${PORT_FORWARDS:-}}" ;;
            7) while true; do
                   read -rp "$(kvm_status "INPUT" " Memory MB [${KGOLD}$MEMORY${KRESET}]: ")" v; v="${v:-$MEMORY}"
                   validate_input "number" "$v" && { MEMORY="$v"; break; }; done ;;
            8) while true; do
                   read -rp "$(kvm_status "INPUT" " CPU count [${KGOLD}$CPUS${KRESET}]: ")" v; v="${v:-$CPUS}"
                   validate_input "number" "$v" && { CPUS="$v"; break; }; done ;;
            9) kvm_save_config; kvm_resize_disk "$vm_name"; load_vm_config "$vm_name"; continue ;;
            0) return 0 ;;
            *) kvm_status "ERROR" "Invalid selection"; continue ;;
        esac
        $needs_reseed && kvm_rebuild_seed
        kvm_save_config
        echo; read -rp "$(kvm_status "INPUT" " Continue editing? (y/N): ")" more
        [[ "$more" =~ ^[Yy]$ ]] || break
    done
}
 
# ── KVM: RESIZE DISK ─────────────────────────────────────────────────
 
kvm_resize_disk() {
    local vm_name=$1; load_vm_config "$vm_name" || return 1
    is_vm_running "$vm_name" && { kvm_status "ERROR" "Stop the VM before resizing its disk"; return 1; }
    kvm_status "INFO" "Current disk size: ${KGOLD}$DISK_SIZE${KRESET}"
    while true; do
        read -rp "$(kvm_status "INPUT" " New disk size (e.g. ${KGOLD}50G${KRESET}): ")" new_size
        if validate_input "size" "$new_size"; then
            [[ "$new_size" == "$DISK_SIZE" ]] && { kvm_status "INFO" "Same size — no change"; return 0; }
            local cur_n=${DISK_SIZE%[GgMm]} cur_u=${DISK_SIZE: -1}
            local new_n=${new_size%[GgMm]}  new_u=${new_size: -1}
            [[ "$cur_u" =~ [Gg] ]] && cur_n=$((cur_n * 1024))
            [[ "$new_u" =~ [Gg] ]] && new_n=$((new_n * 1024))
            if (( new_n < cur_n )); then
                kvm_status "WARN" "⚠️  Shrinking may cause ${KR}DATA LOSS${KAMBER}!"
                read -rp "$(kvm_status "INPUT" " Are you sure? (y/N): ")" ok
                [[ "$ok" =~ ^[Yy]$ ]] || { kvm_status "INFO" "Cancelled"; return 0; }
            fi
            if qemu-img resize "$IMG_FILE" "$new_size"; then
                DISK_SIZE="$new_size"; kvm_save_config
                kvm_status "SUCCESS" "💾 Disk resized to ${KGOLD}$new_size${KRESET}"
            else
                kvm_status "ERROR" "qemu-img resize failed"; return 1
            fi
            break
        fi
    done
}
 
# ── KVM: PERFORMANCE METRICS ─────────────────────────────────────────
 
kvm_show_perf() {
    local vm_name=$1; load_vm_config "$vm_name" || return 1
    kvm_status "SECTION" "📈  Performance Metrics — $vm_name"; echo
    if is_vm_running "$vm_name"; then
        local qemu_pid; qemu_pid=$(pgrep -f "qemu-system.*$IMG_FILE" | head -1)
        if [[ -n "$qemu_pid" ]]; then
            kvm_box_top
            kvm_box_line "  ⚡  QEMU Process  (PID: $qemu_pid)" "${KGOLD}${KBOLD}"
            kvm_box_sep
            local ps_out; ps_out=$(ps -p "$qemu_pid" -o pid,%cpu,%mem,rss --no-headers 2>/dev/null)
            while IFS= read -r line; do
                local pv cv mv rv; read -r pv cv mv rv <<< "$line"
                kvm_box_lc "  📌  PID"  "$pv"
                kvm_box_lc "  🔥  CPU"  "${cv}%"
                kvm_box_lc "  🧠  MEM"  "${mv}%"
                kvm_box_lc "  📦  RSS"  "${rv} kB"
            done <<< "$ps_out"
            kvm_box_sep
            kvm_box_line "  🧠  System Memory:" "${KCYAN}${KBOLD}"
            while IFS= read -r line; do kvm_box_line "    $line" "${KSKY}"; done < <(free -h | awk 'NR<=2')
            kvm_box_sep
            kvm_box_line "  💾  Disk Image:" "${KCYAN}${KBOLD}"
            local du_out; du_out=$(du -h "$IMG_FILE" | awk '{print $1 "  →  " $2}')
            kvm_box_line "    $du_out" "${KSKY}"
            kvm_box_line ""; kvm_box_bottom
        else
            kvm_status "ERROR" "Cannot find QEMU process for ${KGOLD}$vm_name${KRESET}"
        fi
    else
        kvm_box_top
        kvm_box_line "  💤  VM is not running — static config:" "${KAMBER}${KBOLD}"
        kvm_box_sep
        kvm_box_lc "  🧠  RAM"  "${MEMORY}MB"
        kvm_box_lc "  ⚡  CPUs" "$CPUS"
        kvm_box_lc "  💾  Disk" "$DISK_SIZE"
        kvm_box_line ""; kvm_box_bottom
    fi
    echo; read -rp "$(kvm_status "INPUT" " ⏎  Press Enter to continue...")"
}
 
# ── KVM: FIX ISSUES ──────────────────────────────────────────────────
 
kvm_fix_issues() {
    local vm_name=$1; load_vm_config "$vm_name" || return 1
    kvm_status "SECTION" "🔧  Fix Issues — $vm_name"; echo
    kvm_box_top
    kvm_box_line "  🛠️   Select a repair action:" "${KGOLD}${KBOLD}"
    kvm_box_sep
    printf "  ${KCYAN}║${KRESET}  ${KGOLD}  1)${KRESET}  🔓  ${KCREAM}Remove lock files%55s${KCYAN}║${KRESET}\n" ""
    printf "  ${KCYAN}║${KRESET}  ${KGOLD}  2)${KRESET}  🌱  ${KCREAM}Recreate seed image%53s${KCYAN}║${KRESET}\n" ""
    printf "  ${KCYAN}║${KRESET}  ${KGOLD}  3)${KRESET}  🔄  ${KCREAM}Rewrite configuration file%46s${KCYAN}║${KRESET}\n" ""
    printf "  ${KCYAN}║${KRESET}  ${KGOLD}  4)${KRESET}  💀  ${KCREAM}Kill stuck QEMU processes%47s${KCYAN}║${KRESET}\n" ""
    kvm_box_sep
    printf "  ${KCYAN}║${KRESET}  ${KR}  0)${KRESET}  ↩️   ${KCORAL}Back%68s${KCYAN}║${KRESET}\n" ""
    kvm_box_bottom; echo
    read -rp "$(kvm_status "INPUT" " Choice: ")" fc
    case $fc in
        1) rm -f "${IMG_FILE}.lock" "${IMG_FILE}"*.lock 2>/dev/null || true
           kvm_status "SUCCESS" "🔓 Lock files removed" ;;
        2) kvm_rebuild_seed; kvm_status "SUCCESS" "🌱 Seed image recreated" ;;
        3) kvm_save_config;  kvm_status "SUCCESS" "📝 Configuration rewritten" ;;
        4) pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null || true; sleep 1
           pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null || true
           rm -f "${IMG_FILE}.lock" 2>/dev/null || true
           kvm_status "SUCCESS" "💀 Processes killed and lock cleared" ;;
        0) return 0 ;;
        *) kvm_status "ERROR" "Invalid selection" ;;
    esac
    echo; read -rp "$(kvm_status "INPUT" " ⏎  Press Enter to continue...")"
}
 
# ── KVM: PICK VM HELPER ──────────────────────────────────────────────
 
kvm_pick_vm() {
    local prompt="$1"; shift; local kvm_vms=("$@")
    while true; do
        read -rp "$(kvm_status "INPUT" " $prompt (1–${#kvm_vms[@]}): ")" num
        if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#kvm_vms[@]} )); then
            echo "${kvm_vms[$((num-1))]}"; return 0
        fi
        kvm_status "ERROR" "Enter a number between 1 and ${#kvm_vms[@]}"
    done
}
 
# ── KVM: MAIN MENU ───────────────────────────────────────────────────
 
kvm_main_menu() {
    while true; do
        kvm_display_header
        mapfile -t kvm_vms < <(get_vm_list)
        local kvm_vm_count=${#kvm_vms[@]}
        if (( kvm_vm_count > 0 )); then
            kvm_box_top

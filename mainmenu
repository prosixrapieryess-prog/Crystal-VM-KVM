#!/bin/bash
# ============================================================
# PROXLEGENDYT - Advanced VM Manager
# Fully optimized | KVM-Aware | Auto-Dependency Installer
# ============================================================
export LANG=en_US.UTF-8
export TERM=xterm-256color
 
# ─── COLORS ─────────────────────────────────────────────────
R="\e[1;31m"   # Red
G="\e[1;32m"   # Green
Y="\e[1;33m"   # Yellow
B="\e[1;34m"   # Blue
M="\e[1;35m"   # Magenta
C="\e[1;36m"   # Cyan
W="\e[1;37m"   # White
D="\e[2;37m"   # Dim White
N="\e[0m"      # Reset
 
BG_B="\e[44m"  # Blue background
BG_R="\e[41m"  # Red background
BLD="\e[1m"    # Bold
UL="\e[4m"     # Underline
 
# ─── GLOBAL PATHS ────────────────────────────────────────────
VM_DIR="${VM_DIR:-$HOME/vms}"
LOG_FILE="$VM_DIR/manager.log"
 
# ─── LOGGING ─────────────────────────────────────────────────
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE" 2>/dev/null; }
 
# ─── STATUS PRINTER ──────────────────────────────────────────
print_status() {
    local type=$1; shift
    local msg="$*"
    case $type in
        INFO)    echo -e " ${C}${BLD}[  INFO  ]${N}  $msg" ;;
        WARN)    echo -e " ${Y}${BLD}[  WARN  ]${N}  $msg" ;;
        ERROR)   echo -e " ${R}${BLD}[ ERROR  ]${N}  $msg" ;;
        SUCCESS) echo -e " ${G}${BLD}[   OK   ]${N}  $msg" ;;
        INPUT)   echo -ne " ${M}${BLD}[  INPUT ]${N}  $msg" ;;
        KVM)     echo -e " ${G}${BLD}[  KVM   ]${N}  $msg" ;;
        STEP)    echo -e " ${B}${BLD}[ STEP   ]${N}  $msg" ;;
    esac
    log "[$type] $msg"
}
 
# ─── DRAW A DIVIDER ──────────────────────────────────────────
divider() {
    local char="${1:-─}"
    local color="${2:-$D}"
    local width=62
    echo -e "${color}$(printf '%.0s'"$char" $(seq 1 $width))${N}"
}
 

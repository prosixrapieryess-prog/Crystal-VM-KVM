# ─── DELETE VM ───────────────────────────────────────────────
delete_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    echo
    print_status WARN "This will PERMANENTLY DELETE VM '$vm_name' and all its data!"
    print_status INPUT "Type the VM name to confirm deletion: "; read -r confirm
    if [[ "$confirm" != "$vm_name" ]]; then
        print_status INFO "Deletion cancelled."
        return 0
    fi
 
    is_vm_running "$vm_name" && { stop_vm "$vm_name"; sleep 1; }
    rm -f "$IMG_FILE" "$SEED_FILE" "$VM_DIR/$vm_name.conf" "${IMG_FILE}.lock" 2>/dev/null
    print_status SUCCESS "VM '$vm_name' deleted permanently."
}
 
# ─── EDIT VM CONFIG ──────────────────────────────────────────
edit_vm_config() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
    local changed=false
 
    while true; do
        echo
        echo -e "  ${C}${BLD}✏️   EDIT VM: $vm_name${N}"
        divider "─" "$D"
        echo -e "   ${C}1)${N} Hostname       ${D}[$HOSTNAME]${N}"
        echo -e "   ${C}2)${N} Username       ${D}[$USERNAME]${N}"
        echo -e "   ${C}3)${N} Password       ${D}[****]${N}"
        echo -e "   ${C}4)${N} SSH Port       ${D}[$SSH_PORT]${N}"
        echo -e "   ${C}5)${N} GUI Mode       ${D}[$GUI_MODE]${N}"
        echo -e "   ${C}6)${N} Port Forwards  ${D}[${PORT_FORWARDS:-None}]${N}"
        echo -e "   ${C}7)${N} Memory (MB)    ${D}[$MEMORY]${N}"
        echo -e "   ${C}8)${N} CPU Count      ${D}[$CPUS]${N}"
        echo -e "   ${C}9)${N} Disk Size      ${D}[$DISK_SIZE]${N}"
        echo -e "   ${R}0)${N} Back"
        echo
        print_status INPUT "Choice: "; read -r ec
 
        case $ec in
            1) while true; do print_status INPUT "New hostname [$HOSTNAME]: "; read -r v; v="${v:-$HOSTNAME}"; validate_input name "$v" && HOSTNAME="$v" && break; done; changed=true ;;
            2) while true; do print_status INPUT "New username [$USERNAME]: "; read -r v; v="${v:-$USERNAME}"; validate_input username "$v" && USERNAME="$v" && break; done; changed=true ;;
            3) while true; do print_status INPUT "New password: "; read -rs v; echo; [[ -n "$v" ]] && PASSWORD="$v" && break || print_status ERROR "Cannot be empty."; done; changed=true ;;
            4) while true; do print_status INPUT "New SSH port [$SSH_PORT]: "; read -r v; v="${v:-$SSH_PORT}"; validate_input port "$v" && SSH_PORT="$v" && break; done; changed=true ;;
            5) print_status INPUT "GUI mode? [y/N]: "; read -r v; [[ "$v" =~ ^[Yy]$ ]] && GUI_MODE=true || GUI_MODE=false; changed=true ;;
            6) print_status INPUT "Port forwards [${PORT_FORWARDS:-None}]: "; read -r v; PORT_FORWARDS="${v:-$PORT_FORWARDS}"; changed=true ;;
            7) while true; do print_status INPUT "Memory MB [$MEMORY]: "; read -r v; v="${v:-$MEMORY}"; validate_input number "$v" && MEMORY="$v" && break; done; changed=true ;;
            8) while true; do print_status INPUT "CPU count [$CPUS]: "; read -r v; v="${v:-$CPUS}"; validate_input number "$v" && CPUS="$v" && break; done; changed=true ;;
            9) while true; do print_status INPUT "Disk size [$DISK_SIZE]: "; read -r v; v="${v:-$DISK_SIZE}"; validate_input size "$v" && DISK_SIZE="$v" && break; done; changed=true ;;
            0) break ;;
            *) print_status ERROR "Invalid option." ;;
        esac
 
        if $changed; then
            save_vm_config
            # If creds/hostname changed, rebuild seed
            [[ "$ec" =~ ^[123]$ ]] && setup_vm_image
            changed=false
        fi
    done
}
 
# ─── RESIZE DISK ─────────────────────────────────────────────
resize_vm_disk() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
    is_vm_running "$vm_name" && { print_status ERROR "Stop the VM before resizing."; return 1; }
 
    print_status INFO "Current disk size: $DISK_SIZE"
    while true; do
        print_status INPUT "New disk size (e.g. 50G): "; read -r ns
        validate_input size "$ns" || continue
        print_status STEP "Resizing $IMG_FILE → $ns..."
        if qemu-img resize "$IMG_FILE" "$ns"; then
            DISK_SIZE="$ns"; save_vm_config
            print_status SUCCESS "Resized to $ns"
        else
            print_status ERROR "Resize failed."
        fi
        break
    done
}
 
# ─── PERFORMANCE STATS ───────────────────────────────────────
show_vm_performance() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    echo
    divider "─" "$C"
    echo -e "  ${C}${BLD}📊  PERFORMANCE: $vm_name${N}"
    divider "─" "$D"
 
    if is_vm_running "$vm_name"; then
        local pid
        pid=$(pgrep -f "qemu-system.*$(basename "$IMG_FILE")" | head -1)
        if [[ -n "$pid" ]]; then
            echo -e "  ${Y}QEMU PID : ${C}$pid${N}"
            local cpu_mem
            cpu_mem=$(ps -p "$pid" -o %cpu,%mem --no-headers 2>/dev/null | xargs)
            echo -e "  ${Y}CPU/MEM  : ${C}$cpu_mem${N}"
            echo
            echo -e "  ${Y}System Memory:${N}"
            free -h | sed 's/^/    /'
            echo
            echo -e "  ${Y}Image Size on Disk:${N}"
            du -sh "$IMG_FILE" 2>/dev/null | sed 's/^/    /'
        fi
    else
        echo -e "  ${D}VM is not running.${N}"
        echo -e "  Config: ${MEMORY}MB RAM | $CPUS vCPUs | $DISK_SIZE disk"
    fi
    divider "─" "$D"
    echo
    print_status INPUT "Press Enter to continue..."; read -r
}
 
# ─── FIX VM ISSUES ───────────────────────────────────────────
fix_vm_issues() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    echo
    echo -e "  ${C}${BLD}🔧  FIX VM ISSUES: $vm_name${N}"
    divider "─" "$D"
    echo -e "   ${C}1)${N} Remove lock files"
    echo -e "   ${C}2)${N} Recreate seed image"
    echo -e "   ${C}3)${N} Recreate config file"
    echo -e "   ${C}4)${N} Force-kill stuck QEMU processes"
    echo -e "   ${C}5)${N} Verify image integrity"
    echo -e "   ${R}0)${N} Back"
    echo
    print_status INPUT "Choice: "; read -r fc
 
    case $fc in
        1) rm -f "${IMG_FILE}.lock" "${IMG_FILE}"*.lock 2>/dev/null; print_status SUCCESS "Lock files removed." ;;
        2) rm -f "$SEED_FILE"; setup_vm_image ;;
        3) save_vm_config ;;
        4)
            pkill -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null; sleep 1
            pgrep -f "qemu-system.*$(basename "$IMG_FILE")" &>/dev/null \
                && pkill -9 -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null \
                && print_status SUCCESS "Force-killed." \
                || print_status INFO "No stuck processes found."
            ;;
        5)
            print_status STEP "Running qemu-img check..."
            qemu-img check "$IMG_FILE" && print_status SUCCESS "Image OK." || print_status ERROR "Image may be corrupted."
            ;;
        0) return ;;
        *) print_status ERROR "Invalid option." ;;
    esac
    print_status INPUT "Press Enter to continue..."; read -r
}
 

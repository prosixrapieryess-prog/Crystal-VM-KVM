        [[ "$gui_in" =~ ^[Yy]$ ]] && { GUI_MODE=true;  break; }
        [[ "$gui_in" =~ ^[Nn]$ ]] && { GUI_MODE=false; break; }
        print_status "ERROR" "Please answer y or n"

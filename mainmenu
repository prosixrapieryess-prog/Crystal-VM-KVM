            8) (( vm_count > 0 )) && { select_vm "Select VM to edit"  "${vms[@]}" && edit_vm_config "$SELECTED_VM"; } ;;
            9) (( vm_count > 0 )) && { select_vm "Select VM to delete" "${vms[@]}" && delete_vm "$SELECTED_VM"; } ;;
            10) (( vm_count > 0 )) && { select_vm "Select VM to resize" "${vms[@]}" && resize_vm_disk "$SELECTED_VM"; } ;;
            11) (( vm_count > 0 )) && { select_vm "Select VM for stats" "${vms[@]}" && show_vm_performance "$SELECTED_VM"; } ;;
            12) (( vm_count > 0 )) && { select_vm "Select VM to fix"   "${vms[@]}" && fix_vm_issues "$SELECTED_VM"; } ;;

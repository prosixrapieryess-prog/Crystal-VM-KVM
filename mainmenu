EOF
    print_status "SUCCESS" "Config saved → $VM_DIR/$VM_NAME.conf"
}
 
# ═══════════════════════════════════════════════════════════════
#  SHARED — IS VM RUNNING
# ═══════════════════════════════════════════════════════════════
 
is_vm_running() {
    local name=$1
    pgrep -f "qemu-system.*${name}" >/dev/null 2>&1 && return 0
    if load_vm_config "$name" 2>/dev/null && [[ -n "${IMG_FILE:-}" ]]; then
        pgrep -f "qemu-system.*${IMG_FILE}" >/dev/null 2>&1 && return 0
    fi
    return 1
}
 
# ═══════════════════════════════════════════════════════════════
#  MAIN MENU — IMAGE LOCK, SETUP, VM LIFECYCLE
# ═══════════════════════════════════════════════════════════════
 
check_image_lock() {
    local img_file=$1; local vm_name=$2
    if lsof "$img_file" 2>/dev/null | grep -q qemu-system; then
        local pid; pid=$(lsof "$img_file" 2>/dev/null | awk '/qemu-system/{print $2; exit}')
        print_status "WARN" "Image locked by PID $pid"
        read -p "  $(print_status "INPUT" "Kill that process and retry? (y/N): ")" k
        if [[ "$k" =~ ^[Yy]$ ]]; then
            kill "$pid" 2>/dev/null; sleep 2; kill -9 "$pid" 2>/dev/null; return 0
        fi
        return 1
    fi
    local lock="${img_file}.lock"
    if [[ -f "$lock" ]]; then
        print_status "WARN" "Lock file found: $lock"
        if find "$lock" -mmin +5 &>/dev/null; then
            read -p "  $(print_status "INPUT" "Stale lock (>5 min), remove it? (y/N): ")" r
            [[ "$r" =~ ^[Yy]$ ]] && { rm -f "$lock"; return 0; }
        fi
        return 1
    fi
    return 0
}
 
setup_vm_image() {
    print_status "INFO" "Preparing image for: $VM_NAME"
    mkdir -p "$VM_DIR"
    if [[ -f "$IMG_FILE" ]]; then
        print_status "INFO" "Image exists — skipping download"
    else
        print_status "INFO" "Downloading: $IMG_URL"
        wget --progress=bar:force "$IMG_URL" -O "${IMG_FILE}.tmp" || {
            print_status "ERROR" "Download failed."; exit 1
        }
        mv "${IMG_FILE}.tmp" "$IMG_FILE"
        print_status "SUCCESS" "Download complete"
    fi
    qemu-img resize "$IMG_FILE" "$DISK_SIZE" 2>/dev/null || {
        print_status "WARN" "In-place resize failed — creating fresh qcow2..."
        qemu-img create -f qcow2 "$IMG_FILE" "$DISK_SIZE"
    }
    cat > user-data <<EOF
#cloud-config
hostname: $HOSTNAME
ssh_pwauth: true
disable_root: false
users:
  - name: $USERNAME
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    password: $(openssl passwd -6 "$PASSWORD" | tr -d '\n')
chpasswd:
  list: |
    root:$PASSWORD
    $USERNAME:$PASSWORD
  expire: false
EOF
    cat > meta-data <<EOF
instance-id: iid-$VM_NAME
local-hostname: $HOSTNAME
EOF
    cloud-localds "$SEED_FILE" user-data meta-data || {
        print_status "ERROR" "Failed to create cloud-init seed ISO"; exit 1
    }
    echo
    print_status "SUCCESS" "VM '${VM_NAME}' is ready!"
    print_status "INFO"    "Login  →  user: ${USERNAME}  |  pass: ${PASSWORD}"
    print_status "INFO"    "SSH    →  ssh -p ${SSH_PORT} ${USERNAME}@localhost"
}
 
stop_vm() {
    local name=$1; load_vm_config "$name" || return 1
    if is_vm_running "$name"; then
        print_status "INFO" "Sending shutdown to: $name"
        pkill -f "qemu-system.*${IMG_FILE}" 2>/dev/null; sleep 2
        if is_vm_running "$name"; then
            print_status "WARN" "Graceful stop failed — force killing..."
            pkill -9 -f "qemu-system.*${IMG_FILE}" 2>/dev/null
        fi
        rm -f "${IMG_FILE}.lock" 2>/dev/null
        is_vm_running "$name" && { print_status "ERROR" "Could not stop VM $name"; return 1; }
        print_status "SUCCESS" "VM '$name' stopped"
    else
        print_status "INFO" "VM '$name' is not running"
        rm -f "${IMG_FILE}.lock" 2>/dev/null
    fi
}
 
start_vm() {
    local name=$1; load_vm_config "$name" || return 1
    if ! check_image_lock "$IMG_FILE" "$name"; then
        read -p "  $(print_status "INPUT" "Force-kill all QEMU on this image? (y/N): ")" fk
        if [[ "$fk" =~ ^[Yy]$ ]]; then
            pkill    -f "qemu-system.*${IMG_FILE}" 2>/dev/null; sleep 2
            pkill -9 -f "qemu-system.*${IMG_FILE}" 2>/dev/null
            rm -f "${IMG_FILE}.lock" 2>/dev/null
        else return 1; fi
    fi
    if is_vm_running "$name"; then
        print_status "WARN" "VM '$name' is already running"
        read -p "  $(print_status "INPUT" "Stop and restart? (y/N): ")" rc
        [[ "$rc" =~ ^[Yy]$ ]] && { stop_vm "$name"; sleep 2; } || return 1
    fi
    [[ ! -f "$IMG_FILE" ]]  && { print_status "ERROR" "Image missing: $IMG_FILE"; return 1; }
    [[ ! -f "$SEED_FILE" ]] && { print_status "WARN" "Seed ISO missing — rebuilding..."; setup_vm_image; }
    echo
    print_status "INFO" "🚀 Starting VM: $name"
    print_status "INFO" "SSH  →  ssh -p $SSH_PORT $USERNAME@localhost"
    print_status "INFO" "Pass →  $PASSWORD"
    print_status "INFO" "Mode →  TCG software emulation"
    echo
    local qemu_cmd=(
        qemu-system-x86_64 -m "$MEMORY" -smp "$CPUS" -cpu qemu64
        -machine type=pc,accel=tcg
        -drive "file=$IMG_FILE,format=qcow2,if=virtio"
        -drive "file=$SEED_FILE,format=raw,if=virtio"
        -boot order=c
        -device virtio-net-pci,netdev=net0
        -netdev "user,id=net0,hostfwd=tcp::${SSH_PORT}-:22"
        -device virtio-balloon-pci
        -object rng-random,filename=/dev/urandom,id=rng0
        -device virtio-rng-pci,rng=rng0
        -no-hpet -rtc base=utc,clock=host
    )
    if [[ -n "${PORT_FORWARDS:-}" ]]; then
        local netid=1
        IFS=',' read -ra fwds <<< "$PORT_FORWARDS"
        for fwd in "${fwds[@]}"; do
            IFS=':' read -r hport gport <<< "$fwd"
            qemu_cmd+=(-device "virtio-net-pci,netdev=net${netid}")
            qemu_cmd+=(-netdev  "user,id=net${netid},hostfwd=tcp::${hport}-:${gport}")
            ((netid++))
        done
    fi
    if [[ "$GUI_MODE" == true ]]; then
        qemu_cmd+=(-vga virtio -display gtk,gl=on)
        print_status "INFO" "GUI window opening..."
    else
        qemu_cmd+=(-nographic -serial mon:stdio)
        print_status "INFO" "Console mode — Ctrl+A then X to quit QEMU"
    fi
    echo -e "  ${DIM}${MEMORY}MB RAM  │  ${CPUS} vCPU(s)  │  ${DISK_SIZE} disk${N}"; echo
    "${qemu_cmd[@]}" || {
        print_status "ERROR" "QEMU exited with an error"
        rm -f "${IMG_FILE}.lock" 2>/dev/null; return 1
    }
    print_status "INFO" "VM '$name' has shut down"
}
 

}
 
# ─── KVM CHECK ───────────────────────────────────────────────
kvm_available() {
    [[ -e /dev/kvm ]] && [[ -r /dev/kvm ]] && [[ -w /dev/kvm ]]
}
 
kvm_status_msg() {
    if kvm_available; then
        echo -e "${G}KVM${N}"
    else
        echo -e "${Y}TCG (software emulation)${N}"
    fi
}
 
# ─── AUTO-INSTALL DEPENDENCIES ───────────────────────────────
install_deps_if_missing() {
    local pkgs_apt=()
    local needs_install=false
 
    # Map: command → package name
    declare -A CMD_PKG=(
        ["qemu-system-x86_64"]="qemu-system-x86"
        ["qemu-img"]="qemu-utils"
        ["cloud-localds"]="cloud-image-utils"
        ["wget"]="wget"
        ["lsof"]="lsof"
        ["openssl"]="openssl"
    )
 
    for cmd in "${!CMD_PKG[@]}"; do
        if ! command -v "$cmd" &>/dev/null; then
            pkgs_apt+=("${CMD_PKG[$cmd]}")
            needs_install=true
        fi
    done
 
    if $needs_install; then
        # Deduplicate
        local unique_pkgs=($(printf '%s\n' "${pkgs_apt[@]}" | sort -u))
        print_status WARN "Missing dependencies detected."
        print_status STEP "Installing: ${unique_pkgs[*]}"
        echo
 
        if command -v apt-get &>/dev/null; then
            sudo apt-get update -qq 2>/dev/null
            sudo apt-get install -y "${unique_pkgs[@]}" 2>&1 | grep -E "(Installing|Unpacking|Setting up|Error)" || true
        elif command -v dnf &>/dev/null; then
            sudo dnf install -y qemu-system-x86_64 qemu-img cloud-utils wget lsof openssl 2>&1 | tail -5
        elif command -v yum &>/dev/null; then
            sudo yum install -y qemu-kvm qemu-img cloud-utils wget lsof openssl 2>&1 | tail -5
        else
            print_status ERROR "No supported package manager found. Please install manually:"
            print_status INFO  "  sudo apt install qemu-system-x86 qemu-utils cloud-image-utils wget lsof openssl"
            exit 1
        fi
 
        echo
        # Re-verify
        local still_missing=()
        for cmd in "${!CMD_PKG[@]}"; do
            command -v "$cmd" &>/dev/null || still_missing+=("$cmd")
        done
 
        if [[ ${#still_missing[@]} -gt 0 ]]; then
            print_status ERROR "Still missing after install: ${still_missing[*]}"
            print_status INFO  "Try manually: sudo apt install qemu-system-x86 qemu-utils cloud-image-utils lsof openssl wget"
            exit 1
        fi
 
        print_status SUCCESS "All dependencies installed successfully!"
        sleep 1
    fi
}
 
# ─── VALIDATE INPUT ──────────────────────────────────────────
validate_input() {
    local type=$1 value=$2
    case $type in
        number) [[ "$value" =~ ^[0-9]+$ ]] || { print_status ERROR "Must be a number."; return 1; } ;;
        size)   [[ "$value" =~ ^[0-9]+[GgMm]$ ]] || { print_status ERROR "Must include unit (e.g. 20G, 512M)."; return 1; } ;;
        port)
            [[ "$value" =~ ^[0-9]+$ ]] && [ "$value" -ge 23 ] && [ "$value" -le 65535 ] \
                || { print_status ERROR "Port must be between 23 and 65535."; return 1; }
            ;;
        name)     [[ "$value" =~ ^[a-zA-Z0-9_-]+$ ]] || { print_status ERROR "Only letters, numbers, hyphens, underscores."; return 1; } ;;
        username) [[ "$value" =~ ^[a-z_][a-z0-9_-]*$ ]] || { print_status ERROR "Must start with letter/underscore, lowercase."; return 1; } ;;
    esac
    return 0
}
 
# ─── VM LIST ─────────────────────────────────────────────────
get_vm_list() {
    find "$VM_DIR" -maxdepth 1 -name "*.conf" -exec basename {} .conf \; 2>/dev/null | sort
}
 
# ─── LOAD / SAVE CONFIG ──────────────────────────────────────
load_vm_config() {
    local vm_name=$1
    local cfg="$VM_DIR/$vm_name.conf"
    if [[ -f "$cfg" ]]; then
        unset VM_NAME OS_TYPE CODENAME IMG_URL HOSTNAME USERNAME PASSWORD
        unset DISK_SIZE MEMORY CPUS SSH_PORT GUI_MODE PORT_FORWARDS IMG_FILE SEED_FILE CREATED
        source "$cfg"
        return 0
    fi
    print_status ERROR "Config for VM '$vm_name' not found."
    return 1
}
 
save_vm_config() {
    mkdir -p "$VM_DIR"
    local cfg="$VM_DIR/$VM_NAME.conf"
    cat > "$cfg" <<EOF
VM_NAME="$VM_NAME"
OS_TYPE="$OS_TYPE"
CODENAME="$CODENAME"
IMG_URL="$IMG_URL"
HOSTNAME="$HOSTNAME"
USERNAME="$USERNAME"
PASSWORD="$PASSWORD"
DISK_SIZE="$DISK_SIZE"
MEMORY="$MEMORY"
CPUS="$CPUS"
SSH_PORT="$SSH_PORT"
GUI_MODE="$GUI_MODE"
PORT_FORWARDS="$PORT_FORWARDS"
IMG_FILE="$IMG_FILE"
SEED_FILE="$SEED_FILE"
CREATED="$CREATED"
EOF
    print_status SUCCESS "Configuration saved → $cfg"
    log "Saved config for $VM_NAME"
}
 
# ─── IMAGE LOCK CHECK ────────────────────────────────────────
check_image_lock() {
    local img_file=$1 vm_name=$2
    if lsof "$img_file" 2>/dev/null | grep -q qemu-system; then
        local pid
        pid=$(lsof "$img_file" 2>/dev/null | awk '/qemu-system/{print $2}' | head -1)
        print_status WARN "Image locked by PID $pid"
        print_status INPUT "Kill existing process and retry? [y/N]: "
        read -r ans
        if [[ "$ans" =~ ^[Yy]$ ]]; then
            kill "$pid" 2>/dev/null; sleep 2
            kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
            return 0
        fi
        return 1
    fi
    local lock="${img_file}.lock"
    if [[ -f "$lock" ]]; then
        if find "$lock" -mmin +5 &>/dev/null; then
            print_status WARN "Stale lock file found. Removing..."
            rm -f "$lock"
        else
            print_status ERROR "Image is locked: $lock"
            return 1
        fi
    fi
    return 0
}
 
# ─── IS VM RUNNING ───────────────────────────────────────────
is_vm_running() {
    local vm_name=$1
    pgrep -f "qemu-system.*$vm_name" &>/dev/null && return 0
    load_vm_config "$vm_name" &>/dev/null
    [[ -n "$IMG_FILE" ]] && pgrep -f "qemu-system.*$(basename "$IMG_FILE")" &>/dev/null
}
 
# ─── CLEANUP ─────────────────────────────────────────────────
cleanup() {
    rm -f user-data meta-data 2>/dev/null
}
trap cleanup EXIT
 
# ─── SPINNER ─────────────────────────────────────────────────
spinner_start() {
    local msg="${1:-Working...}"
    (
        local chars='⣾⣽⣻⢿⡿⣟⣯⣷'
        while true; do
            for ((i=0;i<${#chars};i++)); do
                printf "\r ${C}${chars:$i:1}${N}  %s   " "$msg"
                sleep 0.08
            done
        done
    ) &
    SPINNER_PID=$!
    disown "$SPINNER_PID"
}
 
spinner_stop() {
    kill "$SPINNER_PID" 2>/dev/null
    printf "\r%60s\r" ""
}
 
# ─── PROGRESS BAR ────────────────────────────────────────────
progress_bar() {
    local current=$1 total=$2 label="${3:-Progress}"
    local width=40
    local filled=$(( current * width / total ))
    local empty=$(( width - filled ))
    printf "\r  ${C}%-12s${N} [${G}%s${D}%s${N}] ${W}%d%%${N}" \
        "$label" \
        "$(printf '█%.0s' $(seq 1 $filled))" \
        "$(printf '░%.0s' $(seq 1 $empty))" \
        $(( current * 100 / total ))
}
 
# ─── SETUP VM IMAGE ──────────────────────────────────────────
setup_vm_image() {
    print_status STEP "Preparing VM image for '$VM_NAME'..."
    mkdir -p "$VM_DIR"
 
    if [[ ! -f "$IMG_FILE" ]]; then
        print_status INFO "Downloading OS image..."
        print_status INFO "URL: $IMG_URL"
        echo
        if ! wget --progress=bar:force:noscroll "$IMG_URL" -O "${IMG_FILE}.tmp" 2>&1; then
            rm -f "${IMG_FILE}.tmp"
            print_status ERROR "Download failed. Check URL or network."
            return 1
        fi
        mv "${IMG_FILE}.tmp" "$IMG_FILE"
        print_status SUCCESS "Image downloaded successfully."
    else
        print_status INFO "Existing image found, skipping download."
    fi
 
    # Resize disk
    print_status STEP "Resizing disk to $DISK_SIZE..."
    if ! qemu-img resize "$IMG_FILE" "$DISK_SIZE" &>/dev/null; then
        print_status WARN "Inline resize failed. Creating backed image..."
        local tmp="${IMG_FILE}.new"
        qemu-img create -f qcow2 -F qcow2 -b "$IMG_FILE" "$tmp" "$DISK_SIZE" &>/dev/null \
            || qemu-img create -f qcow2 "$tmp" "$DISK_SIZE" &>/dev/null
        [[ -f "$tmp" ]] && mv "$tmp" "$IMG_FILE"
    fi
    print_status SUCCESS "Disk sized to $DISK_SIZE."
 
    # cloud-init
    print_status STEP "Writing cloud-init configuration..."
    local hashed_pw
    hashed_pw=$(openssl passwd -6 "$PASSWORD" 2>/dev/null || echo "$PASSWORD")
 
    cat > user-data <<EOF
#cloud-config
hostname: $HOSTNAME
manage_etc_hosts: true
ssh_pwauth: true
disable_root: false
users:
  - name: $USERNAME
    gecos: VM User
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    passwd: $hashed_pw
  - name: root
    lock_passwd: false
    passwd: $hashed_pw
chpasswd:
  list: |
    root:$PASSWORD
    $USERNAME:$PASSWORD
  expire: false
package_update: false
runcmd:
  - sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
  - sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
  - systemctl restart sshd 2>/dev/null || service ssh restart 2>/dev/null || true
EOF
 
    cat > meta-data <<EOF
instance-id: iid-${VM_NAME}-$(date +%s)
local-hostname: $HOSTNAME
EOF
 
    if ! cloud-localds "$SEED_FILE" user-data meta-data 2>/dev/null; then
        print_status ERROR "Failed to create seed ISO. Is cloud-image-utils installed?"
        return 1
    fi
 
    print_status SUCCESS "cloud-init seed image created."
    echo
    divider "─" "$G"
    echo -e "  ${G}${BLD}VM Created Successfully!${N}"
    echo -e "  ${W}SSH :${N}  ssh -p ${C}$SSH_PORT${N} ${C}$USERNAME${N}@localhost"
    echo -e "  ${W}Pass:${N}  ${C}$PASSWORD${N}"
    divider "─" "$G"
    echo
}
 
# ─── CREATE NEW VM ───────────────────────────────────────────
create_new_vm() {
    print_header
    echo -e "  ${C}${BLD}➕  CREATE NEW VIRTUAL MACHINE${N}"
    divider "─" "$D"
    echo
 
    # OS Selection
    local os_names=()
    local i=1
    for os in "${!OS_OPTIONS[@]}"; do
        os_names+=("$os")
    done
    # Sort for consistent display
    IFS=$'\n' os_names=($(sort <<<"${os_names[*]}")); unset IFS
 
    echo -e "  ${Y}${BLD}Select Operating System:${N}"
    echo
    for i in "${!os_names[@]}"; do
        printf "    ${C}%2d)${N}  %s\n" $((i+1)) "${os_names[$i]}"
    done
    echo
 
    local choice os
    while true; do
        print_status INPUT "Your choice [1-${#os_names[@]}]: "; read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#os_names[@]} )); then
            os="${os_names[$((choice-1))]}"
            IFS='|' read -r OS_TYPE CODENAME IMG_URL DEFAULT_HOSTNAME DEFAULT_USERNAME DEFAULT_PASSWORD <<< "${OS_OPTIONS[$os]}"
            print_status SUCCESS "Selected: $os"
            break
        fi
        print_status ERROR "Invalid. Try again."
    done
    echo
 
    # VM Name
    while true; do
        print_status INPUT "VM Name [default: $DEFAULT_HOSTNAME]: "; read -r VM_NAME
        VM_NAME="${VM_NAME:-$DEFAULT_HOSTNAME}"
        validate_input name "$VM_NAME" || continue
        [[ -f "$VM_DIR/$VM_NAME.conf" ]] && { print_status ERROR "VM '$VM_NAME' already exists."; continue; }
        break
    done
 
    # Hostname
    while true; do
        print_status INPUT "Hostname [default: $VM_NAME]: "; read -r HOSTNAME
        HOSTNAME="${HOSTNAME:-$VM_NAME}"
        validate_input name "$HOSTNAME" && break
    done
 
    # Username
    while true; do
        print_status INPUT "Username [default: $DEFAULT_USERNAME]: "; read -r USERNAME
        USERNAME="${USERNAME:-$DEFAULT_USERNAME}"
        validate_input username "$USERNAME" && break
    done
 
    # Password
    while true; do
        print_status INPUT "Password [default: $DEFAULT_PASSWORD]: "; read -rs PASSWORD; echo
        PASSWORD="${PASSWORD:-$DEFAULT_PASSWORD}"
        [[ -n "$PASSWORD" ]] && break
        print_status ERROR "Password cannot be empty."
    done
 
    # Disk Size
    while true; do
        print_status INPUT "Disk Size [default: 20G]: "; read -r DISK_SIZE
        DISK_SIZE="${DISK_SIZE:-20G}"
        validate_input size "$DISK_SIZE" && break
    done
 
    # Memory
    while true; do
        print_status INPUT "Memory MB [default: 2048]: "; read -r MEMORY
        MEMORY="${MEMORY:-2048}"
        validate_input number "$MEMORY" && break
    done
 
    # CPUs
    while true; do
        print_status INPUT "CPU Count [default: 2]: "; read -r CPUS
        CPUS="${CPUS:-2}"
        validate_input number "$CPUS" && break
    done
 
    # SSH Port
    while true; do
        print_status INPUT "SSH Port [default: 2222]: "; read -r SSH_PORT
        SSH_PORT="${SSH_PORT:-2222}"
        validate_input port "$SSH_PORT" || continue
        if ss -tln 2>/dev/null | grep -q ":$SSH_PORT "; then
            print_status ERROR "Port $SSH_PORT is already in use."
            continue
        fi
        break
    done
 
    # GUI Mode
    while true; do
        print_status INPUT "Enable GUI display? [y/N]: "; read -r gui_in
        gui_in="${gui_in:-n}"
        if [[ "$gui_in" =~ ^[Yy]$ ]]; then GUI_MODE=true; break
        elif [[ "$gui_in" =~ ^[Nn]$ ]]; then GUI_MODE=false; break
        fi
        print_status ERROR "Enter y or n."
    done
 
    # Extra port forwards
    print_status INPUT "Extra port forwards (e.g. 8080:80,3306:3306) [Enter for none]: "; read -r PORT_FORWARDS
 
    IMG_FILE="$VM_DIR/$VM_NAME.img"
    SEED_FILE="$VM_DIR/$VM_NAME-seed.iso"
    CREATED="$(date)"
 
    echo
    setup_vm_image && save_vm_config
    print_status INPUT "Press Enter to continue..."; read -r
}
 
# ─── BUILD QEMU COMMAND ──────────────────────────────────────
build_qemu_cmd() {
    local kvm_flags=()
    if kvm_available; then
        kvm_flags=(-enable-kvm -cpu host)
        print_status KVM "KVM acceleration ENABLED — full native speed!"
    else
        kvm_flags=(-machine type=pc,accel=tcg -cpu qemu64)
        print_status WARN "KVM not available — running in software emulation (TCG)."
        print_status INFO "For KVM: sudo modprobe kvm_intel (or kvm_amd) and check /dev/kvm"
    fi
 
    QEMU_CMD=(
        qemu-system-x86_64
        "${kvm_flags[@]}"
        -m "$MEMORY"
        -smp "$CPUS"
        -drive "file=$IMG_FILE,format=qcow2,if=virtio,cache=writeback,aio=threads"
        -drive "file=$SEED_FILE,format=raw,if=virtio"
        -boot order=c,strict=on
        -device virtio-net-pci,netdev=net0,mac=52:54:00:$(printf '%02x:%02x:%02x' $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)))
        -netdev "user,id=net0,hostfwd=tcp::${SSH_PORT}-:22"
        -device virtio-balloon-pci
        -object "rng-random,filename=/dev/urandom,id=rng0"
        -device virtio-rng-pci,rng=rng0
        -no-hpet
        -rtc base=utc,clock=host
        -name "$VM_NAME"
    )
 
    # Extra port forwards
    if [[ -n "$PORT_FORWARDS" ]]; then
        IFS=',' read -ra fwds <<< "$PORT_FORWARDS"
        local fwd_str="user,id=fwd0"
        for fwd in "${fwds[@]}"; do
            IFS=':' read -r hp gp <<< "$fwd"
            fwd_str+=",hostfwd=tcp::${hp}-:${gp}"
        done
        QEMU_CMD+=(-netdev "$fwd_str" -device virtio-net-pci,netdev=fwd0)
    fi
 
    if [[ "$GUI_MODE" == true ]]; then
        QEMU_CMD+=(-vga virtio -display gtk)
    else
        QEMU_CMD+=(-nographic -serial mon:stdio)
    fi
}
 
# ─── START VM ────────────────────────────────────────────────
start_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    if ! check_image_lock "$IMG_FILE" "$vm_name"; then
        print_status ERROR "Cannot start — image locked."
        print_status INPUT "Force-kill all QEMU on this image? [y/N]: "; read -r fk
        if [[ "$fk" =~ ^[Yy]$ ]]; then
            pkill -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null; sleep 2
            pkill -9 -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null
            rm -f "${IMG_FILE}.lock"
        else
            return 1
        fi
    fi
 
    if is_vm_running "$vm_name"; then
        print_status WARN "VM '$vm_name' is already running."
        print_status INPUT "Stop and restart? [y/N]: "; read -r rc
        [[ "$rc" =~ ^[Yy]$ ]] && { stop_vm "$vm_name"; sleep 2; } || return 1
    fi
 
    [[ ! -f "$IMG_FILE" ]]  && { print_status ERROR "Image not found: $IMG_FILE"; return 1; }
    [[ ! -f "$SEED_FILE" ]] && { print_status WARN "Seed missing, recreating..."; setup_vm_image; }
 
    echo
    divider "─" "$C"
    echo -e "  ${C}${BLD}⚡  STARTING VM: $vm_name${N}"
    divider "─" "$C"
    echo -e "  ${W}Mode  :${N} $(kvm_status_msg)"
    echo -e "  ${W}RAM   :${N} ${C}${MEMORY}MB${N}   ${W}CPUs:${N} ${C}${CPUS}${N}   ${W}Disk:${N} ${C}${DISK_SIZE}${N}"
    echo -e "  ${W}SSH   :${N} ${G}ssh -p $SSH_PORT $USERNAME@localhost${N}"
    echo -e "  ${W}Pass  :${N} ${G}$PASSWORD${N}"
    [[ "$GUI_MODE" != true ]] && echo -e "  ${D}Tip: Press Ctrl+A then X to exit QEMU console${N}"
    divider "─" "$C"
    echo
 
    build_qemu_cmd
 
    "${QEMU_CMD[@]}" || {
        print_status ERROR "QEMU exited with error."
        rm -f "${IMG_FILE}.lock" 2>/dev/null
        return 1
    }
 
    print_status INFO "VM '$vm_name' shut down."
    rm -f "${IMG_FILE}.lock" 2>/dev/null
}
 
# ─── STOP VM ─────────────────────────────────────────────────
stop_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
 
    if is_vm_running "$vm_name"; then
        print_status INFO "Sending shutdown signal to '$vm_name'..."
        pkill -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null
        sleep 2
        if is_vm_running "$vm_name"; then
            print_status WARN "Force-killing..."
            pkill -9 -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null
        fi
        rm -f "${IMG_FILE}.lock" 2>/dev/null
        is_vm_running "$vm_name" \
            && print_status ERROR "Failed to stop VM." \
            || print_status SUCCESS "VM '$vm_name' stopped."
    else
        print_status INFO "VM '$vm_name' is already stopped."
        rm -f "${IMG_FILE}.lock" 2>/dev/null
    fi
}
 

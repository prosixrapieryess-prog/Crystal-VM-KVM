# ══════════════════════════════════════════════════════
#  HEADER
# ══════════════════════════════════════════════════════
print_header() {
    clear
    print_logo
    local kvm_line
    if kvm_ok; then
        kvm_line="${G}${BLD}⚡ KVM : ENABLED${N}"
    else
        kvm_line="${Y}${BLD}KVM : DISABLED  (TCG software mode)${N}"
    fi
    echo -e "   $kvm_line   ${DIM}|  v${VERSION}  |  $(date '+%a %d %b %Y  %H:%M')${N}"
    echo
    _line "-" "$DIM"
    echo
}
 
# ══════════════════════════════════════════════════════
#  KVM CHECK
# ══════════════════════════════════════════════════════
kvm_ok() { [[ -e /dev/kvm && -r /dev/kvm && -w /dev/kvm ]]; }
 
# ══════════════════════════════════════════════════════
#  DEPENDENCY AUTO-INSTALLER
# ══════════════════════════════════════════════════════
install_deps() {
    local NEED=( qemu-system-x86_64 qemu-img cloud-localds wget lsof openssl )
    local missing=()
    for cmd in "${NEED[@]}"; do command -v "$cmd" &>/dev/null || missing+=("$cmd"); done
    [[ ${#missing[@]} -eq 0 ]] && return 0
 
    warn "Missing tools: ${missing[*]}"
    echo
 
    local S=""; command -v sudo &>/dev/null && S="sudo"
 
    # Package name tables
    declare -A APT=( [qemu-system-x86_64]="qemu-system-x86" [qemu-img]="qemu-utils"
                     [cloud-localds]="cloud-image-utils" [wget]="wget" [lsof]="lsof" [openssl]="openssl" )
    declare -A APK=( [qemu-system-x86_64]="qemu-system-x86_64" [qemu-img]="qemu-img"
                     [cloud-localds]="cloud-utils" [wget]="wget" [lsof]="lsof" [openssl]="openssl" )
    declare -A DNF=( [qemu-system-x86_64]="qemu-system-x86_64" [qemu-img]="qemu-img"
                     [cloud-localds]="cloud-utils" [wget]="wget" [lsof]="lsof" [openssl]="openssl" )
    declare -A PAC=( [qemu-system-x86_64]="qemu-full" [qemu-img]="qemu-img"
                     [cloud-localds]="cloud-utils" [wget]="wget" [lsof]="lsof" [openssl]="openssl" )
    declare -A NIX=( [qemu-system-x86_64]="nixpkgs.qemu" [qemu-img]="nixpkgs.qemu"
                     [cloud-localds]="nixpkgs.cloud-utils" [wget]="nixpkgs.wget"
                     [lsof]="nixpkgs.lsof" [openssl]="nixpkgs.openssl" )
    declare -A TPKG=( [qemu-system-x86_64]="qemu-system-x86_64" [qemu-img]="qemu-utils"
                      [cloud-localds]="cloud-utils" [wget]="wget" [lsof]="lsof" [openssl]="openssl" )
 
    _pkgs() {
        local -n _t=$1; local out=()
        for c in "${missing[@]}"; do [[ -n "${_t[$c]:-}" ]] && out+=("${_t[$c]}"); done
        printf '%s\n' "${out[@]}" | sort -u
    }
 
    _try() {
        local pm=$1; shift; local pkgs=("$@")
        [[ ${#pkgs[@]} -eq 0 ]] && return 1
        step "[$pm] Installing: ${pkgs[*]}"
        case $pm in
            apt-get) $S apt-get -qq update 2>/dev/null; $S apt-get install -y "${pkgs[@]}" 2>&1 | grep -E "(Setting up|error)" || true ;;
            apt)     $S apt -qq update 2>/dev/null;     $S apt install -y "${pkgs[@]}" 2>&1     | grep -E "(Setting up|error)" || true ;;
            apk)     $S apk update -q 2>/dev/null;      $S apk add --no-cache "${pkgs[@]}" 2>&1 | tail -5 ;;
            pacman)  $S pacman -Sy --noconfirm "${pkgs[@]}" 2>&1 | tail -5 ;;
            zypper)  $S zypper --non-interactive install "${pkgs[@]}" 2>&1 | tail -5 ;;
            dnf)     $S dnf install -y "${pkgs[@]}" 2>&1 | tail -5 ;;
            yum)     $S yum install -y "${pkgs[@]}" 2>&1 | tail -5 ;;
            nix-env) nix-env -iA "${pkgs[@]}" 2>&1 | tail -5 ;;
            brew)    brew install "${pkgs[@]}" 2>&1 | tail -5 ;;
            pkg)     pkg update -y 2>/dev/null; pkg install -y "${pkgs[@]}" 2>&1 | tail -5 ;;
        esac
        missing=()
        for cmd in "${NEED[@]}"; do command -v "$cmd" &>/dev/null || missing+=("$cmd"); done
        [[ ${#missing[@]} -eq 0 ]]
    }
 
    local p=()
    mapfile -t p < <(_pkgs APT);  command -v apt-get &>/dev/null && _try apt-get "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs APT);  command -v apt     &>/dev/null && _try apt     "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs APK);  command -v apk     &>/dev/null && _try apk     "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs PAC);  command -v pacman  &>/dev/null && _try pacman  "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs DNF);  command -v zypper  &>/dev/null && _try zypper  "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs DNF);  command -v dnf     &>/dev/null && _try dnf     "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs DNF);  command -v yum     &>/dev/null && _try yum     "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs NIX);  command -v nix-env &>/dev/null && _try nix-env "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs APT);  command -v brew    &>/dev/null && _try brew    "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
    mapfile -t p < <(_pkgs TPKG); command -v pkg     &>/dev/null && _try pkg     "${p[@]}" && { ok "All dependencies ready!"; sleep 1; return 0; }
 
    echo
    _line "=" "$R"
    echo -e "  ${R}${BLD}  MANUAL INSTALL REQUIRED${N}"
    _line "-" "$DIM"
    echo -e "  ${W}Still missing:${N} ${R}${missing[*]}${N}"
    echo
    echo -e "  ${Y}Run the right command for your system:${N}"
    echo
    echo -e "  ${C}${BLD}Debian / Ubuntu / IDX:${N}"
    echo -e "  ${W}  sudo apt-get update && sudo apt-get install -y \\"
    echo -e "        qemu-system-x86 qemu-utils cloud-image-utils wget lsof openssl${N}"
    echo
    echo -e "  ${C}${BLD}IDX (use Option 2 first, then Rebuild Environment):${N}"
    echo -e "  ${W}  Select Option 2 → follow on-screen steps${N}"
    echo
    echo -e "  ${C}${BLD}Alpine:${N}  ${W}apk add qemu-system-x86_64 qemu-img cloud-utils wget lsof openssl${N}"
    echo -e "  ${C}${BLD}Arch:${N}    ${W}sudo pacman -Sy qemu-full cloud-utils wget lsof openssl${N}"
    echo -e "  ${C}${BLD}Fedora:${N}  ${W}sudo dnf install -y qemu-system-x86_64 qemu-img cloud-utils wget lsof openssl${N}"
    echo -e "  ${C}${BLD}NixOS:${N}   ${W}nix-shell -p qemu cloud-utils wget lsof openssl${N}"
    echo -e "  ${C}${BLD}Termux:${N}  ${W}pkg install qemu-system-x86_64 qemu-utils wget lsof openssl${N}"
    echo
    _line "=" "$R"
    echo
    ask "Press Enter to exit, then run the command above..."; read -r
    exit 1
}
 
# ══════════════════════════════════════════════════════
#  INPUT VALIDATION
# ══════════════════════════════════════════════════════
valid() {
    local type=$1 val=$2
    case $type in
        num)  [[ "$val" =~ ^[0-9]+$ ]] || { err "Must be a number."; return 1; } ;;
        size) [[ "$val" =~ ^[0-9]+[GgMm]$ ]] || { err "Must include unit: e.g. 20G or 512M."; return 1; } ;;
        port) [[ "$val" =~ ^[0-9]+$ ]] && (( val>=23 && val<=65535 )) || { err "Port must be 23-65535."; return 1; } ;;
        name) [[ "$val" =~ ^[a-zA-Z0-9_-]+$ ]] || { err "Only letters, numbers, - and _."; return 1; } ;;
        user) [[ "$val" =~ ^[a-z_][a-z0-9_-]*$ ]] || { err "Start with lowercase letter or underscore."; return 1; } ;;
    esac
    return 0
}
 
# ══════════════════════════════════════════════════════
#  VM CONFIG  (load / save)
# ══════════════════════════════════════════════════════
load_cfg() {
    local f="$VM_DIR/$1.conf"
    [[ -f "$f" ]] || { err "Config for '$1' not found."; return 1; }
    unset VM_NAME OS_TYPE CODENAME IMG_URL HOSTNAME USERNAME PASSWORD \
          DISK_SIZE MEMORY CPUS SSH_PORT GUI_MODE PORT_FORWARDS IMG_FILE SEED_FILE CREATED
    source "$f"
}
 
save_cfg() {
    mkdir -p "$VM_DIR"
    cat > "$VM_DIR/$VM_NAME.conf" <<EOF
VM_NAME="$VM_NAME"
OS_TYPE="$OS_TYPE"
CODENAME="$CODENAME"
IMG_URL="$IMG_URL"
HOSTNAME="$HOSTNAME"
USERNAME="$USERNAME"
PASSWORD="$PASSWORD"
DISK_SIZE="$DISK_SIZE"
MEMORY="$MEMORY"
CPUS="$CPUS"
SSH_PORT="$SSH_PORT"
GUI_MODE="$GUI_MODE"
PORT_FORWARDS="$PORT_FORWARDS"
IMG_FILE="$IMG_FILE"
SEED_FILE="$SEED_FILE"
CREATED="$CREATED"
EOF
    ok "Config saved."
    log "Saved config: $VM_NAME"
}
 
# ══════════════════════════════════════════════════════
#  VM LIST / RUNNING CHECK
# ══════════════════════════════════════════════════════
vm_list()    { find "$VM_DIR" -maxdepth 1 -name "*.conf" -exec basename {} .conf \; 2>/dev/null | sort; }
vm_running() {
    pgrep -f "qemu-system.*${1}" &>/dev/null && return 0
    [[ -n "${IMG_FILE:-}" ]] && pgrep -f "qemu-system.*$(basename "$IMG_FILE")" &>/dev/null
}
 
# ══════════════════════════════════════════════════════
#  IMAGE LOCK CHECK
# ══════════════════════════════════════════════════════
img_locked() {
    local img=$1
    if lsof "$img" 2>/dev/null | grep -q qemu-system; then
        local pid; pid=$(lsof "$img" 2>/dev/null | awk '/qemu-system/{print $2}' | head -1)
        warn "Image locked by PID $pid."
        ask "Force-kill and continue? [y/N]: "; read -r ans
        if [[ "$ans" =~ ^[Yy]$ ]]; then
            kill "$pid" 2>/dev/null; sleep 2
            kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
            return 1
        fi
        return 0
    fi
    local lock="${img}.lock"
    if [[ -f "$lock" ]]; then
        if find "$lock" -mmin +5 &>/dev/null; then
            warn "Stale lock file. Removing..."; rm -f "$lock"; return 1
        fi
        err "Lock file exists: $lock"; return 0
    fi
    return 1
}
 
# ══════════════════════════════════════════════════════
#  SETUP VM IMAGE
# ══════════════════════════════════════════════════════
setup_image() {
    mkdir -p "$VM_DIR"
    step "Preparing image for '$VM_NAME'..."
 
    if [[ ! -f "$IMG_FILE" ]]; then
        step "Downloading: $IMG_URL"
        echo
        if ! wget --progress=bar:force:noscroll "$IMG_URL" -O "${IMG_FILE}.tmp" 2>&1; then
            rm -f "${IMG_FILE}.tmp"
            err "Download failed. Check URL or network."
            return 1
        fi
        mv "${IMG_FILE}.tmp" "$IMG_FILE"
        ok "Image downloaded."
    else
        msg "Existing image found — skipping download."
    fi
 
    step "Resizing disk to $DISK_SIZE..."
    if ! qemu-img resize "$IMG_FILE" "$DISK_SIZE" &>/dev/null; then
        warn "Inline resize failed — creating backed image."
        local tmp="${IMG_FILE}.new"
        qemu-img create -f qcow2 -F qcow2 -b "$IMG_FILE" "$tmp" "$DISK_SIZE" &>/dev/null \
            || qemu-img create -f qcow2 "$tmp" "$DISK_SIZE" &>/dev/null
        [[ -f "$tmp" ]] && mv "$tmp" "$IMG_FILE"
    fi
    ok "Disk set to $DISK_SIZE."
 
    step "Building cloud-init seed..."
    local hpw
    hpw=$(openssl passwd -6 "$PASSWORD" 2>/dev/null) || hpw="$PASSWORD"
 
    cat > /tmp/plyt-user-data <<EOF
#cloud-config
hostname: $HOSTNAME
manage_etc_hosts: true
ssh_pwauth: true
disable_root: false
users:
  - name: $USERNAME
    gecos: VM User
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    passwd: $hpw
chpasswd:
  list: |
    root:$PASSWORD
    $USERNAME:$PASSWORD
  expire: false
runcmd:
  - sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
  - sed -i 's/^#*PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
  - systemctl restart sshd 2>/dev/null || service ssh restart 2>/dev/null || true
EOF
 
    cat > /tmp/plyt-meta-data <<EOF
instance-id: iid-${VM_NAME}-$(date +%s)
local-hostname: $HOSTNAME
EOF
 
    if ! cloud-localds "$SEED_FILE" /tmp/plyt-user-data /tmp/plyt-meta-data 2>/dev/null; then
        err "cloud-localds failed. Is cloud-image-utils installed?"
        return 1
    fi
    rm -f /tmp/plyt-user-data /tmp/plyt-meta-data
 
    echo
    _line "-" "$G"
    echo -e "  ${G}${BLD}VM Ready!${N}"
    echo -e "  ${W}SSH :${N}  ${C}ssh -p $SSH_PORT $USERNAME@localhost${N}"
    echo -e "  ${W}Pass:${N}  ${C}$PASSWORD${N}"
    _line "-" "$G"
    echo
}
 
# ══════════════════════════════════════════════════════
#  BUILD QEMU COMMAND
# ══════════════════════════════════════════════════════
build_qemu() {
    if kvm_ok; then
        kvm_msg "KVM acceleration ENABLED — native speed!"
        QEMU_CMD=( qemu-system-x86_64 -enable-kvm -cpu host )
    else
        warn "KVM unavailable — software emulation (TCG)."
        QEMU_CMD=( qemu-system-x86_64 -machine type=pc,accel=tcg -cpu qemu64 )
    fi
 
    QEMU_CMD+=(
        -m "$MEMORY"
        -smp "$CPUS"
        -drive "file=$IMG_FILE,format=qcow2,if=virtio,cache=writeback"
        -drive "file=$SEED_FILE,format=raw,if=virtio"
        -boot order=c,strict=on
        -device "virtio-net-pci,netdev=net0,mac=52:54:00:$(printf '%02x:%02x:%02x' $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)))"
        -netdev "user,id=net0,hostfwd=tcp::${SSH_PORT}-:22"
        -device virtio-balloon-pci
        -object "rng-random,filename=/dev/urandom,id=rng0"
        -device virtio-rng-pci,rng=rng0
        -rtc base=utc,clock=host
        -no-hpet
        -name "$VM_NAME"
    )
 
    if [[ -n "${PORT_FORWARDS:-}" ]]; then
        local fstr="user,id=fwd0"
        IFS=',' read -ra fwds <<< "$PORT_FORWARDS"
        for fw in "${fwds[@]}"; do
            IFS=':' read -r hp gp <<< "$fw"
            fstr+=",hostfwd=tcp::${hp}-:${gp}"
        done
        QEMU_CMD+=( -netdev "$fstr" -device virtio-net-pci,netdev=fwd0 )
    fi
 
    if [[ "${GUI_MODE:-false}" == true ]]; then
        QEMU_CMD+=( -vga virtio -display gtk )
    else
        QEMU_CMD+=( -nographic -serial mon:stdio )
    fi
}
 
# ══════════════════════════════════════════════════════
#  PROMPT HELPERS
# ══════════════════════════════════════════════════════
prompt() {
    local _var=$1 _label=$2 _def=$3 _type=$4 _val
    while true; do
        ask "$_label${_def:+ [default: $_def]}: "; read -r _val
        _val="${_val:-$_def}"
        if [[ -n "$_type" ]]; then valid "$_type" "$_val" && break
        else [[ -n "$_val" ]] && break || err "Value cannot be empty."; fi
    done
    printf -v "$_var" '%s' "$_val"
}
 
prompt_secret() {
    local _var=$1 _label=$2 _def=$3 _val
    while true; do
        ask "$_label${_def:+ [default: $_def]}: "; read -rs _val; echo
        _val="${_val:-$_def}"
        [[ -n "$_val" ]] && break || err "Password cannot be empty."
    done
    printf -v "$_var" '%s' "$_val"
}
 
# ══════════════════════════════════════════════════════
#  VM SELECTOR
# ══════════════════════════════════════════════════════
select_vm() {
    local prompt_txt=$1; shift
    local vms=("$@") count=${#vms[@]}
    echo
    for i in "${!vms[@]}"; do
        load_cfg "${vms[$i]}" &>/dev/null
        local st="${DIM}stopped${N}"; vm_running "${vms[$i]}" && st="${G}RUNNING${N}"
        printf "    ${C}%2d)${N}  %-24s  %b\n" $((i+1)) "${vms[$i]}" "$st"
    done
    echo
    local sel
    while true; do
        ask "$prompt_txt [1-$count]: "; read -r sel
        [[ "$sel" =~ ^[0-9]+$ ]] && (( sel>=1 && sel<=count )) && break
        err "Enter a number between 1 and $count."
    done
    SELECTED_VM="${vms[$((sel-1))]}"
}
 
# ══════════════════════════════════════════════════════
#  CREATE NEW VM
# ══════════════════════════════════════════════════════
create_vm() {
    print_header
    echo -e "  ${C}${BLD}  CREATE A NEW VIRTUAL MACHINE${N}"; echo
    _line "-" "$DIM"; echo
 
    local os_names=()
    mapfile -t os_names < <(printf '%s\n' "${!OS_LIST[@]}" | sort)
 
    echo -e "  ${Y}${BLD}Select Operating System:${N}"; echo
    for i in "${!os_names[@]}"; do
        printf "    ${C}%2d)${N}  %s\n" $((i+1)) "${os_names[$i]}"
    done
    echo
 
    local choice
    while true; do
        ask "Your choice [1-${#os_names[@]}]: "; read -r choice
        [[ "$choice" =~ ^[0-9]+$ ]] && (( choice>=1 && choice<=${#os_names[@]} )) && break
        err "Invalid. Try again."
    done
 
    local os="${os_names[$((choice-1))]}"
    IFS='|' read -r OS_TYPE CODENAME IMG_URL DEF_HOST DEF_USER DEF_PASS <<< "${OS_LIST[$os]}"
    ok "Selected: $os"; echo
 
    local tmp_name
    while true; do
        prompt tmp_name "VM Name" "$DEF_HOST" name
        if [[ -f "$VM_DIR/$tmp_name.conf" ]]; then
            err "VM '$tmp_name' already exists."
        else
            VM_NAME="$tmp_name"; break
        fi
    done
 
    prompt HOSTNAME   "Hostname"      "$VM_NAME"  name
    prompt USERNAME   "Username"      "$DEF_USER" user
    prompt_secret PASSWORD "Password" "$DEF_PASS"
    prompt DISK_SIZE  "Disk size"     "20G"       size
    prompt MEMORY     "RAM (MB)"      "2048"      num
    prompt CPUS       "CPU cores"     "2"         num
 
    local tmp_port
    while true; do
        prompt tmp_port "SSH Port" "2222" port
        if ss -tln 2>/dev/null | grep -q ":$tmp_port "; then
            err "Port $tmp_port is already in use."
        else
            SSH_PORT="$tmp_port"; break
        fi
    done
 
    local gui_in
    while true; do
        ask "Enable GUI display? [y/N]: "; read -r gui_in; gui_in="${gui_in:-n}"
        if   [[ "$gui_in" =~ ^[Yy]$ ]]; then GUI_MODE=true;  break
        elif [[ "$gui_in" =~ ^[Nn]$ ]]; then GUI_MODE=false; break
        else err "Enter y or n."; fi
    done
 
    ask "Extra port forwards e.g. 8080:80,3306:3306 [Enter=none]: "; read -r PORT_FORWARDS
 
    IMG_FILE="$VM_DIR/$VM_NAME.img"
    SEED_FILE="$VM_DIR/$VM_NAME-seed.iso"
    CREATED="$(date)"
 
    echo
    setup_image && save_cfg
    ask "Press Enter to continue..."; read -r
}
 
# ══════════════════════════════════════════════════════
#  START / STOP VM
# ══════════════════════════════════════════════════════
start_vm() {
    load_cfg "$1" || return 1
 
    if img_locked "$IMG_FILE"; then
        err "Cannot start — image is locked."
        ask "Force-kill all QEMU on this image? [y/N]: "; read -r fk
        if [[ "$fk" =~ ^[Yy]$ ]]; then
            pkill -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null; sleep 2
            pkill -9 -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null
            rm -f "${IMG_FILE}.lock"
        else return 1; fi
    fi
 
    if vm_running "$1"; then
        warn "VM '$1' is already running."
        ask "Stop and restart? [y/N]: "; read -r rc
        if [[ "$rc" =~ ^[Yy]$ ]]; then stop_vm "$1"; sleep 2; else return 1; fi
    fi
 
    [[ ! -f "$IMG_FILE"  ]] && { err "Image not found: $IMG_FILE";  return 1; }
    [[ ! -f "$SEED_FILE" ]] && { warn "Seed missing — recreating..."; setup_image; }
 
    echo
    _line "-" "$C"
    echo -e "  ${C}${BLD}  STARTING:  $1${N}"
    _line "-" "$DIM"
    echo -e "  ${W}RAM  :${N} ${C}${MEMORY}MB${N}   ${W}CPUs:${N} ${C}${CPUS}${N}   ${W}Disk:${N} ${C}${DISK_SIZE}${N}"
    echo -e "  ${W}SSH  :${N} ${G}ssh -p $SSH_PORT $USERNAME@localhost${N}"
    echo -e "  ${W}Pass :${N} ${G}$PASSWORD${N}"
    [[ "${GUI_MODE:-false}" != true ]] && echo -e "  ${DIM}Tip: Ctrl+A then X to exit QEMU console${N}"
    _line "-" "$C"
    echo
 
    build_qemu
    "${QEMU_CMD[@]}" || {
        err "QEMU exited with an error."
        rm -f "${IMG_FILE}.lock" 2>/dev/null
        return 1
    }
    msg "VM '$1' has been shut down."
    rm -f "${IMG_FILE}.lock" 2>/dev/null
}
 
stop_vm() {
    load_cfg "$1" || return 1
    if vm_running "$1"; then
        step "Sending shutdown signal to '$1'..."
        pkill -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null; sleep 2
        vm_running "$1" && pkill -9 -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null
        rm -f "${IMG_FILE}.lock" 2>/dev/null
        vm_running "$1" && err "Failed to stop VM." || ok "VM '$1' stopped."
    else
        msg "VM '$1' is not running."; rm -f "${IMG_FILE}.lock" 2>/dev/null
    fi
}
 
# ══════════════════════════════════════════════════════
#  VM INFO / DELETE / EDIT / RESIZE / PERF / FIX
# ══════════════════════════════════════════════════════
vm_info() {
    load_cfg "$1" || return 1
    local sz="N/A"; [[ -f "$IMG_FILE" ]] && sz=$(du -sh "$IMG_FILE" 2>/dev/null | cut -f1)
    echo; _line "=" "$C"
    echo -e "  ${C}${BLD}  VM INFO -- $1${N}"
    _line "-" "$DIM"
    printf "  ${Y}%-14s${N}  %s\n" "OS"           "$OS_TYPE ($CODENAME)"
    printf "  ${Y}%-14s${N}  %s\n" "Hostname"      "$HOSTNAME"
    printf "  ${Y}%-14s${N}  %s\n" "Username"      "$USERNAME"
    printf "  ${Y}%-14s${N}  %s\n" "Password"      "$PASSWORD"
    printf "  ${Y}%-14s${N}  %s\n" "SSH Port"      "$SSH_PORT"
    printf "  ${Y}%-14s${N}  %s\n" "Memory"        "${MEMORY}MB"
    printf "  ${Y}%-14s${N}  %s\n" "CPUs"          "$CPUS"
    printf "  ${Y}%-14s${N}  %s\n" "Disk"          "$DISK_SIZE  (${sz} on disk)"
    printf "  ${Y}%-14s${N}  %s\n" "GUI Mode"      "$GUI_MODE"
    printf "  ${Y}%-14s${N}  %s\n" "Port Forwards" "${PORT_FORWARDS:-None}"
    printf "  ${Y}%-14s${N}  %s\n" "Created"       "$CREATED"
    _line "-" "$DIM"
    vm_running "$1" \
        && echo -e "  ${G}${BLD}  Status: RUNNING${N}" \
        || echo -e "  ${DIM}  Status: Stopped${N}"
    _line "=" "$C"; echo
    ask "Press Enter to continue..."; read -r
}
 
delete_vm() {
    load_cfg "$1" || return 1
    echo; warn "This will PERMANENTLY DELETE '$1' and all its data!"
    ask "Type the VM name to confirm: "; read -r conf
    if [[ "$conf" != "$1" ]]; then msg "Deletion cancelled."; return 0; fi
    vm_running "$1" && { stop_vm "$1"; sleep 1; }
    rm -f "$IMG_FILE" "$SEED_FILE" "$VM_DIR/$1.conf" "${IMG_FILE}.lock" 2>/dev/null
    ok "VM '$1' permanently deleted."
}
 
edit_vm() {
    load_cfg "$1" || return 1
    while true; do
        echo; echo -e "  ${C}${BLD}  EDIT VM -- $1${N}"; _line "-" "$DIM"
        echo -e "   ${C} 1)${N}  Hostname        ${DIM}[$HOSTNAME]${N}"
        echo -e "   ${C} 2)${N}  Username        ${DIM}[$USERNAME]${N}"
        echo -e "   ${C} 3)${N}  Password        ${DIM}[****]${N}"
        echo -e "   ${C} 4)${N}  SSH Port        ${DIM}[$SSH_PORT]${N}"
        echo -e "   ${C} 5)${N}  GUI Mode        ${DIM}[$GUI_MODE]${N}"
        echo -e "   ${C} 6)${N}  Port Forwards   ${DIM}[${PORT_FORWARDS:-None}]${N}"
        echo -e "   ${C} 7)${N}  Memory (MB)     ${DIM}[$MEMORY]${N}"
        echo -e "   ${C} 8)${N}  CPU Count       ${DIM}[$CPUS]${N}"
        echo -e "   ${C} 9)${N}  Disk Size       ${DIM}[$DISK_SIZE]${N}"
        echo -e "   ${R} 0)${N}  Back"; echo
        ask "Choice: "; read -r ec
        case $ec in
            1) prompt HOSTNAME   "New hostname"  "$HOSTNAME"   name ;;
            2) prompt USERNAME   "New username"  "$USERNAME"   user ;;
            3) prompt_secret PASSWORD "New password" "$PASSWORD" ;;
            4) local np
               while true; do
                   prompt np "New SSH port" "$SSH_PORT" port
                   if [[ "$np" != "$SSH_PORT" ]] && ss -tln 2>/dev/null | grep -q ":$np "; then
                       err "Port $np in use."
                   else SSH_PORT="$np"; break; fi
               done ;;
            5) ask "GUI mode? [y/N]: "; read -r gi
               [[ "$gi" =~ ^[Yy]$ ]] && GUI_MODE=true || GUI_MODE=false ;;
            6) ask "Port forwards [${PORT_FORWARDS:-None}]: "; read -r pf
               PORT_FORWARDS="${pf:-$PORT_FORWARDS}" ;;
            7) prompt MEMORY    "Memory MB"  "$MEMORY"    num  ;;
            8) prompt CPUS      "CPU count"  "$CPUS"      num  ;;
            9) prompt DISK_SIZE "Disk size"  "$DISK_SIZE" size ;;
            0) break ;;
            *) err "Invalid option."; continue ;;
        esac
        save_cfg
        [[ "$ec" =~ ^[123]$ ]] && setup_image
    done
}
 
resize_disk() {
    load_cfg "$1" || return 1
    vm_running "$1" && { err "Stop the VM before resizing."; return 1; }
    msg "Current size: $DISK_SIZE"
    local ns; prompt ns "New disk size" "$DISK_SIZE" size
    step "Resizing $IMG_FILE to $ns..."
    if qemu-img resize "$IMG_FILE" "$ns"; then
        DISK_SIZE="$ns"; save_cfg; ok "Resized to $ns."
    else err "Resize failed."; fi
}
 
vm_perf() {
    load_cfg "$1" || return 1
    echo; _line "-" "$C"
    echo -e "  ${C}${BLD}  PERFORMANCE -- $1${N}"; _line "-" "$DIM"
    if vm_running "$1"; then
        local pid; pid=$(pgrep -f "qemu-system.*$(basename "$IMG_FILE")" | head -1)
        if [[ -n "$pid" ]]; then
            echo -e "  ${Y}PID    :${N} $pid"
            local cpumem; cpumem=$(ps -p "$pid" -o %cpu,%mem --no-headers 2>/dev/null | xargs)
            echo -e "  ${Y}CPU/MEM:${N} $cpumem"; echo
            echo -e "  ${Y}System Memory:${N}"; free -h 2>/dev/null | sed 's/^/    /'; echo
            echo -e "  ${Y}Image on Disk:${N}"; du -sh "$IMG_FILE" 2>/dev/null | sed 's/^/    /'
        fi
    else
        echo -e "  ${DIM}VM is not running.${N}"
        echo -e "  Config: ${MEMORY}MB RAM | $CPUS vCPUs | $DISK_SIZE"
    fi
    _line "-" "$DIM"; echo
    ask "Press Enter to continue..."; read -r
}
 
fix_vm() {
    load_cfg "$1" || return 1
    echo; echo -e "  ${C}${BLD}  FIX ISSUES -- $1${N}"; _line "-" "$DIM"
    echo -e "   ${C}1)${N}  Remove lock files"
    echo -e "   ${C}2)${N}  Recreate seed image"
    echo -e "   ${C}3)${N}  Rewrite config file"
    echo -e "   ${C}4)${N}  Force-kill stuck QEMU"
    echo -e "   ${C}5)${N}  Verify image integrity"
    echo -e "   ${R}0)${N}  Back"; echo
    ask "Choice: "; read -r fc
    case $fc in
        1) rm -f "${IMG_FILE}.lock" "${IMG_FILE}"*.lock 2>/dev/null; ok "Lock files removed." ;;
        2) rm -f "$SEED_FILE"; setup_image ;;
        3) save_cfg ;;
        4) pkill -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null; sleep 1
           pkill -9 -f "qemu-system.*$(basename "$IMG_FILE")" 2>/dev/null; ok "Killed QEMU processes." ;;
        5) step "Checking image integrity..."
           qemu-img check "$IMG_FILE" && ok "Image OK." || err "Image may be corrupted." ;;
        0) return ;;
        *) err "Invalid option." ;;
    esac
    ask "Press Enter to continue..."; read -r
}
 
# ══════════════════════════════════════════════════════
#  IDX DEV.NIX SETUP
# ══════════════════════════════════════════════════════
idx_setup() {
    print_header
    echo -e "  ${C}${BLD}  IDX DEV.NIX SETUP${N}"; echo
    _line "-" "$DIM"; echo
 
    local root="" search="$PWD"
    for _ in 1 2 3 4 5; do
        [[ -d "$search/.idx" ]] && root="$search" && break
        search="$(dirname "$search")"
    done
 
    if [[ -z "$root" ]]; then
        warn "IDX project not auto-detected."
        echo -e "   ${C}1)${N}  $HOME"
        echo -e "   ${C}2)${N}  $PWD"
        echo -e "   ${C}3)${N}  Custom path"; echo
        ask "Choice [1-3]: "; read -r lc
        case $lc in 1) root="$HOME" ;; 2) root="$PWD" ;;
            3) ask "Full path: "; read -r root ;; *) root="$PWD" ;; esac
    else
        ok "IDX project detected: $root"
    fi
 
    local nix="$root/.idx/dev.nix"
    mkdir -p "$root/.idx"
    [[ -f "$nix" ]] && cp "$nix" "${nix}.bak.$(date +%s)" && warn "Old dev.nix backed up."
 
    cat > "$nix" <<'DEVNIX'
# =========================================================
#  PROXLEGENDYT  --  IDX dev.nix
#  After saving: Ctrl+Shift+P -> "Firebase Studio: Rebuild"
# =========================================================
{ pkgs, ... }: {
 
  channel = "stable-24.05";
 
  packages = with pkgs; [
    qemu_kvm          # qemu-system-x86_64 with KVM
    qemu-utils        # qemu-img, qemu-nbd
    cloud-utils       # cloud-localds
    wget curl lsof openssl
    iproute2 procps
    unzip git sudo bash coreutils
  ];
 
  env = { VM_DIR = "/home/user/vms"; };
 
  idx = {
    extensions = [];
    workspace = {
      onCreate = {
        setup = "mkdir -p /home/user/vms && chmod +x mainmenu 2>/dev/null || true";
      };
      onStart = {
        kvm-check = ''
          [ -e /dev/kvm ] \
            && echo "KVM available -- full speed!" \
            || echo "KVM not found -- TCG mode"
        '';
      };
    };
  };
}
DEVNIX
 
    echo; echo -e "${C}$(cat "$nix")${N}"; echo
    _line "=" "$G"
    ok "dev.nix written to: $nix"; echo
    echo -e "  ${Y}${BLD}NEXT STEPS:${N}"
    echo -e "   ${W}1.${N}  Press ${C}Ctrl+Shift+P${N} in IDX"
    echo -e "   ${W}2.${N}  Run: ${C}Firebase Studio: Rebuild Environment${N}"
    echo -e "   ${W}3.${N}  Wait ~2 min, then re-run this script"
    _line "=" "$G"; echo
    ask "Press Enter to return..."; read -r
}
 

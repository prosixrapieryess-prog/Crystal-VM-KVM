            kvm_box_sep
            local idx_colors=("${KR}" "${KORANGE}" "${KGOLD}" "${KLIME}" "${KTEAL}" "${KCYAN}" "${KLBLUE}" "${KBLUE}" "${KVIOLET}" "${KPURPLE}" "${KPINK}" "${KHOTPINK}")
            for i in "${!kvm_vms[@]}"; do
                local badge run_color
                if is_vm_running "${kvm_vms[$i]}"; then
                    badge="🚀 Running"; run_color="${KLIME}${KBOLD}"
                else
                    badge="💤 Stopped"; run_color="${KDIM}${KSKY}"
                fi
                local ic="${idx_colors[$((i % ${#idx_colors[@]}))]}"
                printf "  ${KCYAN}║${KRESET}  ${ic}${KBOLD} %2d) ${KRESET}  ${KCREAM}%-35s${KRESET}  ${run_color}%s${KRESET}%$((20 - ${#badge}))s${KCYAN}║${KRESET}\n" \
                    $((i+1)) "${kvm_vms[$i]}" "$badge" ""
            done
            kvm_box_bottom; echo
        else
            echo -e "  ${KDIM}${KVIOLET}  No VMs found — create one to get started!${KRESET}"; echo
        fi
        kvm_neon_divider; echo
        kvm_box_top
        kvm_box_line "  🎮  KVM Real VPS Manager" "${KGOLD}${KBOLD}"
        kvm_box_sep
        printf "  ${KCYAN}║${KRESET}  ${KGOLD}  1)${KRESET}  🆕  ${KCREAM}Create a new VM%57s${KCYAN}║${KRESET}\n" ""
        if (( kvm_vm_count > 0 )); then
            printf "  ${KCYAN}║${KRESET}  ${KGOLD}  2)${KRESET}  🚀  ${KLIME}Start a VM%62s${KCYAN}║${KRESET}\n" ""
            printf "  ${KCYAN}║${KRESET}  ${KGOLD}  3)${KRESET}  🛑  ${KCORAL}Stop a VM%63s${KCYAN}║${KRESET}\n" ""
            printf "  ${KCYAN}║${KRESET}  ${KGOLD}  4)${KRESET}  📊  ${KSKY}Show VM info%60s${KCYAN}║${KRESET}\n" ""
            printf "  ${KCYAN}║${KRESET}  ${KGOLD}  5)${KRESET}  ✏️   ${KAMBER}Edit VM config%58s${KCYAN}║${KRESET}\n" ""
            printf "  ${KCYAN}║${KRESET}  ${KGOLD}  6)${KRESET}  🗑️   ${KR}Delete a VM%61s${KCYAN}║${KRESET}\n" ""
            printf "  ${KCYAN}║${KRESET}  ${KGOLD}  7)${KRESET}  📈  ${KTEAL}Resize VM disk%58s${KCYAN}║${KRESET}\n" ""
            printf "  ${KCYAN}║${KRESET}  ${KGOLD}  8)${KRESET}  📊  ${KLBLUE}Performance stats%55s${KCYAN}║${KRESET}\n" ""
            printf "  ${KCYAN}║${KRESET}  ${KGOLD}  9)${KRESET}  🔧  ${KVIOLET}Fix VM issues%59s${KCYAN}║${KRESET}\n" ""
        fi
        kvm_box_sep
        printf "  ${KCYAN}║${KRESET}  ${KR}  0)${KRESET}  ↩️   ${KCORAL}Back to Main Menu%55s${KCYAN}║${KRESET}\n" ""
        kvm_box_bottom; echo
        read -rp "$(kvm_status "INPUT" " Your choice: ")" choice
        local vm
        case $choice in
            1) kvm_create_vm ;;
            2) (( kvm_vm_count > 0 )) || continue
               vm=$(kvm_pick_vm "VM to start"  "${kvm_vms[@]}"); [[ -n "$vm" ]] && kvm_start_vm    "$vm" ;;
            3) (( kvm_vm_count > 0 )) || continue
               vm=$(kvm_pick_vm "VM to stop"   "${kvm_vms[@]}"); [[ -n "$vm" ]] && kvm_stop_vm     "$vm" ;;
            4) (( kvm_vm_count > 0 )) || continue
               vm=$(kvm_pick_vm "VM to inspect" "${kvm_vms[@]}"); [[ -n "$vm" ]] && kvm_show_info   "$vm" ;;
            5) (( kvm_vm_count > 0 )) || continue
               vm=$(kvm_pick_vm "VM to edit"   "${kvm_vms[@]}"); [[ -n "$vm" ]] && kvm_edit_config "$vm" ;;
            6) (( kvm_vm_count > 0 )) || continue
               vm=$(kvm_pick_vm "VM to delete" "${kvm_vms[@]}"); [[ -n "$vm" ]] && kvm_delete_vm   "$vm" ;;
            7) (( kvm_vm_count > 0 )) || continue
               vm=$(kvm_pick_vm "VM to resize" "${kvm_vms[@]}"); [[ -n "$vm" ]] && kvm_resize_disk "$vm" ;;
            8) (( kvm_vm_count > 0 )) || continue
               vm=$(kvm_pick_vm "VM to inspect" "${kvm_vms[@]}"); [[ -n "$vm" ]] && kvm_show_perf   "$vm" ;;
            9) (( kvm_vm_count > 0 )) || continue
               vm=$(kvm_pick_vm "VM to fix"    "${kvm_vms[@]}"); [[ -n "$vm" ]] && kvm_fix_issues  "$vm" ;;
            0) return 0 ;;
            *) kvm_status "ERROR" "Invalid option — choose from the menu" ;;
        esac
        echo; read -rp "$(kvm_status "INPUT" " ⏎  Press Enter to continue...")"
    done
}
 

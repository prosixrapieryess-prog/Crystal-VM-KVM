            os_idx=$(( os_choice - 1 )); break
        fi
        print_status "ERROR" "Please enter a number between 1 and ${total}"
    done
    OS_TYPE="${os_types[$os_idx]}"; CODENAME="${os_codes[$os_idx]}"; IMG_URL="${os_urls[$os_idx]}"
    local DEFAULT_USERNAME="${os_users[$os_idx]}"
    local DEFAULT_HOSTNAME="${OS_TYPE}${CODENAME}"
    local DEFAULT_PASSWORD="${OS_TYPE}"

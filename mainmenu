# ─── STATUS MESSAGES ────────────────────────────────────────
print_status() {
    local type=$1
    local message=$2
    case $type in
        INFO)    echo -e "  ${CY}${BD}[  INFO  ]${RST} ${LW}$message${RST}" ;;
        WARN)    echo -e "  ${Y}${BD}[  WARN  ]${RST} ${Y}$message${RST}" ;;
        ERROR)   echo -e "  ${R}${BD}[ ERROR  ]${RST} ${LR}$message${RST}" ;;
        SUCCESS) echo -e "  ${G}${BD}[   OK   ]${RST} ${LG}$message${RST}" ;;
        INPUT)   echo -ne "  ${M}${BD}[ INPUT  ]${RST} ${LM}$message${RST}" ;;
        STEP)    echo -e "  ${B}${BD}[  STEP  ]${RST} ${LB}$message${RST}" ;;
    esac
}

# ─── DIVIDERS ───────────────────────────────────────────────
divider()      { echo -e "${BLK}  ──────────────────────────────────────────────────────────────${RST}"; }
bold_divider() { echo -e "${CY}  ══════════════════════════════════════════════════════════════${RST}"; }

# ─── PROGRESS BAR ───────────────────────────────────────────
progress_bar() {
    local current=$1 total=$2 width=50
    local filled=$(( current * width / total ))
    local empty=$(( width - filled ))
    local pct=$(( current * 100 / total ))
    printf "  ${CY}[${G}"
    printf '%0.s█' $(seq 1 $filled)
    printf "${BLK}"
    printf '%0.s░' $(seq 1 $empty)
    printf "${CY}]${RST} ${BD}${W}%3d%%${RST}\r" $pct
}

# ─── SPINNER ────────────────────────────────────────────────
spinner_pid=""
start_spinner() {
    local msg="${1:-Working...}"
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    (
        local i=0
        while true; do
            printf "\r  ${CY}${BD}${frames[$i]}${RST}  ${LW}%s${RST}  " "$msg"
            i=$(( (i+1) % ${#frames[@]} ))
            sleep 0.1
        done
    ) &
    spinner_pid=$!
    disown "$spinner_pid"
}

stop_spinner() {
    if [[ -n "$spinner_pid" ]]; then
        kill "$spinner_pid" 2>/dev/null
        wait "$spinner_pid" 2>/dev/null
        spinner_pid=""
        printf "\r%80s\r"  # clear spinner line
    fi
}

# ─── DEPENDENCY CHECK ───────────────────────────────────────
check_dependencies() {
    local deps=("qemu-system-x86_64" "wget" "cloud-localds" "qemu-img" "lsof" "openssl")
    local missing=()
    for dep in "${deps[@]}"; do
        command -v "$dep" &>/dev/null || missing+=("$dep")
    done
    if [[ ${#missing[@]} -ne 0 ]]; then
        print_status ERROR "Missing: ${missing[*]}"
        print_status INFO  "Install: sudo apt install qemu-system-x86 cloud-image-utils wget lsof openssl"
        exit 1
    fi
}

# ─── INPUT VALIDATION ───────────────────────────────────────
validate_input() {
    local type=$1 value=$2
    case $type in
        number)   [[ "$value" =~ ^[0-9]+$ ]] || { print_status ERROR "Must be a number"; return 1; } ;;
        size)     [[ "$value" =~ ^[0-9]+[GgMm]$ ]] || { print_status ERROR "Format: 100G or 512M"; return 1; } ;;
        port)     [[ "$value" =~ ^[0-9]+$ ]] && [ "$value" -ge 23 ] && [ "$value" -le 65535 ] || { print_status ERROR "Valid port: 23-65535"; return 1; } ;;
        name)     [[ "$value" =~ ^[a-zA-Z0-9_-]+$ ]] || { print_status ERROR "Only letters, numbers, - and _"; return 1; } ;;
        username) [[ "$value" =~ ^[a-z_][a-z0-9_-]*$ ]] || { print_status ERROR "Must start with letter/underscore"; return 1; } ;;
    esac
    return 0
}

# ─── VM LIST ────────────────────────────────────────────────
get_vm_list() {
    find "$VM_DIR" -maxdepth 1 -name "*.conf" -exec basename {} .conf \; 2>/dev/null | sort
}

# ─── LOAD CONFIG ────────────────────────────────────────────
load_vm_config() {
    local vm_name=$1
    local config_file="$VM_DIR/$vm_name.conf"
    if [[ -f "$config_file" ]]; then
        unset VM_NAME OS_TYPE CODENAME IMG_URL HOSTNAME USERNAME PASSWORD
        unset DISK_SIZE MEMORY CPUS SSH_PORT GUI_MODE PORT_FORWARDS IMG_FILE SEED_FILE CREATED
        # shellcheck source=/dev/null
        source "$config_file"
        return 0
    else
        print_status ERROR "Config for '$vm_name' not found"
        return 1
    fi
}

# ─── SAVE CONFIG ────────────────────────────────────────────
save_vm_config() {
    mkdir -p "$VM_DIR"
    local config_file="$VM_DIR/$VM_NAME.conf"
    cat > "$config_file" <<EOF
VM_NAME="$VM_NAME"
OS_TYPE="$OS_TYPE"
CODENAME="$CODENAME"
IMG_URL="$IMG_URL"
HOSTNAME="$HOSTNAME"
USERNAME="$USERNAME"
PASSWORD="$PASSWORD"
DISK_SIZE="$DISK_SIZE"
MEMORY="$MEMORY"
CPUS="$CPUS"
SSH_PORT="$SSH_PORT"
GUI_MODE="$GUI_MODE"
PORT_FORWARDS="$PORT_FORWARDS"
IMG_FILE="$IMG_FILE"
SEED_FILE="$SEED_FILE"
CREATED="$CREATED"
EOF
    print_status SUCCESS "Config saved → $config_file"
}

# ─── IMAGE LOCK CHECK ───────────────────────────────────────
check_image_lock() {
    local img_file=$1 vm_name=$2
    if lsof "$img_file" 2>/dev/null | grep -q qemu-system; then
        local pid
        pid=$(lsof "$img_file" 2>/dev/null | awk '/qemu-system/{print $2}' | head -1)
        print_status WARN "Image locked by PID: $pid"
        if [[ -n "$pid" ]] && ps -p "$pid" -o cmd= 2>/dev/null | grep -q "$vm_name"; then
            print_status INPUT "Kill and restart? [y/N]: "; read -r kc
            if [[ "$kc" =~ ^[Yy]$ ]]; then
                kill "$pid" 2>/dev/null; sleep 2
                kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
                return 0
            fi
        fi
        return 1
    fi
    local lock_file="${img_file}.lock"
    if [[ -f "$lock_file" ]]; then
        # find returns exit 0 always; must check if it actually matched (non-empty output)
        if [[ -n "$(find "$lock_file" -mmin +5 2>/dev/null)" ]]; then
            print_status WARN "Stale lock file found (>5 min old)"
            print_status INPUT "Remove it? [y/N]: "; read -r rl
            [[ "$rl" =~ ^[Yy]$ ]] && rm -f "$lock_file" && print_status SUCCESS "Lock removed" && return 0
        fi
        return 1
    fi
    return 0
}

# ─── IS VM RUNNING ──────────────────────────────────────────
is_vm_running() {
    local vm_name=$1
    pgrep -f "qemu-system.*${vm_name}" &>/dev/null && return 0
    # Redirect ALL output (stdout+stderr) — print_status writes to stdout, not stderr
    if load_vm_config "$vm_name" &>/dev/null; then
        pgrep -f "qemu-system.*${IMG_FILE}" &>/dev/null && return 0
    fi
    return 1
}

# ─── STOP VM ────────────────────────────────────────────────
stop_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1
    if is_vm_running "$vm_name"; then
        print_status INFO "Stopping VM: ${BD}$vm_name${RST}"
        pkill -TERM -f "qemu-system.*${IMG_FILE}" 2>/dev/null; sleep 3
        if is_vm_running "$vm_name"; then
            print_status WARN "Forcing termination..."
            pkill -9 -f "qemu-system.*${IMG_FILE}" 2>/dev/null; sleep 1
        fi
        rm -f "${IMG_FILE}.lock" 2>/dev/null
        is_vm_running "$vm_name" \
            && print_status ERROR "Failed to stop VM" \
            || print_status SUCCESS "VM '$vm_name' stopped"
    else
        print_status INFO "VM '$vm_name' is not running"
        rm -f "${IMG_FILE}.lock" 2>/dev/null
    fi
}

# ─── SETUP VM IMAGE ─────────────────────────────────────────
setup_vm_image() {
    mkdir -p "$VM_DIR"
    print_status STEP "Preparing image for ${BD}$VM_NAME${RST}"
    divider

    if [[ -f "$IMG_FILE" ]]; then
        print_status INFO "Image already exists — skipping download"
    else
        print_status INFO "Downloading: $IMG_URL"
        echo ""
        if ! wget --progress=bar:force:noscroll "$IMG_URL" -O "${IMG_FILE}.tmp"; then
            print_status ERROR "Download failed!"
            rm -f "${IMG_FILE}.tmp"
            return 1
        fi
        mv "${IMG_FILE}.tmp" "$IMG_FILE"
        print_status SUCCESS "Download complete"
    fi

    # Resize disk
    print_status STEP "Resizing disk to $DISK_SIZE"
    if ! qemu-img resize "$IMG_FILE" "$DISK_SIZE" &>/dev/null; then
        print_status WARN "In-place resize failed — creating backed overlay"
        local base_copy="${IMG_FILE}.base"
        local overlay="${IMG_FILE}.overlay.qcow2"
        # Keep original as backing store under a stable name
        cp "$IMG_FILE" "$base_copy"
        if qemu-img create -f qcow2 -F qcow2 -b "$base_copy" "$overlay" "$DISK_SIZE" &>/dev/null; then
            mv "$overlay" "$IMG_FILE"
            # backing path is now absolute — rebase to make it self-contained
            qemu-img rebase -u -b "$base_copy" "$IMG_FILE" &>/dev/null || true
        else
            print_status ERROR "Overlay creation failed — using original size"
            rm -f "$base_copy" "$overlay" 2>/dev/null
        fi
    fi
    print_status SUCCESS "Disk sized to $DISK_SIZE"

    # Build cloud-init
    print_status STEP "Building cloud-init config"
    local hashed_pass
    hashed_pass=$(openssl passwd -6 "$PASSWORD" 2>/dev/null | tr -d '\n')

    cat > /tmp/user-data-"$VM_NAME" <<EOF
#cloud-config
hostname: $HOSTNAME
manage_etc_hosts: true
ssh_pwauth: true
disable_root: false
users:
  - name: $USERNAME
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    passwd: ${hashed_pass}
  - name: root
    lock_passwd: false
    passwd: ${hashed_pass}
chpasswd:
  expire: false
package_update: false
runcmd:
  - sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
  - sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
  - systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null
EOF

    cat > /tmp/meta-data-"$VM_NAME" <<EOF
instance-id: iid-${VM_NAME}-$(date +%s)
local-hostname: $HOSTNAME
EOF

    if ! cloud-localds "$SEED_FILE" /tmp/user-data-"$VM_NAME" /tmp/meta-data-"$VM_NAME" 2>/dev/null; then
        print_status ERROR "Failed to create seed image"
        return 1
    fi
    rm -f /tmp/user-data-"$VM_NAME" /tmp/meta-data-"$VM_NAME"

    divider
    print_status SUCCESS "VM '${BD}$VM_NAME${RST}' is ready!"
    echo -e "\n  ${CY}╔══════════════════════════════╗"
    echo -e "  ║  ${W}${BD}SSH:${RST}${CY}  ssh -p $SSH_PORT $USERNAME@localhost ${CY}║"
    echo -e "  ║  ${W}${BD}Pass:${RST}${CY} $PASSWORD$(printf '%*s' $((28 - ${#PASSWORD})) '')${CY}║"
    echo -e "  ╚══════════════════════════════╝${RST}\n"
}

# ─── BUILD QEMU COMMAND ─────────────────────────────────────
# Populates global QEMU_CMD array — do NOT call inside $() subshell
# so that print_status output reaches the terminal correctly.
QEMU_CMD=()
build_qemu_cmd() {
    QEMU_CMD=(qemu-system-x86_64)

    # KVM or TCG — status prints go to terminal (not captured)
    if $KVM_AVAILABLE; then
        QEMU_CMD+=(-enable-kvm -cpu host,+x2apic -machine type=q35,accel=kvm)
        # kvm-pit flag is ONLY valid with KVM
        QEMU_CMD+=(-global kvm-pit.lost_tick_policy=discard)
        print_status SUCCESS "Using ${BD}KVM acceleration${RST}"
    else
        QEMU_CMD+=(-cpu qemu64 -machine type=q35,accel=tcg)
        print_status WARN "KVM unavailable — using software emulation (TCG)"
    fi

    # FIX smp: sockets=1 so total vCPUs = cores, not cores²
    QEMU_CMD+=(
        -m "$MEMORY"
        -smp "cpus=${CPUS},cores=${CPUS},threads=1,sockets=1"
        -drive "file=$IMG_FILE,format=qcow2,if=virtio,cache=writeback,aio=threads,discard=unmap"
        -drive "file=$SEED_FILE,format=raw,if=virtio,readonly=on"
        -boot order=c,menu=off
        -device virtio-balloon-pci
        -device virtio-rng-pci,rng=rng0
        -object rng-random,filename=/dev/urandom,id=rng0
        -rtc base=utc,clock=host,driftfix=slew
    )

    # FIX port forwards: all hostfwds go on the SAME netdev string, not separate devices
    local netdev_str="user,id=net0,hostfwd=tcp::${SSH_PORT}-:22"
    if [[ -n "$PORT_FORWARDS" ]]; then
        IFS=',' read -ra forwards <<< "$PORT_FORWARDS"
        for fwd in "${forwards[@]}"; do
            fwd="${fwd// /}"
            IFS=':' read -r hport gport <<< "$fwd"
            if [[ -n "$hport" && -n "$gport" ]]; then
                netdev_str+=",hostfwd=tcp::${hport}-:${gport}"
            fi
        done
    fi
    QEMU_CMD+=(
        -device "virtio-net-pci,netdev=net0,mac=52:54:00:$(printf '%02x:%02x:%02x' $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)))"
        -netdev "$netdev_str"
    )

    # GUI or headless
    if [[ "$GUI_MODE" == true ]]; then
        QEMU_CMD+=(-vga virtio -display gtk,gl=on -usb -device usb-tablet)
        print_status INFO "Starting in ${BD}GUI mode${RST}"
    else
        QEMU_CMD+=(-nographic -serial mon:stdio)
        print_status INFO "Console mode — ${Y}Ctrl+A then X${RST} to quit"
    fi
}

# ─── START VM ───────────────────────────────────────────────
start_vm() {
    local vm_name=$1
    load_vm_config "$vm_name" || return 1

    if ! check_image_lock "$IMG_FILE" "$vm_name"; then
        print_status ERROR "Image is locked"
        print_status INPUT "Force-kill all QEMU using this image? [y/N]: "; read -r fk
        if [[ "$fk" =~ ^[Yy]$ ]]; then
            pkill -9 -f "qemu-system.*${IMG_FILE}" 2>/dev/null; sleep 2
            rm -f "${IMG_FILE}.lock" 2>/dev/null
            print_status SUCCESS "Processes killed"
        else
            return 1
        fi
    fi

    if is_vm_running "$vm_name"; then
        print_status WARN "VM '$vm_name' is already running"
        print_status INPUT "Stop and restart? [y/N]: "; read -r rc
        if [[ "$rc" =~ ^[Yy]$ ]]; then
            stop_vm "$vm_name"; sleep 2
        else
            return 1
        fi
    fi

    [[ ! -f "$IMG_FILE" ]] && { print_status ERROR "Image not found: $IMG_FILE"; return 1; }
    [[ ! -f "$SEED_FILE" ]] && { print_status WARN "Seed missing — rebuilding..."; setup_vm_image; }

    echo ""
    bold_divider
    echo -e "  ${BD}${CY}  LAUNCHING VM: ${W}$vm_name${RST}"
    bold_divider
    echo -e "  ${LW}  RAM: ${CY}${MEMORY}MB${RST}  │  CPUs: ${CY}${CPUS}${RST}  │  Disk: ${CY}${DISK_SIZE}${RST}  │  SSH Port: ${CY}${SSH_PORT}${RST}"
    bold_divider
    echo ""

    # Build command into global QEMU_CMD array (no subshell — print_status goes to terminal)
    build_qemu_cmd
    echo ""
    # Run directly from array — safe quoting, no eval needed
    "${QEMU_CMD[@]}" || {
        print_status ERROR "QEMU exited with error. Check config."
        rm -f "${IMG_FILE}.lock" 2>/dev/null
        return 1
    }
    print_status INFO "VM '$vm_name' has shut down"
}

# ─── CREATE NEW VM ──────────────────────────────────────────
create_new_vm() {
    print_header
    echo -e "  ${BD}${CY}  ╔══════════════════════════╗"
    echo -e "  ║   🆕  CREATE NEW VM      ║"
    echo -e "  ╚══════════════════════════╝${RST}\n"

    # OS selection
    local -a os_keys=(
        "Ubuntu 22.04 LTS"
        "Ubuntu 24.04 LTS"
        "Debian 11 (Bullseye)"
        "Debian 12 (Bookworm)"
        "Debian 13 (Trixie)"
        "Fedora 40"
        "CentOS Stream 9"
        "AlmaLinux 9"
        "Rocky Linux 9"
    )
    local -a os_vals=(
        "ubuntu|jammy|https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img|ubuntu22|ubuntu|ubuntu"
        "ubuntu|noble|https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img|ubuntu24|ubuntu|ubuntu"
        "debian|bullseye|https://cloud.debian.org/images/cloud/bullseye/latest/debian-11-generic-amd64.qcow2|debian11|debian|debian"
        "debian|bookworm|https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-generic-amd64.qcow2|debian12|debian|debian"
        "debian|trixie|https://cloud.debian.org/images/cloud/trixie/daily/latest/debian-13-generic-amd64-daily.qcow2|debian13|debian|debian"
        "fedora|40|https://download.fedoraproject.org/pub/fedora/linux/releases/40/Cloud/x86_64/images/Fedora-Cloud-Base-40-1.14.x86_64.qcow2|fedora40|fedora|fedora"
        "centos|stream9|https://cloud.centos.org/centos/9-stream/x86_64/images/CentOS-Stream-GenericCloud-9-latest.x86_64.qcow2|centos9|centos|centos"
        "almalinux|9|https://repo.almalinux.org/almalinux/9/cloud/x86_64/images/AlmaLinux-9-GenericCloud-latest.x86_64.qcow2|almalinux9|alma|alma"
        "rockylinux|9|https://download.rockylinux.org/pub/rocky/9/images/x86_64/Rocky-9-GenericCloud.latest.x86_64.qcow2|rocky9|rocky|rocky"
    )

    divider
    echo -e "  ${BD}${CY}  Select Operating System:${RST}\n"
    for i in "${!os_keys[@]}"; do
        printf "  ${CY}%2d)${RST} ${W}%s${RST}\n" $((i+1)) "${os_keys[$i]}"
    done
    divider

    local choice
    while true; do
        print_status INPUT "OS choice [1-${#os_keys[@]}]: "; read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#os_keys[@]} ]; then
            local idx=$((choice-1))
            IFS='|' read -r OS_TYPE CODENAME IMG_URL DEFAULT_HOSTNAME DEFAULT_USERNAME DEFAULT_PASSWORD <<< "${os_vals[$idx]}"
            print_status SUCCESS "Selected: ${os_keys[$idx]}"
            break
        fi
        print_status ERROR "Invalid selection"
    done

    echo ""
    divider

    # VM Name
    while true; do
        print_status INPUT "VM name [default: $DEFAULT_HOSTNAME]: "; read -r VM_NAME
        VM_NAME="${VM_NAME:-$DEFAULT_HOSTNAME}"
        validate_input "name" "$VM_NAME" || continue
        [[ -f "$VM_DIR/$VM_NAME.conf" ]] && { print_status ERROR "VM '$VM_NAME' already exists"; continue; }
        break
    done

    # Hostname
    while true; do
        print_status INPUT "Hostname [default: $VM_NAME]: "; read -r HOSTNAME
        HOSTNAME="${HOSTNAME:-$VM_NAME}"
        validate_input "name" "$HOSTNAME" && break
    done

    # Username
    while true; do
        print_status INPUT "Username [default: $DEFAULT_USERNAME]: "; read -r USERNAME
        USERNAME="${USERNAME:-$DEFAULT_USERNAME}"
        validate_input "username" "$USERNAME" && break
    done

    # Password
    while true; do
        print_status INPUT "Password [default: $DEFAULT_PASSWORD]: "; read -rs PASSWORD; echo ""
        PASSWORD="${PASSWORD:-$DEFAULT_PASSWORD}"
        [[ -n "$PASSWORD" ]] && break
        print_status ERROR "Password cannot be empty"
    done

    # Disk
    while true; do
        print_status INPUT "Disk size [default: 20G]: "; read -r DISK_SIZE
        DISK_SIZE="${DISK_SIZE:-20G}"
        validate_input "size" "$DISK_SIZE" && break
    done

    # Memory
    while true; do
        print_status INPUT "RAM in MB [default: 2048]: "; read -r MEMORY
        MEMORY="${MEMORY:-2048}"
        validate_input "number" "$MEMORY" && break
    done

    # CPUs
    while true; do
        local max_cpu
        max_cpu=$(nproc 2>/dev/null || echo 4)
        print_status INPUT "CPUs [default: 2, max: $max_cpu]: "; read -r CPUS
        CPUS="${CPUS:-2}"
        validate_input "number" "$CPUS" && break
    done

    # SSH Port
    while true; do
        print_status INPUT "SSH port [default: 2222]: "; read -r SSH_PORT
        SSH_PORT="${SSH_PORT:-2222}"
        validate_input "port" "$SSH_PORT" || continue
        if ss -tln 2>/dev/null | grep -q ":${SSH_PORT} "; then
            print_status ERROR "Port $SSH_PORT is in use"
        else
            break
        fi
    done

    # GUI
    while true; do
        print_status INPUT "Enable GUI? [y/N]: "; read -r gui_in
        gui_in="${gui_in:-n}"
        case "$gui_in" in
            [Yy]) GUI_MODE=true; break ;;
            [Nn]) GUI_MODE=false; break ;;
            *) print_status ERROR "Please enter y or n" ;;
        esac
    done

    # Port forwards
    print_status INPUT "Extra port forwards (e.g. 8080:80,3306:3306 or blank): "; read -r PORT_FORWARDS

    IMG_FILE="$VM_DIR/$VM_NAME.img"
    SEED_FILE="$VM_DIR/$VM_NAME-seed.iso"
    CREATED="$(date)"

    echo ""
    setup_vm_image || return 1
    save_vm_config

    print_status INPUT "Start VM now? [y/N]: "; read -r start_now
    [[ "$start_now" =~ ^[Yy]$ ]] && start_vm "$VM_NAME"
}


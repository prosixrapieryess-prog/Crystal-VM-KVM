# ─────────────────────────────────────────
# MAIN MENU (for IDX VPS Maker)
# ─────────────────────────────────────────
main_menu() {
    while true; do
        print_header
 
        local vms=()
        mapfile -t vms < <(get_vm_list)
        local vm_count=${#vms[@]}
 
        if [ "$vm_count" -gt 0 ]; then
            print_status "INFO" "Found $vm_count existing VM(s):"
            for i in "${!vms[@]}"; do
                local status="💤"
                is_vm_running "${vms[$i]}" && status="🚀"
                printf "  %2d) ${G}%s${N} %s\n" $((i+1)) "${vms[$i]}" "$status"
            done
            echo
        fi
 
        echo -e "${C}📋 Main Menu:${N}"
        echo -e "  ${G}1) 🆕 Create a new VM${N}"
        if [ "$vm_count" -gt 0 ]; then
            echo -e "  ${G}2) 🚀 Start a VM${N}"
            echo -e "  ${Y}3) 🛑 Stop a VM${N}"
            echo -e "  ${C}4) 📊 Show VM info${N}"
            echo -e "  ${C}5) ✏️  Edit VM configuration${N}"
            echo -e "  ${R}6) 🗑️  Delete a VM${N}"
            echo -e "  ${M}7) 📈 Resize VM disk${N}"
            echo -e "  ${M}8) 📊 Show VM performance${N}"
            echo -e "  ${Y}9) 🔧 Fix VM issues${N}"
        fi
        echo -e "  ${R}0) 👋 Exit${N}"
        echo
 
        read -p "$(print_status "INPUT" "Enter your choice: ")" choice
 
        local vm_num
        case $choice in
            1) create_new_vm ;;
            2) if [ "$vm_count" -gt 0 ]; then
                   read -p "$(print_status "INPUT" "VM number to start: ")" vm_num
                   [[ "$vm_num" =~ ^[0-9]+$ ]] && [ "$vm_num" -ge 1 ] && [ "$vm_num" -le "$vm_count" ] \
                       && start_vm "${vms[$((vm_num-1))]}" || print_status "ERROR" "Invalid selection"
               fi ;;
            3) if [ "$vm_count" -gt 0 ]; then
                   read -p "$(print_status "INPUT" "VM number to stop: ")" vm_num
                   [[ "$vm_num" =~ ^[0-9]+$ ]] && [ "$vm_num" -ge 1 ] && [ "$vm_num" -le "$vm_count" ] \
                       && stop_vm "${vms[$((vm_num-1))]}" || print_status "ERROR" "Invalid selection"
               fi ;;
            4) if [ "$vm_count" -gt 0 ]; then
                   read -p "$(print_status "INPUT" "VM number to show info: ")" vm_num
                   [[ "$vm_num" =~ ^[0-9]+$ ]] && [ "$vm_num" -ge 1 ] && [ "$vm_num" -le "$vm_count" ] \
                       && show_vm_info "${vms[$((vm_num-1))]}" || print_status "ERROR" "Invalid selection"
               fi ;;
            5) if [ "$vm_count" -gt 0 ]; then
                   read -p "$(print_status "INPUT" "VM number to edit: ")" vm_num
                   [[ "$vm_num" =~ ^[0-9]+$ ]] && [ "$vm_num" -ge 1 ] && [ "$vm_num" -le "$vm_count" ] \
                       && edit_vm_config "${vms[$((vm_num-1))]}" || print_status "ERROR" "Invalid selection"
               fi ;;
            6) if [ "$vm_count" -gt 0 ]; then
                   read -p "$(print_status "INPUT" "VM number to delete: ")" vm_num
                   [[ "$vm_num" =~ ^[0-9]+$ ]] && [ "$vm_num" -ge 1 ] && [ "$vm_num" -le "$vm_count" ] \
                       && delete_vm "${vms[$((vm_num-1))]}" || print_status "ERROR" "Invalid selection"
               fi ;;
            7) if [ "$vm_count" -gt 0 ]; then
                   read -p "$(print_status "INPUT" "VM number to resize: ")" vm_num
                   [[ "$vm_num" =~ ^[0-9]+$ ]] && [ "$vm_num" -ge 1 ] && [ "$vm_num" -le "$vm_count" ] \
                       && resize_vm_disk "${vms[$((vm_num-1))]}" || print_status "ERROR" "Invalid selection"
               fi ;;
            8) if [ "$vm_count" -gt 0 ]; then
                   read -p "$(print_status "INPUT" "VM number for performance: ")" vm_num
                   [[ "$vm_num" =~ ^[0-9]+$ ]] && [ "$vm_num" -ge 1 ] && [ "$vm_num" -le "$vm_count" ] \
                       && show_vm_performance "${vms[$((vm_num-1))]}" || print_status "ERROR" "Invalid selection"
               fi ;;
            9) if [ "$vm_count" -gt 0 ]; then
                   read -p "$(print_status "INPUT" "VM number to fix: ")" vm_num
                   [[ "$vm_num" =~ ^[0-9]+$ ]] && [ "$vm_num" -ge 1 ] && [ "$vm_num" -le "$vm_count" ] \
                       && fix_vm_issues "${vms[$((vm_num-1))]}" || print_status "ERROR" "Invalid selection"
               fi ;;
            0) print_status "INFO" "Goodbye!"; return 0 ;;
            *) print_status "ERROR" "Invalid option" ;;
        esac
 
        read -p "$(print_status "INPUT" "Press Enter to continue...")"
    done
}
 

    read -p "  $(print_status "INPUT" "Extra port forwards e.g. 8080:80 (Enter to skip): ")" PORT_FORWARDS
    IMG_FILE="$VM_DIR/$VM_NAME.img"; SEED_FILE="$VM_DIR/$VM_NAME-seed.iso"; CREATED="$(date)"
    echo; sep_thin
    echo -e "  ${GOLD}Summary:${N}"
    echo -e "  ${Y}OS${N}   → ${W}${os_labels[$os_idx]}${N}"
    echo -e "  ${Y}Name${N} → ${W}${VM_NAME}${N}   ${Y}User${N} → ${G}${USERNAME}${N}   ${Y}SSH${N} → ${M}:${SSH_PORT}${N}"
    echo -e "  ${Y}RAM${N}  → ${W}${MEMORY}MB${N}  ${Y}CPUs${N} → ${W}${CPUS}${N}  ${Y}Disk${N} → ${W}${DISK_SIZE}${N}"
    sep_thin; echo
    setup_vm_image; save_vm_config
}
 

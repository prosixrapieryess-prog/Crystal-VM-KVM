#!/bin/bash
# ╔══════════════════════════════════════════════════════════════╗
# ║         PROXLEGENDYT — VM / KVM Manager                     ║
# ║         Version 4.0  |  Google IDX + KVM Ready             ║
# ╚══════════════════════════════════════════════════════════════╝
export LANG=en_US.UTF-8
export TERM="${TERM:-xterm-256color}"
 
# ══════════════════════════════════════════════════════
#  COLORS & STYLES
# ══════════════════════════════════════════════════════
R="\e[1;31m"    # Bold Red
G="\e[1;32m"    # Bold Green
Y="\e[1;33m"    # Bold Yellow
B="\e[1;34m"    # Bold Blue
M="\e[1;35m"    # Bold Magenta
C="\e[1;36m"    # Bold Cyan
W="\e[1;37m"    # Bold White
DIM="\e[2;37m"  # Dim White
N="\e[0m"       # Reset
BLD="\e[1m"     # Bold
 
# ══════════════════════════════════════════════════════
#  GLOBAL CONFIG
# ══════════════════════════════════════════════════════
VM_DIR="${VM_DIR:-$HOME/vms}"
LOG_FILE="$VM_DIR/proxlegendyt.log"
VERSION="4.0"
 
# ══════════════════════════════════════════════════════
#  LOGGING
# ══════════════════════════════════════════════════════
log() { mkdir -p "$VM_DIR"; echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE" 2>/dev/null; }
 
# ══════════════════════════════════════════════════════
#  PRINT HELPERS
# ══════════════════════════════════════════════════════
_line() {
    local char="${1:-─}" color="${2:-$DIM}" len=66
    echo -e "${color}$(printf "%${len}s" | tr ' ' "$char")${N}"
}
msg()     { echo -e " ${C}${BLD}[  INFO  ]${N}  $*"; log "[INFO] $*"; }
warn()    { echo -e " ${Y}${BLD}[  WARN  ]${N}  $*"; log "[WARN] $*"; }
err()     { echo -e " ${R}${BLD}[ ERROR  ]${N}  $*"; log "[ERROR] $*"; }
ok()      { echo -e " ${G}${BLD}[   OK   ]${N}  $*"; log "[OK] $*"; }
step()    { echo -e " ${B}${BLD}[ STEP   ]${N}  $*"; log "[STEP] $*"; }
kvm_msg() { echo -e " ${G}${BLD}[  KVM   ]${N}  $*"; log "[KVM] $*"; }
ask()     { echo -ne " ${M}${BLD}[ INPUT  ]${N}  $*"; }
 

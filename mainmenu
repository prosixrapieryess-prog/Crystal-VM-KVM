# ─────────────────────────────────────────
# IS VM RUNNING
# ─────────────────────────────────────────
is_vm_running() {
    local vm_name=$1
    pgrep -f "qemu-system.*$vm_name" >/dev/null && return 0
    if load_vm_config "$vm_name" 2>/dev/null; then
        pgrep -f "qemu-system.*$IMG_FILE" >/dev/null && return 0
    fi
    return 1
}
 
# ─────────────────────────────────────────
# EDIT VM CONFIG
# ─────────────────────────────────────────
edit_vm_config() {
    local vm_name=$1
    if ! load_vm_config "$vm_name"; then return 1; fi
 
    print_status "INFO" "Editing VM: $vm_name"
 
    while true; do
        echo -e "\n${C}📝 What would you like to edit?${N}"
        echo "  1) 🏷️  Hostname"
        echo "  2) 👤 Username"
        echo "  3) 🔑 Password"
        echo "  4) 🔌 SSH Port"
        echo "  5) 🖥️  GUI Mode"
        echo "  6) 🌐 Port Forwards"
        echo "  7) 🧠 Memory"
        echo "  8) ⚡ CPUs"
        echo "  9) 💾 Disk Size"
        echo "  0) ↩️  Back"
        read -p "$(print_status "INPUT" "Enter your choice: ")" edit_choice
 
        case $edit_choice in
            1) while true; do
                   read -p "$(print_status "INPUT" "New hostname (current: $HOSTNAME): ")" v; v="${v:-$HOSTNAME}"
                   validate_input "name" "$v" && { HOSTNAME="$v"; break; }
               done ;;
            2) while true; do
                   read -p "$(print_status "INPUT" "New username (current: $USERNAME): ")" v; v="${v:-$USERNAME}"
                   validate_input "username" "$v" && { USERNAME="$v"; break; }
               done ;;
            3) while true; do
                   read -s -p "$(print_status "INPUT" "New password: ")" v; echo
                   v="${v:-$PASSWORD}"
                   [ -n "$v" ] && { PASSWORD="$v"; break; } || print_status "ERROR" "Password cannot be empty"
               done ;;
            4) while true; do
                   read -p "$(print_status "INPUT" "New SSH port (current: $SSH_PORT): ")" v; v="${v:-$SSH_PORT}"
                   if validate_input "port" "$v"; then
                       if [ "$v" != "$SSH_PORT" ] && ss -tln 2>/dev/null | grep -q ":$v "; then
                           print_status "ERROR" "Port $v is already in use"
                       else
                           SSH_PORT="$v"; break
                       fi
                   fi
               done ;;
            5) while true; do
                   read -p "$(print_status "INPUT" "Enable GUI? (y/n, current: $GUI_MODE): ")" v
                   if [[ "$v" =~ ^[Yy]$ ]]; then GUI_MODE=true; break
                   elif [[ "$v" =~ ^[Nn]$ ]]; then GUI_MODE=false; break
                   elif [ -z "$v" ]; then break
                   else print_status "ERROR" "Please answer y or n"; fi
               done ;;
            6) read -p "$(print_status "INPUT" "Port forwards (current: ${PORT_FORWARDS:-None}): ")" v
               PORT_FORWARDS="${v:-$PORT_FORWARDS}" ;;
            7) while true; do
                   read -p "$(print_status "INPUT" "New memory MB (current: $MEMORY): ")" v; v="${v:-$MEMORY}"
                   validate_input "number" "$v" && { MEMORY="$v"; break; }
               done ;;
            8) while true; do
                   read -p "$(print_status "INPUT" "New CPU count (current: $CPUS): ")" v; v="${v:-$CPUS}"
                   validate_input "number" "$v" && { CPUS="$v"; break; }
               done ;;
            9) while true; do
                   read -p "$(print_status "INPUT" "New disk size (current: $DISK_SIZE): ")" v; v="${v:-$DISK_SIZE}"
                   validate_input "size" "$v" && { DISK_SIZE="$v"; break; }
               done ;;
            0) return 0 ;;
            *) print_status "ERROR" "Invalid selection"; continue ;;
        esac
 
        [[ "$edit_choice" =~ ^[1-3]$ ]] && { print_status "INFO" "Updating cloud-init config..."; setup_vm_image; }
        save_vm_config
 
        read -p "$(print_status "INPUT" "Continue editing? (y/N): ")" cont
        [[ ! "$cont" =~ ^[Yy]$ ]] && break
    done
}
 
# ─────────────────────────────────────────
# RESIZE DISK
# ─────────────────────────────────────────
resize_vm_disk() {
    local vm_name=$1
    if ! load_vm_config "$vm_name"; then return 1; fi
    if is_vm_running "$vm_name"; then
        print_status "ERROR" "Cannot resize disk while VM is running. Stop it first."
        return 1
    fi
 
    print_status "INFO" "Current disk size: $DISK_SIZE"
    while true; do
        read -p "$(print_status "INPUT" "New disk size (e.g., 50G): ")" new_size
        if validate_input "size" "$new_size"; then
            if qemu-img resize "$IMG_FILE" "$new_size"; then
                DISK_SIZE="$new_size"
                save_vm_config
                print_status "SUCCESS" "Disk resized to $new_size"
            else
                print_status "ERROR" "Failed to resize disk"
                return 1
            fi
            break
        fi
    done
}
 
# ─────────────────────────────────────────
# VM PERFORMANCE
# ─────────────────────────────────────────
show_vm_performance() {
    local vm_name=$1
    if load_vm_config "$vm_name"; then
        echo -e "${G}📈📈📈📈📈📈📈📈📈📈📈📈📈📈📈${N}"
        print_status "INFO" "Performance metrics for: $vm_name"
        if is_vm_running "$vm_name"; then
            local qemu_pid
            qemu_pid=$(pgrep -f "qemu-system.*$IMG_FILE" | head -1)
            if [[ -n "$qemu_pid" ]]; then
                echo -e "\n${C}⚡ QEMU Process Stats:${N}"
                ps -p "$qemu_pid" -o pid,%cpu,%mem,rss,vsz --no-headers
                echo -e "\n${C}🧠 Memory Usage:${N}"
                free -h
                echo -e "\n${C}💾 Disk Usage:${N}"
                du -h "$IMG_FILE"
            else
                print_status "ERROR" "Could not find QEMU process"
            fi
        else
            print_status "INFO" "VM is not running"
            echo -e "  🧠 Memory: $MEMORY MB | ⚡ CPUs: $CPUS | 💾 Disk: $DISK_SIZE"
        fi
        echo -e "${G}📈📈📈📈📈📈📈📈📈📈📈📈📈📈📈${N}"
        read -p "$(print_status "INPUT" "Press Enter to continue...")"
    fi
}
 
# ─────────────────────────────────────────
# FIX VM ISSUES
# ─────────────────────────────────────────
fix_vm_issues() {
    local vm_name=$1
    if ! load_vm_config "$vm_name"; then return 1; fi
    print_status "INFO" "Fixing issues for VM: $vm_name"
 
    echo -e "\n${Y}🔧 Select issue to fix:${N}"
    echo "  1) 🔓 Remove lock files"
    echo "  2) 🗑️  Recreate seed image"
    echo "  3) 🔄 Recreate configuration"
    echo "  4) 💀 Kill stuck processes"
    echo "  0) ↩️  Back"
    read -p "$(print_status "INPUT" "Enter your choice: ")" fix_choice
 
    case $fix_choice in
        1) rm -f "${IMG_FILE}.lock" "${IMG_FILE}"*.lock 2>/dev/null
           print_status "SUCCESS" "Lock files removed" ;;
        2) rm -f "$SEED_FILE"; setup_vm_image
           print_status "SUCCESS" "Seed image recreated" ;;
        3) save_vm_config
           print_status "SUCCESS" "Configuration recreated" ;;
        4) pkill -f "qemu-system.*$IMG_FILE" 2>/dev/null
           sleep 1
           pkill -9 -f "qemu-system.*$IMG_FILE" 2>/dev/null
           print_status "SUCCESS" "Killed stuck processes" ;;
        0) return 0 ;;
        *) print_status "ERROR" "Invalid selection" ;;
    esac
}
 

# ═══════════════════════════════════════════════════════════════
#  STATUS / INPUT HELPERS
# ═══════════════════════════════════════════════════════════════
 
print_status() {
    local type=$1
    local message=$2
    case $type in
        "INFO")    echo -e "  ${C}╠═ 📋 ${W}${message}${N}" ;;
        "WARN")    echo -e "  ${Y}╠═ ⚠️  ${Y}${message}${N}" ;;
        "ERROR")   echo -e "  ${R}╠═ ❌ ${R}${message}${N}" ;;
        "SUCCESS") echo -e "  ${G}╠═ ✅ ${G}${message}${N}" ;;
        "INPUT")   echo -en "  ${C}╠═ 🎯 ${W}${message}${N}" ;;
        "TITLE")   echo -e "  ${GOLD}╔═══ ${message} ═══╗${N}" ;;
        *)         echo "  [$type] $message" ;;
    esac
}
 
# ═══════════════════════════════════════════════════════════════
#  INPUT VALIDATION
# ═══════════════════════════════════════════════════════════════
 
validate_input() {
    local type=$1
    local value=$2
    case $type in
        "number")
            [[ "$value" =~ ^[0-9]+$ ]] || {
                print_status "ERROR" "Must be a whole number"; return 1; }
            ;;
        "size")
            [[ "$value" =~ ^[0-9]+[GgMm]$ ]] || {
                print_status "ERROR" "Must include a unit — e.g. 20G or 512M"; return 1; }
            ;;
        "port")
            if ! [[ "$value" =~ ^[0-9]+$ ]] || \
               [ "$value" -lt 23 ] || [ "$value" -gt 65535 ]; then
                print_status "ERROR" "Port must be a number between 23 and 65535"
                return 1
            fi
            ;;
        "name")
            [[ "$value" =~ ^[a-zA-Z0-9_-]+$ ]] || {
                print_status "ERROR" "Only letters, numbers, hyphens and underscores allowed"
                return 1; }
            ;;
        "username")
            [[ "$value" =~ ^[a-z_][a-z0-9_-]*$ ]] || {
                print_status "ERROR" "Must start with a lowercase letter or underscore"
                return 1; }
            ;;
    esac
    return 0
}
 
# ═══════════════════════════════════════════════════════════════
#  DEPENDENCY CHECK
# ═══════════════════════════════════════════════════════════════
 
check_dependencies() {
    local deps=("qemu-system-x86_64" "wget" "cloud-localds" "qemu-img" "lsof")
    local missing=()
    for dep in "${deps[@]}"; do
        command -v "$dep" &>/dev/null || missing+=("$dep")
    done
    if [ "${#missing[@]}" -ne 0 ]; then
        print_status "ERROR" "Missing: ${missing[*]}"
        print_status "INFO"  "Install: sudo apt install qemu-system cloud-image-utils wget lsof"
        exit 1
    fi
}
 
